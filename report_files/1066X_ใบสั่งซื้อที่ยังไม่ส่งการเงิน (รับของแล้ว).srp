  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID (NOLOCK) where HIDE='' or HIDE is null or HIDE='N'   order by DEPT_NAME                                                                                 " SpecificOptions.Text="" PropData="05704C6566740388000470546F700390000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select  i.PO_NO,i.INVOICE_NO,dbo.cymd2be(i.RECEIVE_DATE) as RCV_DATE,&#13;&#10;c.COMPANY_NAME,i.TOTAL_ITEM,dbo.cymd2be(p.PO_DATE) as PO_DATE,p.GF_NO,i.VENDOR_CODE,&#13;&#10;i.TOTAL_COST,i.RECEIVE_NO                                                &#13;&#10;from MS_IVO i (NOLOCK)&#13;&#10;left join MS_PO p (NOLOCK) on (i.PO_NO = p.REF_NO)&#13;&#10;left join COMPANY c (NOLOCK) on (p.VENDOR_CODE = c.COMPANY_CODE)&#13;&#10;where p.PO_DATE between  :date1  and :date2&#13;&#10;and not EXISTS(select * from DOC_FLOW_C d (NOLOCK) Where d.INVOICE_NO = i.INVOICE_NO )&#13;&#10;and i.TOTAL_COST &#62; 0&#13;&#10;AND p.BUY_COMMON&#60;&#62;99 AND p.BUY_METHOD&#60;&#62;99                                                                                                &#13;&#10;order by c.COMPANY_NAME,i.PO_NO                        " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
