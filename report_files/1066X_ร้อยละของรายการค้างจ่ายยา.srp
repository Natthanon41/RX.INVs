<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.7746115046" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; hosp_type:integer ;&#13;&#10; hosp_type_text:string ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  date1.date:=now -30 ;&#13;&#10;  date2.date:=now  ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;   DialogPage1.visible:=False ;&#13;&#10;&#13;&#10;   if RadioButton1.checked then qry_rp1.sql[9]:=' and d1.HOSP_TYPE=1 '&#13;&#10;   else if RadioButton2.Checked then  qry_rp1.sql[9]:=' and d1.HOSP_TYPE&#60;&#62;1 '&#13;&#10;   else  qry_rp1.sql[9]:='' ;&#13;&#10;&#13;&#10;   if RadioButton1.checked then hosp_type_text:=' คลังภายในโรงพยาบาล '&#13;&#10;   else if RadioButton2.Checked then hosp_type_text:=' คลังภายนอกโรงพยาบาล '&#13;&#10;   else  hosp_type_text:='รวมคลังภายในและภายนอกโรงพยาบาล' ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure GroupHeader1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="rp1"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}        &#13;&#10;&#13;&#10;select d1.DEPT_NAME,SUM(CASE when c.QTY_RCV &#60; c.QTY_ORDER then 1 else 0 end) as ITEM_ACCR,COUNT(c.TRADE_CODE) as ALL_ITEM,&#13;&#10;SUM(CASE when c.QTY_RCV &#60; c.QTY_ORDER then 1 else 0 end)*convert(real,100)/COUNT(c.TRADE_CODE) as PERCENT_OF_ACCR                               &#13;&#10;from SM_PO_C c  (NOLOCK)&#13;&#10;left join SM_PO s (NOLOCK) on (c.SUB_PO_NO = s.SUB_PO_NO)&#13;&#10;left join DEPT_ID d1 (NOLOCK) on (d1.DEPT_ID = s.DEPT_ID)&#13;&#10;where s.SUB_PO_DATE between :date1 and :date2&#13;&#10;and (c.CANCEL_DISP='N' or c.CANCEL_DISP='' or c.CANCEL_DISP is null)&#13;&#10;and c.CONFIRM_FLAG='Y'&#13;&#10;and s.STOCK_ID= :stock_id&#13;&#10;--insert sql here                                              &#13;&#10;group by d1.DEPT_NAME&#13;&#10;HAVING SUM(CASE when c.QTY_RCV &#60; c.QTY_ORDER then 1 else 0 end)*100/COUNT(c.TRADE_CODE) &#62; 0 &#13;&#10;order by SUM(CASE when c.QTY_RCV &#60; c.QTY_ORDER then 1 else 0 end)*100/COUNT(c.TRADE_CODE) DESC&#13;&#10;&#13;&#10;&#13;&#10;{ELSE}      &#13;&#10;&#13;&#10;select d1.DEPT_NAME,SUM(CASE when c.QTY_RCV &#60; c.QTY_ORDER then 1 else 0 end) as ITEM_ACCR,COUNT(c.TRADE_CODE) as ALL_ITEM,&#13;&#10;SUM(CASE when c.QTY_RCV &#60; c.QTY_ORDER then 1 else 0 end)*convert(real,100)/COUNT(c.TRADE_CODE) as PERCENT_OF_ACCR                               &#13;&#10;from SM_PO_C c &#13;&#10;left join SM_PO s on (c.SUB_PO_NO = s.SUB_PO_NO)&#13;&#10;left join DEPT_ID d1 on (d1.DEPT_ID = s.DEPT_ID)&#13;&#10;where s.SUB_PO_DATE between :date1 and :date2&#13;&#10;and (c.CANCEL_DISP='N' or c.CANCEL_DISP='' or c.CANCEL_DISP is null)&#13;&#10;and c.CONFIRM_FLAG='Y'&#13;&#10;and s.STOCK_ID= :stock_id&#13;&#10;--insert sql here                                              &#13;&#10;group by d1.DEPT_NAME&#13;&#10;HAVING SUM(CASE when c.QTY_RCV &#60; c.QTY_ORDER then 1 else 0 end)*100/COUNT(c.TRADE_CODE) &#62; 0 &#13;&#10;order by SUM(CASE when c.QTY_RCV &#60; c.QTY_ORDER then 1 else 0 end)*100/COUNT(c.TRADE_CODE) DESC     &#13;&#10;&#13;&#10;&#13;&#10;{ENDIF}      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where HIDE='' or HIDE is null  or HIDE ='N'&#13;&#10;and DEPT_TYPE in (2,3)                                                 &#13;&#10;order by DEPT_NAME                                        " SpecificOptions.Text="" PropData="05704C656674030C010470546F7003A8000A506172616D65746572730100"/>
  </TfrxDataPage>
