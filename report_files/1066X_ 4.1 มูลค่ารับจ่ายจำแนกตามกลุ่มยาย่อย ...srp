<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.0844528935" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  date1.date:=now ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:=&#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp" DataSetName="rp"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp" UserName="rp" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                             &#13;&#10;select s.SUB_COMMIT_DES,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED)='ED' and c.R_S_STATUS='R' and m.BUY_COMMON&#60;&#62;'99'  then  c.VALUE else NULL end)  as ED_AMT,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED)='NED' and c.R_S_STATUS='R' and m.BUY_COMMON&#60;&#62;'99'  then  c.VALUE else NULL end)   as NED_AMT,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED) not in ('ED','NED') and c.R_S_STATUS='R' and m.BUY_COMMON&#60;&#62;'99' then c.VALUE else NULL end) as UNC_AMT, &#13;&#10;SUM(CASE when  c.R_S_STATUS='R' and m.BUY_COMMON&#60;&#62;'99' then c.VALUE else NULL end) as ALL_AMT,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED)='ED' and c.R_S_STATUS='R' and m.BUY_COMMON='99'  then  c.VALUE else NULL end)  as DED_AMT,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED)='NED' and c.R_S_STATUS='R' and m.BUY_COMMON='99'  then  c.VALUE else NULL end)   as DNED_AMT,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED) not in ('ED','NED') and c.R_S_STATUS='R' and m.BUY_COMMON='99' then c.VALUE else NULL end) as DUNC_AMT, &#13;&#10;SUM(CASE when c.R_S_STATUS='R' and m.BUY_COMMON='99' then c.VALUE else NULL end) as DALL_AMT,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED)='ED' and c.R_S_STATUS&#60;&#62;'R'  then  c.VALUE else NULL end)  as XED_AMT,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED)='NED' and c.R_S_STATUS&#60;&#62;'R'   then  c.VALUE else NULL end)   as XNED_AMT,&#13;&#10;SUM(CASE when dbo.IS_ED(v.IS_ED) not in ('ED','NED') and c.R_S_STATUS&#60;&#62;'R'  then c.VALUE else NULL end) as XUNC_AMT, &#13;&#10;SUM(CASE when c.R_S_STATUS&#60;&#62;'R'  then c.VALUE else NULL end) as XALL_AMT&#13;&#10;from CARD c (NOLOCK)&#13;&#10;left join MS_IVO m (NOLOCK) on (c.R_S_NUMBER=m.RECEIVE_NO)&#13;&#10;left join DEPT_ID d (NOLOCK) on (c.DEPT_ID = d.DEPT_ID)&#13;&#10;left join DRUG_VN v (NOLOCK) on (c.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join ED_GROUP e (NOLOCK) on (g.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s (NOLOCK) on (e.SUB_COMMIT_CODE=s.SUB_COMMIT_CODE)&#13;&#10;where c.STOCK_ID=:stock&#13;&#10;and c.R_S_DATE between :date1 and :date2        &#13;&#10;group by s.SUB_COMMIT_DES     &#13;&#10;order by s.SUB_COMMIT_DES&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select s.SUB_COMMIT_DES,&#13;&#10;SUM(CASE when IS_ED(v.IS_ED)='ED' and c.R_S_STATUS='R' and m.BUY_COMMON&#60;&#62;'99'  then  c.VALUE else NULL end)  as ED_AMT,&#13;&#10;SUM(CASE when  IS_ED(v.IS_ED)='NED' and c.R_S_STATUS='R' and m.BUY_COMMON&#60;&#62;'99'  then  c.VALUE else NULL end)   as NED_AMT,&#13;&#10;SUM(CASE when  IS_ED(v.IS_ED) not in ('ED','NED') and c.R_S_STATUS='R' and m.BUY_COMMON&#60;&#62;'99' then c.VALUE else NULL end) as UNC_AMT, &#13;&#10;SUM(CASE when  c.R_S_STATUS='R' and m.BUY_COMMON&#60;&#62;'99' then c.VALUE else NULL end) as ALL_AMT,&#13;&#10;SUM(CASE when  IS_ED(v.IS_ED)='ED' and c.R_S_STATUS='R' and m.BUY_COMMON='99'  then  c.VALUE else NULL end)  as DED_AMT,&#13;&#10;SUM(CASE when  IS_ED(v.IS_ED)='NED' and c.R_S_STATUS='R' and m.BUY_COMMON='99'  then  c.VALUE else NULL end)   as DNED_AMT,&#13;&#10;SUM(CASE when  IS_ED(v.IS_ED) not in ('ED','NED') and c.R_S_STATUS='R' and m.BUY_COMMON='99' then c.VALUE else NULL end) as DUNC_AMT, &#13;&#10;SUM(CASE when c.R_S_STATUS='R' and m.BUY_COMMON='99' then c.VALUE else NULL end) as DALL_AMT,&#13;&#10;SUM(CASE when  IS_ED(v.IS_ED)='ED' and c.R_S_STATUS&#60;&#62;'R'  then  c.VALUE else NULL end)  as XED_AMT,&#13;&#10;SUM(CASE when  IS_ED(v.IS_ED)='NED' and c.R_S_STATUS&#60;&#62;'R'   then  c.VALUE else NULL end)   as XNED_AMT,&#13;&#10;SUM(CASE when  IS_ED(v.IS_ED) not in ('ED','NED') and c.R_S_STATUS&#60;&#62;'R'  then c.VALUE else NULL end) as XUNC_AMT, &#13;&#10;SUM(CASE when c.R_S_STATUS&#60;&#62;'R'  then c.VALUE else NULL end) as XALL_AMT&#13;&#10;from CARD c &#13;&#10;left join MS_IVO m on (c.R_S_NUMBER=m.RECEIVE_NO)&#13;&#10;left join DEPT_ID d on (c.DEPT_ID = d.DEPT_ID)&#13;&#10;left join DRUG_VN v on (c.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join DRUG_GN g on (c.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join ED_GROUP e on (g.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s on (e.SUB_COMMIT_CODE=s.SUB_COMMIT_CODE)&#13;&#10;where c.STOCK_ID=:stock&#13;&#10;and c.R_S_DATE between :date1 and :date2        &#13;&#10;group by s.SUB_COMMIT_DES     &#13;&#10;order by s.SUB_COMMIT_DES&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                             &#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;and DEPT_TYPE=2&#13;&#10;{ELSE}&#13;&#10;select * from DEPT_ID  where (HIDE='' or HIDE is null or HIDE='N')     &#13;&#10;and DEPT_TYPE=2  &#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData="05704C65667402480470546F700380000A506172616D65746572730100"/>
  </TfrxDataPage>
