    <TfrxReportSummary Name="ReportSummary1" FillType="ftBrush" FillGap.Top="0" FillGap.Left="0" FillGap.Bottom="0" FillGap.Right="0" Frame.Typ="0" Height="83.14966" Left="0" Top="252" Width="1046.92981">
      <TfrxMemoView Name="Memo23" AllowVectorExport="True" Left="3.77953" Top="50.13389" Width="1039.37075" Height="26.45671" DisplayFormat.FormatStr="%2.2n" DisplayFormat.Kind="fkNumeric" Font.Charset="1" Font.Color="255" Font.Height="-21" Font.Name="AngsanaUPC" Font.Style="0" Frame.Typ="0" HAlign="haCenter" ParentFont="False" Text="[IIF(SUM(&#60;rp.&#34;UNC_AMT&#34;&#62;+&#60;rp.&#34;DUNC_AMT&#34;&#62;+&#60;rp.&#34;XUNC_AMT&#34;&#62;,MasterData1) &#62; 0,'มีรายการที่จำแนกประเภท ED/NED ไม่ได้  '+inttostr(SUM(&#60;rp.&#34;UNC_AMT&#34;&#62;+&#60;rp.&#34;DUNC_AMT&#34;&#62;+&#60;rp.&#34;XUNC_AMT&#34;&#62;,MasterData1) )+' บาท ','')]"/>
