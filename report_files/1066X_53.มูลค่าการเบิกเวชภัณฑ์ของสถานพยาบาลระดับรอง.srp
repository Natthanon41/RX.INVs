  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
    <item Name="USER_ID"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;  &#13;&#10;select t.DIST_TYPE_NAME,s.REF_NO,s.SUB_PO_DATE,d.DEPT_NAME,s.SUB_PO_NO,SUM(CASE when g.IS_ED in (1,2) then c.[VALUE] else 0 end) as MED,&#13;&#10;SUM(CASE when g.IS_ED not in (1,2) then c.[VALUE] else 0 end) as MEDSUP,&#13;&#10;(select SUM(s2.TOTAL_VALUE) from SM_PO s2 (NOLOCK) where s2.TOTAL_VALUE &#62; 0 &#13;&#10;and s2.STOCK_ID=s.STOCK_ID and s2.DEPT_ID=s.DEPT_ID &#13;&#10;and s2.SUB_PO_DATE &#62;= dbo.BEGIN_FY(getdate()) and  s2.SUB_PO_DATE &#60; :ymd /* and s2.SUB_PO_NO=s.SUB_PO_NO */) as BF,&#13;&#10;(select SUM(s2.TOTAL_VALUE) from SM_PO s2 (NOLOCK) where s2.TOTAL_VALUE &#62; 0    &#13;&#10;and s2.STOCK_ID=s.STOCK_ID and s2.DEPT_ID=s.DEPT_ID &#13;&#10;and s2.SUB_PO_DATE between dbo.BEGIN_FY(getdate()) and :ym +'31'  ) as BUY_ALL,&#13;&#10;s.TOTAL_ITEM                                    &#13;&#10;from SM_PO_C c (NOLOCK) &#13;&#10;left join SM_PO s (NOLOCK) on (c.SUB_PO_NO = s.SUB_PO_NO)&#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join DEPT_ID d (NOLOCK) on (d.DEPT_ID = s.DEPT_ID)&#13;&#10;left join DIST_TYPE t (NOLOCK) on (t.DIST_TYPE_CODE = s.DIST_TYPE)                                                                                                                                                                           &#13;&#10;where d.HOSP_TYPE=3 and left(s.SUB_PO_DATE,6)=:ym2        &#13;&#10;&#13;&#10;                                                           &#13;&#10;and s.TOTAL_ITEM &#62; 0&#13;&#10;and (c.CANCEL_DISP='' or c.CANCEL_DISP is null or c.CANCEL_DISP='N')&#13;&#10;and c.CONFIRM_FLAG='Y'               &#13;&#10;GROUP BY s.TOTAL_ITEM, s.REF_NO,s.SUB_PO_DATE,d.DEPT_NAME,s.SUB_PO_NO,s.STOCK_ID,s.DEPT_ID,t.DIST_TYPE_NAME    &#13;&#10;order by d.DEPT_NAME&#13;&#10;&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;&#13;&#10;select t.DIST_TYPE_NAME,s.REF_NO,s.SUB_PO_DATE,d.DEPT_NAME,s.SUB_PO_NO,SUM(CASE when g.IS_ED in (1,2) then c.`VALUE` else 0 end) as MED,&#13;&#10;SUM(CASE when g.IS_ED not in (1,2) then c.`VALUE` else 0 end) as MEDSUP,&#13;&#10;(select SUM(s2.TOTAL_VALUE) from SM_PO s2 where s2.TOTAL_VALUE &#62; 0 &#13;&#10;and s2.STOCK_ID=s.STOCK_ID and s2.DEPT_ID=s.DEPT_ID &#13;&#10;and s2.SUB_PO_DATE &#62;= BEGIN_FY(CURRENT_DATE()) and  s2.SUB_PO_DATE &#60; :ymd /* and s2.SUB_PO_NO=s.SUB_PO_NO */) as BF,&#13;&#10;(select SUM(s2.TOTAL_VALUE) from SM_PO s2 where s2.TOTAL_VALUE &#62; 0    &#13;&#10;and s2.STOCK_ID=s.STOCK_ID and s2.DEPT_ID=s.DEPT_ID &#13;&#10;and s2.SUB_PO_DATE between BEGIN_FY(CURRENT_DATE()) and :ym +'31'  ) as BUY_ALL,&#13;&#10;s.TOTAL_ITEM                                    &#13;&#10;from SM_PO_C c &#13;&#10;left join SM_PO s on (c.SUB_PO_NO = s.SUB_PO_NO)&#13;&#10;left join DRUG_GN g on (c.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join DEPT_ID d on (d.DEPT_ID = s.DEPT_ID)&#13;&#10;left join DIST_TYPE t on (t.DIST_TYPE_CODE = s.DIST_TYPE)                                                                                                                                                                           &#13;&#10;where d.HOSP_TYPE=3 and left(s.SUB_PO_DATE,6)=:ym2        &#13;&#10;&#13;&#10;                                                           &#13;&#10;and s.TOTAL_ITEM &#62; 0&#13;&#10;and (c.CANCEL_DISP='' or c.CANCEL_DISP is null or c.CANCEL_DISP='N')&#13;&#10;and c.CONFIRM_FLAG='Y'               &#13;&#10;GROUP BY s.TOTAL_ITEM, s.REF_NO,s.SUB_PO_DATE,d.DEPT_NAME,s.SUB_PO_NO,s.STOCK_ID,s.DEPT_ID,t.DIST_TYPE_NAME    &#13;&#10;order by d.DEPT_NAME    &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;{endif}          &#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;  &#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;and DEPT_TYPE=2                                         &#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;select * from DEPT_ID where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;and DEPT_TYPE=2                                         &#13;&#10;order by DEPT_NAME    &#13;&#10;&#13;&#10;&#13;&#10;{endif}      " SpecificOptions.Text="" PropData="05704C65667402640470546F7003EC000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_all_disp" UserName="rp2" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;&#13;&#10;  &#13;&#10;select SUM(s2.TOTAL_VALUE) as ALL_BUY,COUNT(s2.SUB_PO_NO) as COUNTPO,SUM(s2.TOTAL_ITEM) as COUNTITEM&#13;&#10;from SM_PO s2 (NOLOCK)&#13;&#10;left join DEPT_ID d (NOLOCK) on (d.DEPT_ID = s2.DEPT_ID)    &#13;&#10;where &#13;&#10;s2.TOTAL_VALUE &#62; 0&#13;&#10;and s2.TOTAL_ITEM &#62; 0    &#13;&#10;and s2.SUB_PO_DATE between dbo.BEGIN_FY(getdate()) and :ym +'31'  &#13;&#10;and d.HOSP_TYPE=3        &#13;&#10;and s2.STOCK_ID=:stock_id&#13;&#10;&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;select SUM(s2.TOTAL_VALUE) as ALL_BUY,COUNT(s2.SUB_PO_NO) as COUNTPO,SUM(s2.TOTAL_ITEM) as COUNTITEM&#13;&#10;from SM_PO s2&#13;&#10;left join DEPT_ID d on (d.DEPT_ID = s2.DEPT_ID)    &#13;&#10;where &#13;&#10;s2.TOTAL_VALUE &#62; 0&#13;&#10;and s2.TOTAL_ITEM &#62; 0    &#13;&#10;and s2.SUB_PO_DATE between BEGIN_FY(CURRENT_DATE()) and :ym +'31'  &#13;&#10;and d.HOSP_TYPE=3        &#13;&#10;and s2.STOCK_ID=:stock_id    &#13;&#10;&#13;&#10;&#13;&#10;{endif}      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_dist_type" UserName="dist_type" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DIST_TYPE                                           " SpecificOptions.Text="" PropData="05704C65667402600470546F700340010A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_user" UserName="user" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from profile where UserCode=:usercode                                                                                                                                                                                                                                                                                                " SpecificOptions.Text="" PropData="05704C65667402640470546F7003A4010A506172616D657465727301010643204E616D653D2275736572636F6465222044617461547970653D226674537472696E67222045787072657373696F6E3D22262336303B555345525F4944262336323B220000"/>
  </TfrxDataPage>
