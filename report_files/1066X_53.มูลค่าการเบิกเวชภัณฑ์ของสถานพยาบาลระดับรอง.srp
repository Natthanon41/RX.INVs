<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.8989186574" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  ym,m,ymd ,STOCK_DES : string ;&#13;&#10;  Line_no,trimes: integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  m1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),5,2) ;&#13;&#10;    y1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),1,4) ;&#13;&#10;&#13;&#10;  qry_dist_type.close ;&#13;&#10;  qry_dist_type.open ;&#13;&#10;&#13;&#10; // qry_dist_type.first ;&#13;&#10;  cbb_distType.keyvalue:=1 ; //qry_dist_type.fieldbyname('DIST_TYPE_CODE').asinteger  ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;   if strtoint(m1.text) &#60; 10 then m:='0'+inttostr(strtoint(m1.text)) else m:=m1.text ;&#13;&#10;   ym:=inttostr(strtoint(y1.text)-543)+m  ;&#13;&#10;   ymd:=ym+'01' ;&#13;&#10;&#13;&#10;   CASE  strtoint(m1.text) of&#13;&#10;     1:trimes:=2 ;&#13;&#10;     2:trimes:=2 ;&#13;&#10;     3:trimes:=2 ;&#13;&#10;     4:trimes:=3;&#13;&#10;     5:trimes:=3 ;&#13;&#10;     6:trimes:=3 ;&#13;&#10;     7:trimes:=4  ;&#13;&#10;     8:trimes:=4;&#13;&#10;     9:trimes:=4;&#13;&#10;     10:trimes:=1;&#13;&#10;     11:trimes:=1 ;&#13;&#10;     12:trimes:=1  ;&#13;&#10;   end;&#13;&#10;&#13;&#10;   qry_rp1.Close ;&#13;&#10;&#13;&#10;   if chk_allStock.checked then&#13;&#10;   begin&#13;&#10;     qry_rp1.SQL[15]:='' ;&#13;&#10;     STOCK_DES:='ทุกคลัง' ;&#13;&#10;   end&#13;&#10;   else&#13;&#10;   begin&#13;&#10;     STOCK_DES:=cbb_stock.text ;&#13;&#10;     qry_rp1.SQL[15]:=' and s.STOCK_ID='+''''+cbb_stock.keyvalue+'''' ;&#13;&#10;   end;&#13;&#10;&#13;&#10;   if  chk_dis_type.checked then&#13;&#10;   begin&#13;&#10;    qry_rp1.SQL[16]:='' ;&#13;&#10;&#13;&#10;   end&#13;&#10;   else&#13;&#10;   begin&#13;&#10;     qry_rp1.SQL[16]:='  and s.DIST_TYPE='+''''+inttostr(cbb_distType.keyvalue)+'''' ;&#13;&#10;   end;&#13;&#10;&#13;&#10;   qry_rp1.open ;&#13;&#10;&#13;&#10;end ;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  line_no:= 0 ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure GroupHeader1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   line_no:=line_no+1 ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure chk_allStockOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if chk_allStock.checked then cbb_stock.enabled:=False else cbb_stock.enabled:=True ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure CheckBox1OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if chk_dis_type.checked then cbb_distType.enabled:=False else cbb_distType.enabled:=True ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="rp1"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
    <item DataSet="qry_all_disp" DataSetName="rp2"/>
    <item DataSet="qry_dist_type" DataSetName="dist_type"/>
    <item DataSet="qry_user" DataSetName="user"/>
