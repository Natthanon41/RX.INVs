<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="43066.6190786458" ReportOptions.Description.Text="" ReportOptions.LastChange="45240.4955277199" ScriptLanguage="PascalScript" ScriptText.Text="procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    date1.date:=now - 30  ;&#13;&#10;  date2.date:=now  ;&#13;&#10;&#13;&#10;  qry_dept.close ;&#13;&#10;  qry_dept.open ;&#13;&#10;&#13;&#10;  cbb_dept.keyvalue:=&#60;MY_STOCK_CODE&#62; ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="frxReport1OnReportPrint">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="rp1"/>
    <item DataSet="qry_dept" DataSetName="dept"/>
  </Datasets>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                                     &#13;&#10;&#13;&#10;SELECT s.STOCK_ID, s.DEPT_ID, d.DEPT_NAME, c.WORKING_CODE, g.DRUG_NAME, c.TRADE_CODE, v.TRADE_NAME, c.PACK_RATIO, &#13;&#10;u.SALE_UNIT, t.SALE_UNIT AS PACK_UNIT_DESC, c.BUY_UNIT_COST, &#13;&#10;SUM(c.`VALUE`) AS VALUEX, SUM(c.QTY_RCV) AS QTY&#13;&#10;FROM sm_po s&#13;&#10;LEFT JOIN sm_po_c c ON c.SUB_PO_NO = s.SUB_PO_NO&#13;&#10;LEFT JOIN dept_id d ON d.DEPT_ID = s.DEPT_ID&#13;&#10;LEFT JOIN drug_gn g ON g.WORKING_CODE = c.WORKING_CODE&#13;&#10;LEFT JOIN drug_vn v ON v.TRADE_CODE = c.TRADE_CODE&#13;&#10;LEFT JOIN sale_unit u ON u.SU_ID = g.SALE_UNIT_ID&#13;&#10;LEFT JOIN pack_ratio p ON p.PACK_CODE = c.PACK_CODE&#13;&#10;LEFT JOIN sale_unit t ON t.SU_ID = p.PACK_UNIT&#13;&#10;WHERE s.SUB_PO_DATE BETWEEN :date1  and :date2&#13;&#10;AND s.STOCK_ID =:stockid&#13;&#10;AND s.CONFIRM_FLAG = 'Y' AND c.CANCEL_DISP IS NULL                     &#13;&#10;GROUP BY s.STOCK_ID, s.DEPT_ID, d.DEPT_NAME, c.WORKING_CODE, g.DRUG_NAME, c.TRADE_CODE, v.TRADE_NAME, &#13;&#10;u.SALE_UNIT, t.SALE_UNIT, c.BUY_UNIT_COST, c.PACK_RATIO  &#13;&#10;HAVING SUM(c.QTY_RCV) &#62; 0&#13;&#10;ORDER BY s.DEPT_ID, c.WORKING_CODE, c.TRADE_CODE      &#13;&#10;&#13;&#10;{ELSE}&#13;&#10;  &#13;&#10;SELECT s.STOCK_ID, s.DEPT_ID, d.DEPT_NAME, c.WORKING_CODE, g.DRUG_NAME, c.TRADE_CODE, v.TRADE_NAME, c.PACK_RATIO, &#13;&#10;u.SALE_UNIT, t.SALE_UNIT AS PACK_UNIT_DESC, c.BUY_UNIT_COST, &#13;&#10;SUM(c.`VALUE`) AS VALUEX, SUM(c.QTY_RCV) AS QTY&#13;&#10;FROM sm_po s&#13;&#10;LEFT JOIN sm_po_c c ON c.SUB_PO_NO = s.SUB_PO_NO&#13;&#10;LEFT JOIN dept_id d ON d.DEPT_ID = s.DEPT_ID&#13;&#10;LEFT JOIN drug_gn g ON g.WORKING_CODE = c.WORKING_CODE&#13;&#10;LEFT JOIN drug_vn v ON v.TRADE_CODE = c.TRADE_CODE&#13;&#10;LEFT JOIN sale_unit u ON u.SU_ID = g.SALE_UNIT_ID&#13;&#10;LEFT JOIN pack_ratio p ON p.PACK_CODE = c.PACK_CODE&#13;&#10;LEFT JOIN sale_unit t ON t.SU_ID = p.PACK_UNIT&#13;&#10;WHERE s.SUB_PO_DATE BETWEEN :date1  and :date2&#13;&#10;AND s.STOCK_ID =:stockid&#13;&#10;AND s.CONFIRM_FLAG = 'Y' AND c.CANCEL_DISP IS NULL  &#13;&#10;GROUP BY s.STOCK_ID, s.DEPT_ID, d.DEPT_NAME, c.WORKING_CODE, g.DRUG_NAME, c.TRADE_CODE, v.TRADE_NAME, &#13;&#10;u.SALE_UNIT, t.SALE_UNIT, c.BUY_UNIT_COST, c.PACK_RATIO  &#13;&#10;HAVING SUM(c.QTY_RCV) &#62; 0&#13;&#10;ORDER BY s.DEPT_ID, c.WORKING_CODE, c.TRADE_CODE            &#13;&#10;  &#13;&#10;{ENDIF}                &#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_dept" UserName="dept" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;  select * from DEPT_ID (NOLOCK) where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=2&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;  select * from DEPT_ID  where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=2&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData="05704C6566740384000470546F7003BC000A506172616D65746572730100"/>
  </TfrxDataPage>
