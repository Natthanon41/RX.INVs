<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="42119.8655733102" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.1025032407" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  date1.date:=now - 90 ;&#13;&#10;  date2.date:=now  ;&#13;&#10;&#13;&#10;  qry_dept.close ;&#13;&#10;  qry_dept.open ;&#13;&#10;&#13;&#10;  cbb_dept.keyvalue:=&#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="rp1"/>
    <item DataSet="qry_dept" DataSetName="dept"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select g.WORKING_CODE,g.DRUG_NAME,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.ACTIVE_QTY&#13;&#10;         when c.R_S_STATUS in ('B') then c.ACTIVE_QTY*-1 else NULL end    &#13;&#10;) as R_QTY,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.COST &#13;&#10;         when c.R_S_STATUS in ('B') then c.COST*-1 else NULL end&#13;&#10; ) as R_AMT,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('T','S')then c.ACTIVE_QTY &#13;&#10;         when c.R_S_STATUS='C' then c.ACTIVE_QTY*-1&#13;&#10;         else NULL end) as S_QTY,    &#13;&#10;SUM(CASE when c.R_S_STATUS in ('T','S')  then c.COST &#13;&#10;         when (c.R_S_STATUS='C') then c.COST*-1 else NULL end) as S_AMT ,&#13;&#10;(select top 1 z.PACK_RATIO  from PACK_RATIO  z where z.WORKING_CODE=c.WORKING_CODE order by  z.LAST_BUY DESC) as PACK_RATIO,u.SALE_UNIT,&#13;&#10;case when (select top 1 i.STD_PRICE from INV_MD i (NOLOCK) where i.WORKING_CODE=c.WORKING_CODE and i.DEPT_ID=c.STOCK_ID) is null then&#13;&#10;(select top 1 z.BUY_UNIT_COST  from PACK_RATIO  z where z.WORKING_CODE=c.WORKING_CODE order by  z.LAST_BUY DESC) else&#13;&#10;(select top 1 i.STD_PRICE from INV_MD i (NOLOCK) where i.WORKING_CODE=c.WORKING_CODE and i.DEPT_ID=c.STOCK_ID) end as U_PRICE,&#13;&#10;g.GROUP_CODE,e.NAME as ED_NAME,s.SUB_COMMIT_DES,&#13;&#10;h.HOSP_LIST_DESC,dbo.IS_ED(g.IS_ED) as IS_ED,dbo.ED_LIST(g.ED_LIST) as ED_LIST, CASE when v.TRADE_FLAG=0 then 'Original' else ' Generic' end as 'O/G',&#13;&#10;dbo.FiscalYear(c.R_S_DATE)  as 'FiscalYear'      &#13;&#10;from CARD c (NOLOCK)&#13;&#10;left join DRUG_VN v (NOLOCK) on (c.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join SALE_UNIT u (NOLOCK) on (g.SALE_UNIT_ID=u.SU_ID)                                                                                                                                     &#13;&#10;left join ED_GROUP e (NOLOCK) on (g.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s (NOLOCK) on (g.SUBCOM=s.SUB_COMMIT_CODE)&#13;&#10;left join HOSP_LIST h (NOLOCK) on (g.HOSP_LIST=h.HOSP_LIST_CODE)      &#13;&#10;left join INV_MD i (NOLOCK) on (c.WORKING_CODE=i.WORKING_CODE and i.DEPT_ID=c.STOCK_ID)&#13;&#10;left join DEPT_ID d (NOLOCK) on (c.STOCK_ID=d.DEPT_ID)                                                                                                                    &#13;&#10;where d.DEPT_TYPE='2'                               &#13;&#10;and c.R_S_DATE between :date1 and :date2  and c.STOCK_ID=:stockid                                                                         &#13;&#10;group by g.DRUG_NAME,s.SUB_COMMIT_DES,e.NAME,h.HOSP_LIST_DESC,u.SALE_UNIT,c.WORKING_CODE,dbo.IS_ED(g.IS_ED),g.GROUP_CODE ,dbo.ED_LIST(g.ED_LIST) ,&#13;&#10;CASE when v.TRADE_FLAG=0 then 'Original' else ' Generic' end,g.WORKING_CODE ,dbo.FiscalYear(c.R_S_DATE),c.STOCK_ID              &#13;&#10;order by g.DRUG_NAME  &#13;&#10;&#13;&#10; {ELSE}&#13;&#10;&#13;&#10;select g.WORKING_CODE,g.DRUG_NAME,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.ACTIVE_QTY&#13;&#10;         when c.R_S_STATUS in ('B') then c.ACTIVE_QTY*-1 else NULL end    &#13;&#10;) as R_QTY,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.COST &#13;&#10;         when c.R_S_STATUS in ('B') then c.COST*-1 else NULL end&#13;&#10; ) as R_AMT,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('T','S')then c.ACTIVE_QTY &#13;&#10;         when c.R_S_STATUS='C' then c.ACTIVE_QTY*-1&#13;&#10;         else NULL end) as S_QTY,    &#13;&#10;SUM(CASE when c.R_S_STATUS in ('T','S')  then c.COST &#13;&#10;         when (c.R_S_STATUS='C') then c.COST*-1 else NULL end) as S_AMT ,&#13;&#10;(select  z.PACK_RATIO  from PACK_RATIO  z where z.WORKING_CODE=c.WORKING_CODE order by  z.LAST_BUY DESC limit 1  ) as PACK_RATIO,u.SALE_UNIT,&#13;&#10;case when (select  i.STD_PRICE from INV_MD i  where i.WORKING_CODE=c.WORKING_CODE and i.DEPT_ID=c.STOCK_ID limit 1 ) is null then&#13;&#10;(select  z.BUY_UNIT_COST  from PACK_RATIO  z where z.WORKING_CODE=c.WORKING_CODE order by  z.LAST_BUY DESC limit 1 ) else&#13;&#10;(select  i.STD_PRICE from INV_MD i  where i.WORKING_CODE=c.WORKING_CODE and i.DEPT_ID=c.STOCK_ID limit 1) end as U_PRICE,&#13;&#10;g.GROUP_CODE,e.NAME as ED_NAME,s.SUB_COMMIT_DES,&#13;&#10;h.HOSP_LIST_DESC,IS_ED(g.IS_ED) as IS_ED,ED_LIST(g.ED_LIST) as ED_LIST, CASE when v.TRADE_FLAG=0 then 'Original' else ' Generic' end as 'O/G',&#13;&#10;FiscalYear(c.R_S_DATE)  as 'FiscalYear'      &#13;&#10;from CARD c &#13;&#10;left join DRUG_VN v  on (c.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join DRUG_GN g  on (c.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join SALE_UNIT u  on (g.SALE_UNIT_ID=u.SU_ID)                                                                                                                                     &#13;&#10;left join ED_GROUP e  on (g.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s  on (g.SUBCOM=s.SUB_COMMIT_CODE)&#13;&#10;left join HOSP_LIST h  on (g.HOSP_LIST=h.HOSP_LIST_CODE)      &#13;&#10;left join INV_MD i  on (c.WORKING_CODE=i.WORKING_CODE and i.DEPT_ID=c.STOCK_ID)&#13;&#10;left join DEPT_ID d  on (c.STOCK_ID=d.DEPT_ID)                                                                                                                    &#13;&#10;where d.DEPT_TYPE='2'                               &#13;&#10;and c.R_S_DATE between :date1 and :date2  and c.STOCK_ID=:stockid                                                                         &#13;&#10;group by g.DRUG_NAME,s.SUB_COMMIT_DES,e.NAME,h.HOSP_LIST_DESC,u.SALE_UNIT,c.WORKING_CODE,IS_ED(g.IS_ED),g.GROUP_CODE ,ED_LIST(g.ED_LIST) ,&#13;&#10;CASE when v.TRADE_FLAG=0 then 'Original' else ' Generic' end,g.WORKING_CODE ,FiscalYear(c.R_S_DATE),c.STOCK_ID              &#13;&#10;order by g.DRUG_NAME  &#13;&#10;&#13;&#10;&#13;&#10; {ENDIF}    &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_dept" UserName="dept" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;select * from DEPT_ID where (HIDE is null or HIDE='' or HIDE='N')&#13;&#10; {ELSE}                               &#13;&#10;select * from DEPT_ID where (HIDE is null or HIDE='' or HIDE='N')   &#13;&#10; {ENDIF}    " SpecificOptions.Text="" PropData="05704C656674034C010470546F700308010A506172616D65746572730100"/>
  </TfrxDataPage>
