  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_location" UserName="location" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                                     &#13;&#10;select DISTINCT LOCATION from INV_MD (NOLOCK) where DEPT_ID=:dept_id&#13;&#10;ORDER BY LOCATION&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select DISTINCT LOCATION from INV_MD  where DEPT_ID=:dept_id&#13;&#10;ORDER BY LOCATION&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_inv_md" UserName="invmd" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select T.* FROM&#13;&#10;(&#13;&#10;select i.WORKING_CODE,i.TOTAL_VALUE,@PercentValue := @PercentValue + ifnull(i.TOTAL_VALUE,0)*100/(select sum(x.TOTAL_VALUE)&#13;&#10;from INV_MD x  where x.DEPT_ID=i.DEPT_ID )    &#13;&#10; as PerCum,&#13;&#10; cast(i.QTY_ON_HAND AS SIGNED)%cast(i.FIRST_PACK_RATIO AS SIGNED) as UNPACK,   &#13;&#10; g.DRUG_NAME,i.LOCATION,i.FIRST_PACK_RATIO,i.LAST_PACK_RATIO,i.QTY_ON_HAND&#13;&#10;   &#13;&#10;from INV_MD i &#13;&#10;left join DRUG_GN g  on (i.WORKING_CODE = g.WORKING_CODE)&#13;&#10;JOIN (SELECT @PercentValue := 0) r    &#13;&#10;where i.DEPT_ID=:dept_id             &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  &#13;&#10;     &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10; ) as T where T.PerCum &#60;= :RM_PERCENT  &#13;&#10;      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_inv_md_c" UserName="invmd_c" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select cast(i.QTY_ON_HAND AS SIGNED)%cast(i.PACK_RATIO AS SIGNED) as UNPACK, g.DRUG_NAME,v.TRADE_CODE,v.TRADE_NAME,i.* &#13;&#10;from INV_MD_C i &#13;&#10;left join DRUG_GN g  on (i.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join DRUG_VN v  on (i.TRADE_CODE = v.TRADE_CODE)                                                                                                                                          &#13;&#10;where i.DEPT_ID=:dept_id and i.WORKING_CODE=:WORKING_CODE                                                                          " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
