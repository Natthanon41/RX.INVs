<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="42119.8655733102" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.820317662" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;WCODE:string ;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  date1.date:=now -30  ;&#13;&#10;  date2.date:=now  ;&#13;&#10;&#13;&#10;  qry_dept.close ;&#13;&#10;  qry_dept.open ;&#13;&#10;&#13;&#10;  cbb_dept.keyvalue:=&#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  qry_vd.close ;&#13;&#10;  qry_vd.open ;&#13;&#10;&#13;&#10;  cbb_vd.keyvalue:=30 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure keywordOnKeyUp(Sender: TfrxComponent; var Key: Word; Shift: Integer);&#13;&#10;begin&#13;&#10;    if trim(keyword.text)='' then exit;&#13;&#10;&#13;&#10;  qry_medItem.close ;&#13;&#10;  qry_medItem.ParamByName('working_code').value:=trim(keyword.text);&#13;&#10;  qry_medItem.ParamByName('drug_name').value:='%'+ uppercase(trim(keyword.text)) +'%' ;&#13;&#10;  qry_medItem.open ;&#13;&#10;&#13;&#10;   listbox1.Items.Clear  ;&#13;&#10;&#13;&#10;  while not qry_medItem.eof do&#13;&#10;  begin&#13;&#10;&#13;&#10;     listbox1.Items.Add(trim(qry_medItem.FieldByName('WORKING_CODE').asString)+': '+qry_medItem.FieldByName('DRUG_NAME').asString) ;&#13;&#10;&#13;&#10;  qry_medItem.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure BitBtn1OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure ListBox1OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  WCODE:=listbox1.Items.Strings(listbox1.itemindex) ;&#13;&#10;  WCODE:=COPY(WCODE,1,POS(':',WCODE)-1) ;&#13;&#10;&#13;&#10;  qry_vd.close ;&#13;&#10;  qry_vd.ParamByName('wcode').value:=WCODE ;&#13;&#10;  qry_vd.open ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="rp1"/>
    <item DataSet="qry_dept" DataSetName="dept"/>
    <item DataSet="qry_vd" DataSetName="vd"/>
    <item DataSet="qry_medItem" DataSetName="med"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}    &#13;&#10;&#13;&#10;select m.DEPT_ID,m.INVOICE_NO,m.RECEIVE_NO,m.PO_NO,dbo.cymd2be(m.PO_DATE) as PODATE,v.COMPANY_NAME as VENDOR_NAME,c.QTY_ORDER,c.QTY_RCV,&#13;&#10;c.COST,c.PACK_RATIO,s1.SALE_UNIT as SUBPACKUNIT,&#13;&#10;s2.SALE_UNIT as PACKUNIT,dbo.IS_ED(g.IS_ED) as ED_FLAG,&#13;&#10;CASE when c.FREE_FLAG='N' then c.[VALUE] else 0 end as VALUE_PO,&#13;&#10;CASE when c.FREE_FLAG&#60;&#62;'N' then c.[VALUE] else 0 end as VALUE_FREE,&#13;&#10;c.BUY_UNIT_COST,c.WORKING_CODE,g.DRUG_NAME&#13;&#10;from MS_IVO m (NOLOCK)&#13;&#10;left join MS_IVO_C c (NOLOCK) on (c.RECEIVE_NO=m.RECEIVE_NO and c.REV_FLAG='N')                                                                                                            &#13;&#10;left join COMPANY v (NOLOCK) on (v.COMPANY_CODE=m.VENDOR_CODE)   &#13;&#10;left JOIN PACK_RATIO p on (p.PACK_CODE=c.PACK_CODE)&#13;&#10;left join SALE_UNIT s1 (NOLOCK) on (s1.SU_ID=p.SUBPACK_UNIT)     &#13;&#10;left join SALE_UNIT s2 (NOLOCK) on (s2.SU_ID=p.PACK_UNIT)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE = g.WORKING_CODE)                                                                                                                              &#13;&#10;where m.RECEIVE_DATE between :date1 and :date2  and m.DEPT_ID=:stockid&#13;&#10;and m.VENDOR_CODE=:vd                                             &#13;&#10;and c.REV_FLAG='N'  and c.WORKING_CODE=:wcode                                                     &#13;&#10;order by m.RECEIVE_DATE&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;select m.DEPT_ID,m.INVOICE_NO,m.RECEIVE_NO,m.PO_NO,cymd2be(m.PO_DATE) as PODATE,v.COMPANY_NAME as VENDOR_NAME,c.QTY_ORDER,c.QTY_RCV,                    &#13;&#10;c.COST,c.PACK_RATIO,s1.SALE_UNIT as SUBPACKUNIT,&#13;&#10;s2.SALE_UNIT as PACKUNIT,IS_ED(g.IS_ED) as ED_FLAG,&#13;&#10;CASE when c.FREE_FLAG='N' then c.`VALUE` else 0 end as VALUE_PO,&#13;&#10;CASE when c.FREE_FLAG&#60;&#62;'N' then c.`VALUE` else 0 end as VALUE_FREE,&#13;&#10;c.BUY_UNIT_COST,c.WORKING_CODE,g.DRUG_NAME&#13;&#10;from MS_IVO m&#13;&#10;left join MS_IVO_C c on (c.RECEIVE_NO=m.RECEIVE_NO and c.REV_FLAG='N')                                                                                                            &#13;&#10;left join COMPANY v on (v.COMPANY_CODE=m.VENDOR_CODE)   &#13;&#10;left JOIN PACK_RATIO p on (p.PACK_CODE=c.PACK_CODE)&#13;&#10;left join SALE_UNIT s1 on (s1.SU_ID=p.SUBPACK_UNIT)     &#13;&#10;left join SALE_UNIT s2 on (s2.SU_ID=p.PACK_UNIT)     &#13;&#10;left join DRUG_GN g on (c.WORKING_CODE = g.WORKING_CODE)                                                                                                                              &#13;&#10;where m.RECEIVE_DATE between :date1 and :date2  and m.DEPT_ID=:stockid&#13;&#10;and m.VENDOR_CODE=:vd                                             &#13;&#10;and c.REV_FLAG='N'  and c.WORKING_CODE=:wcode                                                     &#13;&#10;order by m.RECEIVE_DATE                                                                                                                                             &#13;&#10;    &#13;&#10;&#13;&#10;&#13;&#10;{endif}      &#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_dept" UserName="dept" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=2  order by DEPT_NAME                                                                                                                                        " SpecificOptions.Text="" PropData="05704C656674034C010470546F700308010A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_vd" UserName="vd" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select c.* from COMPANY c&#13;&#10;WHERE &#13;&#10;c.COMPANY_CODE in &#13;&#10;(SELECT DISTINCT                   &#13;&#10; m.VENDOR_CODE from MS_PO m      &#13;&#10; left join MS_PO_C d on (m.PO_NO = d.PO_NO)&#13;&#10; where d.WORKING_CODE=:wcode                                                         &#13;&#10;)    &#13;&#10; order by COMPANY_NAME" SpecificOptions.Text="" PropData="05704C656674034C010470546F700350010A506172616D65746572730101063E204E616D653D2277636F6465222044617461547970653D226674537472696E67222045787072657373696F6E3D22262336303B57434F4445262336323B220000"/>
    <TfrxUniDACQuery Name="qry_medItem" UserName="med" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DRUG_GN where WORKING_CODE=:working_code or upper(DRUG_NAME) like :drug_name                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               " SpecificOptions.Text="" PropData="05704C65667403FC000470546F700374010A506172616D657465727301010629204E616D653D22776F726B696E675F636F6465222044617461547970653D226674556E6B6E6F776E2200010626204E616D653D22647275675F6E616D65222044617461547970653D226674556E6B6E6F776E220000"/>
  </TfrxDataPage>
