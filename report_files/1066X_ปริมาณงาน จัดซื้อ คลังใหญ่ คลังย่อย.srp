      <TfrxMemoView Name="Memo2" AllowVectorExport="True" Left="2" Top="2" Width="1039.37075" Height="52.91342" AllowHTMLTags="True" Font.Charset="1" Font.Color="0" Font.Height="-21" Font.Name="AngsanaUPC" Font.Style="0" Frame.Typ="0" HAlign="haCenter" ParentFont="False" Text="&#60;b&#62;สรุปภาระงาน การสั่งซื้อ การรับเวชภัณฑ์ การเบิกจ่ายเวชภัณฑ์&#60;/b&#62;&#13;&#10;ตั้งแต่วันที่ [formatdatetime('dd/mm/YYYY',date1.date)] ถึงวันที่  [formatdatetime('dd/mm/YYYY',date2.date)] ">
