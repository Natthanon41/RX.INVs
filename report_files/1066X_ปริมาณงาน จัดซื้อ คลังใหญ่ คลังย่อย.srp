<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.6613119907" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  date1.date:=now-30 ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp" DataSetName="rp"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp" UserName="rp" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}        &#13;&#10;&#13;&#10;DECLARE @Date1 char(8), @Date2 char(8)&#13;&#10;SET @Date1 = :date1             &#13;&#10;SET @Date2 = :date2             &#13;&#10;&#13;&#10;SELECT T.date_list,SUM(PO) as PO,&#13;&#10;SUM(IVO) as IVO,&#13;&#10;SUM(DIS) as DIS&#13;&#10;&#13;&#10;FROM( &#13;&#10;select d.date_list, COUNT(DISTINCT m.REF_NO) as PO,&#13;&#10;0 as IVO,0 as DIS&#13;&#10;from (SELECT dbo.ce2cymd(DATEADD(DAY,number+1,@Date1)) as date_list&#13;&#10;FROM master..spt_values&#13;&#10;WHERE type = 'P'&#13;&#10;AND DATEADD(DAY,number+1,@Date1) &#60; @Date2) as d&#13;&#10;left join MS_PO m (NOLOCK) on (m.REQ_APP_DATE = d.date_list and m.REQ_APP_DATE BETWEEN @Date1  and @Date2)&#13;&#10;group by d.date_list&#13;&#10;&#13;&#10;UNION&#13;&#10;select d.date_list, 0 as PO,0 as IVO,COUNT(DISTINCT m.SUB_PO_NO) as DIS&#13;&#10;from (SELECT dbo.ce2cymd(DATEADD(DAY,number+1,@Date1)) as date_list&#13;&#10;FROM master..spt_values&#13;&#10;WHERE type = 'P'&#13;&#10;AND DATEADD(DAY,number+1,@Date1) &#60; @Date2) as d&#13;&#10;left join SM_PO m (NOLOCK) on  (m.SUB_PO_DATE = d.date_list and m.SUB_PO_DATE BETWEEN @Date1  and @Date2)&#13;&#10;left join DEPT_ID i (NOLOCK) on (m.STOCK_ID = i.DEPT_ID)&#13;&#10;where i.DEPT_TYPE=2                                         &#13;&#10;group by d.date_list&#13;&#10;&#13;&#10;UNION&#13;&#10;select  d.date_list, 0 as PO,COUNT(DISTINCT m.RECEIVE_NO) as IVO,0 as DIS&#13;&#10;from (SELECT dbo.ce2cymd(DATEADD(DAY,number+1,@Date1)) as date_list&#13;&#10;FROM master..spt_values&#13;&#10;WHERE type = 'P'&#13;&#10;AND DATEADD(DAY,number+1,@Date1) &#60; @Date2) as d&#13;&#10;left join MS_IVO m (NOLOCK) on (m.RECEIVE_DATE =  d.date_list and m.RECEIVE_DATE BETWEEN @Date1  and @Date2) &#13;&#10;group by d.date_list&#13;&#10;&#13;&#10;) as T&#13;&#10;GROUP BY T.date_list&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;DECLARE @Date1 char(8), @Date2 char(8)&#13;&#10;SET @Date1 = :date1             &#13;&#10;SET @Date2 = :date2             &#13;&#10;&#13;&#10;SELECT T.date_list,SUM(PO) as PO,&#13;&#10;SUM(IVO) as IVO,&#13;&#10;SUM(DIS) as DIS&#13;&#10;&#13;&#10;FROM( &#13;&#10;select d.date_list, COUNT(DISTINCT m.REF_NO) as PO,&#13;&#10;0 as IVO,0 as DIS&#13;&#10;from (SELECT ce2cymd(DATEADD(DAY,number+1,@Date1)) as date_list&#13;&#10;FROM master..spt_values&#13;&#10;WHERE type = 'P'&#13;&#10;AND DATEADD(DAY,number+1,@Date1) &#60; @Date2) as d&#13;&#10;left join MS_PO m (NOLOCK) on (m.REQ_APP_DATE = d.date_list and m.REQ_APP_DATE BETWEEN @Date1  and @Date2)&#13;&#10;group by d.date_list&#13;&#10;&#13;&#10;UNION&#13;&#10;select d.date_list, 0 as PO,0 as IVO,COUNT(DISTINCT m.SUB_PO_NO) as DIS&#13;&#10;from (SELECT ce2cymd(DATEADD(DAY,number+1,@Date1)) as date_list&#13;&#10;FROM master..spt_values&#13;&#10;WHERE type = 'P'&#13;&#10;AND DATEADD(DAY,number+1,@Date1) &#60; @Date2) as d&#13;&#10;left join SM_PO m on  (m.SUB_PO_DATE = d.date_list and m.SUB_PO_DATE BETWEEN @Date1  and @Date2)&#13;&#10;left join DEPT_ID i on (m.STOCK_ID = i.DEPT_ID)&#13;&#10;where i.DEPT_TYPE=2                                         &#13;&#10;group by d.date_list&#13;&#10;&#13;&#10;UNION&#13;&#10;select  d.date_list, 0 as PO,COUNT(DISTINCT m.RECEIVE_NO) as IVO,0 as DIS&#13;&#10;from (SELECT ce2cymd(DATEADD(DAY,number+1,@Date1)) as date_list&#13;&#10;FROM master..spt_values&#13;&#10;WHERE type = 'P'&#13;&#10;AND DATEADD(DAY,number+1,@Date1) &#60; @Date2) as d&#13;&#10;left join MS_IVO m on (m.RECEIVE_DATE =  d.date_list and m.RECEIVE_DATE BETWEEN @Date1  and @Date2) &#13;&#10;group by d.date_list&#13;&#10;&#13;&#10;) as T&#13;&#10;GROUP BY T.date_list    &#13;&#10;&#13;&#10;{ENDIF}        " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where (HIDE='' or HIDE is null)     &#13;&#10;and INV_TYPE='99'  " SpecificOptions.Text="" PropData="05704C65667402380470546F700384000A506172616D65746572730100"/>
