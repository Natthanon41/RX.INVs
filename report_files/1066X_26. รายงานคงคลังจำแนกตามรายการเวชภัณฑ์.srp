<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43577.4760081482" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  m0,y0,m_1,ym0,ym1 ,: string ;&#13;&#10;  Line_no: integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  m1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),5,2) ;&#13;&#10;    y1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),1,4) ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  if   inttostr(strtoint(m1.text)) = '1' then&#13;&#10;  begin&#13;&#10;&#13;&#10;     m0:='12' ;&#13;&#10;     y0:=inttostr(strtoint(y1.text)-1-543) ;&#13;&#10;     m_1:='01' ;&#13;&#10;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;&#13;&#10;    if   length(inttostr(strtoint(m1.text)-1)) = 1 then&#13;&#10;    begin&#13;&#10;      m0:= '0'+inttostr(strtoint(m1.text)-1);&#13;&#10;&#13;&#10;        if   length(inttostr(strtoint(m1.text))) = 1 then  m_1:= '0'+inttostr(strtoint(m1.text))&#13;&#10;        else m_1:= m1.text;&#13;&#10;&#13;&#10;    end&#13;&#10;    else&#13;&#10;    begin&#13;&#10;      m0:= inttostr(strtoint(m1.text)-1);&#13;&#10;      m_1:= m1.text;&#13;&#10;    end;&#13;&#10;&#13;&#10;   y0:=inttostr(strtoint(y1.text)-543) ;&#13;&#10;&#13;&#10;  end;&#13;&#10;&#13;&#10;  ym0:= y0 + m0 ;&#13;&#10;  ym1:=inttostr(strtoint(y1.text)-543)+m_1 ;&#13;&#10;&#13;&#10; end ;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10; Line_no:=Line_no+1 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;end.&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="qry_rp1"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="qry_rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}  &#13;&#10;&#13;&#10;SELECT T.SALE_UNIT,T.UNIT_COST,T.PACK_RATIO,T.DRUG_NAME,T.NLEM,SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE,&#13;&#10;SUM(T.RM_QTY) as RM_QTY                                &#13;&#10;from (  &#13;&#10;select g.DRUG_NAME,i.WORKING_CODE, dbo.NLEM(g.IS_ED) as NLEM,&#13;&#10;&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) between  left(dbo.ce2cymd(GETDATE()-900),6) and   :ym_fw                         &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as FW_VALUE,&#13;&#10;          &#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE ,&#13;&#10;      &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  between  left(dbo.ce2cymd(GETDATE()-900),6)   and   :ym1                &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC ) as RM_VALUE,&#13;&#10;(select top 1 c.REMAIN_QTY from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  between  left(ce2cymd(CURDATE()-900),6)   and  :ym1               &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC ) as RM_QTY,&#13;&#10;(select top 1  c.REMAIN_VALUE/c.REMAIN_QTY from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  between  left(ce2cymd(CURDATE()-900),6)   and  :ym1               &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE AND  c.REMAIN_QTY &#62; 0                                   &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC) as UNIT_COST,            &#13;&#10;i.TOTAL_VALUE,&#13;&#10;CASE when isnull(i.FIRST_PACK_RATIO,0) &#62; 0 then i.FIRST_PACK_RATIO else i.LAST_PACK_RATIO    end as PACK_RATIO&#13;&#10;from INV_MD i&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)      &#13;&#10;left join SALE_UNIT s on (g.SALE_UNIT_ID = s.SU_ID)  &#13;&#10;left join  (&#13;&#10;   select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          						SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.[VALUE]&#13;&#10;                   when c1.R_S_STATUS in ('B') then c1.[VALUE]*-1    &#13;&#10;                   else NULL end) as RCV_VALUE,&#13;&#10;            						SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.[VALUE] &#13;&#10;	                     									 when (c1.R_S_STATUS='C') then c1.[VALUE]*-1 else NULL end) as DIS_VALUE&#13;&#10;            						from CARD c1&#13;&#10;            where c1.STOCK_ID=:dept0     &#13;&#10;            and left(c1.R_S_DATE,6) = :ym2  &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)    &#13;&#10;where i.DEPT_ID=:dept  and   g.WORKING_CODE is not null                                                                      &#13;&#10;)  as T&#13;&#10;/*where T.TOTAL_VALUE  &#62; 0.99 */&#13;&#10;/*where   FW_VALUE &#62; 0 and   RCV_VALUE &#62; 0 and   DIS_VALUE &#62; 0 and   RM_VALUE &#62; 0   */&#13;&#10;/*where  T.NLEM in ('ED','NED') */                                                                                  &#13;&#10;group by T.SALE_UNIT,T.UNIT_COST,T.PACK_RATIO,T.DRUG_NAME,T.NLEM&#13;&#10;order by T.NLEM,T.DRUG_NAME&#13;&#10;  &#13;&#10;{ELSE}     &#13;&#10;&#13;&#10;SELECT T.SALE_UNIT,T.UNIT_COST,T.PACK_RATIO,T.DRUG_NAME,T.NLEM,SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE,&#13;&#10;SUM(T.RM_QTY) as RM_QTY    &#13;&#10;from (  &#13;&#10;select s.SALE_UNIT,g.DRUG_NAME,i.WORKING_CODE,NLEM(g.IS_ED) as NLEM,&#13;&#10;&#13;&#10;(select c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) between  left(ce2cymd(CURDATE()-900),6) and  :ym_fw                        &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC limit 1) as FW_VALUE,&#13;&#10;          &#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE ,&#13;&#10;      &#13;&#10;(select c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  between  left(ce2cymd(CURDATE()-900),6)   and  :ym1               &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC limit 1) as RM_VALUE,&#13;&#10;(select c.REMAIN_QTY from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  between  left(ce2cymd(CURDATE()-900),6)   and  :ym1               &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC limit 1) as RM_QTY,&#13;&#10;(select  c.REMAIN_VALUE/c.REMAIN_QTY from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  between  left(ce2cymd(CURDATE()-900),6)   and  :ym1               &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE AND  c.REMAIN_QTY &#62; 0                                   &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC limit 1) as UNIT_COST,              &#13;&#10;&#13;&#10;i.TOTAL_VALUE,  &#13;&#10;CASE when ifnull(i.FIRST_PACK_RATIO,0) &#62; 0 then i.FIRST_PACK_RATIO else i.LAST_PACK_RATIO  end as PACK_RATIO            &#13;&#10;from INV_MD i&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join SALE_UNIT s on (g.SALE_UNIT_ID = s.SU_ID)                                                                                                               &#13;&#10;left join  (&#13;&#10;   select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          						SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.`VALUE`&#13;&#10;                   when c1.R_S_STATUS in ('B') then c1.`VALUE`*-1    &#13;&#10;                   else NULL end) as RCV_VALUE,&#13;&#10;            						SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.`VALUE` &#13;&#10;	                     									 when (c1.R_S_STATUS='C') then c1.`VALUE`*-1 else NULL end) as DIS_VALUE&#13;&#10;            						from CARD c1&#13;&#10;            where c1.STOCK_ID=:dept0       &#13;&#10;            and left(c1.R_S_DATE,6) =:ym2        &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)    &#13;&#10;where i.DEPT_ID=:dept   and   g.WORKING_CODE is not null                                                                      &#13;&#10;)  as T&#13;&#10;                                                                                &#13;&#10;group by T.SALE_UNIT,T.UNIT_COST,T.PACK_RATIO,T.DRUG_NAME,T.NLEM  &#13;&#10;order by T.NLEM,T.DRUG_NAME                      &#13;&#10;&#13;&#10;{ENDIF}     " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select * from DEPT_ID where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;order by DEPT_NAME    &#13;&#10;&#13;&#10;{ENDIF}     " SpecificOptions.Text="" PropData="05704C65667402640470546F7003EC000A506172616D65746572730100"/>
  </TfrxDataPage>
