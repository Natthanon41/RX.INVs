  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_budget_amt" UserName="budget" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}    &#13;&#10;&#13;&#10;select t.BUDGET_NAME,isnull(po.BUY_THIS_DAY,0) as BUY_THIS_DAY,b.BUDGET_AMOUNT,po.BUY_BF as BUY_BF_DEPT,&#13;&#10;po_all.BUY_BF as BUY_BF_ALL  ,&#13;&#10;isnull(po.TOTAL_BUY_PO,0) as TOTAL_BUY,    &#13;&#10;po_all.BUY_THIS_FIS_ALL                    &#13;&#10;from BDG_AMT b (NOLOCK)&#13;&#10;left join BDG_TYPE t (NOLOCK) on (t.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;  &#13;&#10;left join (select p.BUDGET_TYPE,&#13;&#10;SUM(CASE when p.REQ_APP_DATE =:ymd0 then p.TOTAL_COST_AD else 0 end) as BUY_THIS_DAY,&#13;&#10;SUM(CASE when p.REQ_APP_DATE &#60;:ymd0 then p.TOTAL_COST_AD else 0 end) as BUY_BF,        &#13;&#10;SUM(p.TOTAL_COST) as TOTAL_BUY_PO                    &#13;&#10;from MS_PO p (NOLOCK) &#13;&#10;where p.DEPT_ID=:dept_id&#13;&#10;and dbo.ThaiFiscalYear(p.REQ_APP_DATE)=dbo.ThaiFiscalYear(:ymd2)             &#13;&#10;group by p.BUDGET_TYPE) as po&#13;&#10;  &#13;&#10;on (po.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;  &#13;&#10;left join (select p.BUDGET_TYPE,&#13;&#10;SUM(CASE when p.REQ_APP_DATE =:ymd0 then p.TOTAL_COST_AD else 0 end) as BUY_THIS_DAY,&#13;&#10;SUM(CASE when ( p.REQ_APP_DATE &#60; :ymd0) or ( p.REQ_APP_DATE =:ymd0  and p.DEPT_ID&#60;&#62;:dept_id ) then p.TOTAL_COST_AD else 0 end) as BUY_BF,&#13;&#10;SUM(CASE when ( p.REQ_APP_DATE &#60;=:ymd0 ) then p.TOTAL_COST_AD else 0 end) as BUY_THIS_FIS_ALL,    &#13;&#10;SUM(p.TOTAL_COST) as TOTAL_BUY_PO                    &#13;&#10;from MS_PO p (NOLOCK) &#13;&#10;where  &#13;&#10;dbo.ThaiFiscalYear(p.REQ_APP_DATE)=dbo.ThaiFiscalYear(:ymd2)&#13;&#10;group by p.BUDGET_TYPE) as po_all&#13;&#10;  &#13;&#10;on (po_all.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;  &#13;&#10;where b.FISCAL_YEAR=dbo.ThaiFiscalYear(:ymd2 )&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select t.BUDGET_NAME,ifnull(po.BUY_THIS_DAY,0) as BUY_THIS_DAY,b.BUDGET_AMOUNT,po.BUY_BF as BUY_BF_DEPT,  &#13;&#10;po_all.BUY_BF as BUY_BF_ALL  ,&#13;&#10;ifnull(po.TOTAL_BUY_PO,0) as TOTAL_BUY,    &#13;&#10;po_all.BUY_THIS_FIS_ALL                    &#13;&#10;from BDG_AMT b&#13;&#10;left join BDG_TYPE t on (t.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;  &#13;&#10;left join (select p.BUDGET_TYPE,&#13;&#10;SUM(CASE when p.REQ_APP_DATE =:ymd0 then p.TOTAL_COST_AD else 0 end) as BUY_THIS_DAY,&#13;&#10;SUM(CASE when p.REQ_APP_DATE &#60;:ymd0 then p.TOTAL_COST_AD else 0 end) as BUY_BF,        &#13;&#10;SUM(p.TOTAL_COST) as TOTAL_BUY_PO                    &#13;&#10;from MS_PO p &#13;&#10;where p.DEPT_ID=:dept_id&#13;&#10;and ThaiFiscalYear(p.REQ_APP_DATE)=ThaiFiscalYear(:ymd2)             &#13;&#10;group by p.BUDGET_TYPE) as po&#13;&#10;  &#13;&#10;on (po.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;  &#13;&#10;left join (select p.BUDGET_TYPE,&#13;&#10;SUM(CASE when p.REQ_APP_DATE =:ymd0 then p.TOTAL_COST_AD else 0 end) as BUY_THIS_DAY,&#13;&#10;SUM(CASE when ( p.REQ_APP_DATE &#60; :ymd0) or ( p.REQ_APP_DATE =:ymd0  and p.DEPT_ID&#60;&#62;:dept_id ) then p.TOTAL_COST_AD else 0 end) as BUY_BF,&#13;&#10;SUM(CASE when ( p.REQ_APP_DATE &#60;=:ymd0 ) then p.TOTAL_COST_AD else 0 end) as BUY_THIS_FIS_ALL,    &#13;&#10;SUM(p.TOTAL_COST) as TOTAL_BUY_PO                    &#13;&#10;from MS_PO p&#13;&#10;where  &#13;&#10;ThaiFiscalYear(p.REQ_APP_DATE)=ThaiFiscalYear(:ymd2)&#13;&#10;group by p.BUDGET_TYPE) as po_all&#13;&#10;  &#13;&#10;on (po_all.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;  &#13;&#10;where b.FISCAL_YEAR=ThaiFiscalYear(:ymd2 )  &#13;&#10;&#13;&#10;&#13;&#10;{ENDIF}      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select b.BUYMET_DES, m.DEPT_ID,m.REF_NO,dbo.cymd2be(m.PO_DATE) as PODATE,v.COMPANY_NAME as VENDOR_NAME,c.QTY_ORDER,&#13;&#10;ISNULL(c.QTY_ORDER_RCV,0) as QTY_ORDER_RCV, m.CNT_NO,c.PACK_RATIO,                                                                      &#13;&#10;c.COST,c.PACK_RATIO,s1.SALE_UNIT as SUBPACKUNIT,&#13;&#10;s2.SALE_UNIT as PACKUNIT,dbo.IS_ED(g.IS_ED) as ED_FLAG,&#13;&#10;CASE when c.FREE_FLAG=0 then 'ซื้อ' when  c.FREE_FLAG=1 then 'ชดเชย (1)' when  c.FREE_FLAG=2 then 'ชดเชย (2)' else 'Error'  end as ITEM_TYPE,&#13;&#10;c.BUY_UNIT_COST,c.WORKING_CODE,g.DRUG_NAME&#13;&#10;from MS_PO m (NOLOCK)&#13;&#10;left join MS_PO_C c (NOLOCK) on (c.PO_NO=m.PO_NO and c.REV_FLAG='N')                                                                                                            &#13;&#10;left join COMPANY v (NOLOCK) on (v.COMPANY_CODE=m.VENDOR_CODE)   &#13;&#10;left JOIN PACK_RATIO p on (p.PACK_CODE=c.PACK_CODE)&#13;&#10;left join SALE_UNIT s1 (NOLOCK) on (s1.SU_ID=p.SUBPACK_UNIT)     &#13;&#10;left join SALE_UNIT s2 (NOLOCK) on (s2.SU_ID=p.PACK_UNIT)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join BUYMETHOD b (NOLOCK) on (b.BUYMET_CODE = m.BUY_METHOD)                                                                                                                                         &#13;&#10;where m.REQ_APP_DATE=:date1 and m.DEPT_ID=:stockid&#13;&#10;and c.REV_FLAG='N'&#13;&#10;order by m.REF_NO&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select b.BUYMET_DES, m.DEPT_ID,m.REF_NO,cymd2be(m.PO_DATE) as PODATE,v.COMPANY_NAME as VENDOR_NAME,c.QTY_ORDER,&#13;&#10;IFNULL(c.QTY_ORDER_RCV,0) as QTY_ORDER_RCV, m.CNT_NO,c.PACK_RATIO,                                                                     &#13;&#10;c.COST,c.PACK_RATIO,s1.SALE_UNIT as SUBPACKUNIT,&#13;&#10;s2.SALE_UNIT as PACKUNIT, IS_ED(g.IS_ED) as ED_FLAG,&#13;&#10;CASE when c.FREE_FLAG=0 then 'ซื้อ' when  c.FREE_FLAG=1 then 'ชดเชย (1)' when  c.FREE_FLAG=2 then 'ชดเชย (2)' else 'Error'  end as ITEM_TYPE,&#13;&#10;c.BUY_UNIT_COST,c.WORKING_CODE,g.DRUG_NAME&#13;&#10;from MS_PO m&#13;&#10;left join MS_PO_C c on (c.PO_NO=m.PO_NO and c.REV_FLAG='N')                                                                                                            &#13;&#10;left join COMPANY v on (v.COMPANY_CODE=m.VENDOR_CODE)   &#13;&#10;left JOIN PACK_RATIO p on (p.PACK_CODE=c.PACK_CODE)&#13;&#10;left join SALE_UNIT s1 on (s1.SU_ID=p.SUBPACK_UNIT)     &#13;&#10;left join SALE_UNIT s2 on (s2.SU_ID=p.PACK_UNIT)     &#13;&#10;left join DRUG_GN g on (c.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join BUYMETHOD b on (b.BUYMET_CODE = m.BUY_METHOD)                                                                                                                                         &#13;&#10;where m.REQ_APP_DATE=:date1 &#13;&#10;and m.DEPT_ID=:stockid&#13;&#10;and c.REV_FLAG='N'&#13;&#10;order by m.REF_NO                                                                                                                                                        &#13;&#10;  &#13;&#10;&#13;&#10;&#13;&#10;{ENDIF}      &#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_dept" UserName="dept" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=1                                                                                              " SpecificOptions.Text="" PropData="05704C65667403AC000470546F700384000A506172616D65746572730100"/>
  </TfrxDataPage>
