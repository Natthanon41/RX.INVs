<TfrxReport Version="6.9.2" DotMatrixReport="False" EngineOptions.SilentMode="True" EngineOptions.NewSilentMode="simSilent" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="45134.4507705324" ReportOptions.Description.Text="" ReportOptions.LastChange="45142.6576671643" ScriptLanguage="PascalScript" ScriptText.Text="procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;// date1.date:=now ;&#13;&#10;// date2.date:=now ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Label1OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="DialogPage1OnActivate">
  <Datasets>
    <item DataSet="sum_per_drug_dep" DataSetName="per_drug_dep"/>
  </Datasets>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="sum_per_drug_dep" UserName="per_drug_dep" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SELECT&#13;&#10;	di.DEPT_ID, &#13;&#10;	di.DEPT_NAME,&#13;&#10;	d.WORKING_CODE,&#13;&#10;	d.DRUG_NAME,&#13;&#10;	SUM(c.QTY_ORDER * c.PACK_RATIO) AS cc,&#13;&#10;	sp.STOCK_ID,&#13;&#10;	SUM(c.VALUE) AS sum_value&#13;&#10;	    &#13;&#10;FROM sm_po sp&#13;&#10;LEFT JOIN sm_po_c c ON sp.SUB_PO_NO=c.SUB_PO_NO&#13;&#10;LEFT JOIN drug_gn d ON c.WORKING_CODE=d.WORKING_CODE&#13;&#10;LEFT JOIN dept_id di ON sp.DEPT_ID=di.DEPT_ID&#13;&#10;WHERE &#13;&#10;	&#13;&#10;	&#13;&#10;   sp.CONFIRM_DATE BETWEEN :date1 AND :date2                                                 &#13;&#10;	AND (c.CANCEL_DISP IS NULL OR c.CANCEL_DISP='')&#13;&#10;	AND di.DEPT_ID LIKE 'HC%'&#13;&#10;GROUP BY sp.DEPT_ID,c.WORKING_CODE&#13;&#10;order by  di.DEPT_NAME,d.DRUG_NAME                                               " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
