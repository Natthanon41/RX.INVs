<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" EngineOptions.SilentMode="True" EngineOptions.NewSilentMode="simSilent" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="45239.6761768056" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; input_year : integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  monthx.text:= formatdatetime('mm',now-29) ;&#13;&#10;  yearx.text:=  inttostr(strtoint(formatdatetime('YYYY',now-30))+543) ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  date1.date:=now-30 ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure monthxOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;    input_year:= strtoint(yearx.text)-543 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="frxReport1OnReportPrint">
  <Datasets>
    <item DataSet="qry_stockcard" DataSetName="rp1"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_stockcard" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                                  &#13;&#10;select * from&#13;&#10;(&#13;&#10;select c1.R_S_NUMBER,c1.WORKING_CODE,g.DRUG_NAME,&#13;&#10;c1.LOT_NO,&#13;&#10;c1.EXPIRED_DATE,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.ACTIVE_QTY                    &#13;&#10;when c1.R_S_STATUS in ('B') then c1.ACTIVE_QTY*-1 &#13;&#10;else NULL end) as RCV_QTY  ,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.[VALUE]                                    &#13;&#10;when c1.R_S_STATUS in ('B') then   c1.[VALUE]*-1 &#13;&#10;else NULL end) as RCV_VALUE,&#13;&#10;(select top 1  ACTIVE_PACK  from CARD c (NOLOCK) where c.WORKING_CODE = c1.WORKING_CODE &#13;&#10;and c.STOCK_ID = c1.STOCK_ID  Order by RECORD_NUMBER DESC) as  PACK_RATIO    &#13;&#10;/*,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.ACTIVE_QTY                     &#13;&#10;	      when (c1.R_S_STATUS='C') then c1.ACTIVE_QTY*-1 else NULL end) as DIS_QTY  */    &#13;&#10;from CARD c1 (NOLOCK)                &#13;&#10;left join DRUG_GN g (NOLOCK) on (c1.WORKING_CODE = g.WORKING_CODE)&#13;&#10;where (c1.STOCK_ID =:stock_id  )                                                           &#13;&#10;         and dbo.ce2cymd(c1.OPERATE_DATE) between  :date1 and :date2       &#13;&#10;group by c1.WORKING_CODE,g.DRUG_NAME,c1.STOCK_ID,c1.R_S_NUMBER,c1.LOT_NO,c1.EXPIRED_DATE&#13;&#10;) T WHERE T.RCV_QTY  is not null&#13;&#10;Order by T.R_S_NUMBER,T.DRUG_NAME DESC&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select * from&#13;&#10;(&#13;&#10;select c1.R_S_NUMBER,c1.WORKING_CODE,g.DRUG_NAME,&#13;&#10;c1.LOT_NO,&#13;&#10;c1.EXPIRED_DATE,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.ACTIVE_QTY                    &#13;&#10;when c1.R_S_STATUS in ('B') then c1.ACTIVE_QTY*-1 &#13;&#10;else NULL end) as RCV_QTY  ,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.VALUE                                    &#13;&#10;when c1.R_S_STATUS in ('B') then   c1.VALUE*-1 &#13;&#10;else NULL end) as RCV_VALUE,&#13;&#10;(select   ACTIVE_PACK  from CARD c  where c.WORKING_CODE = c1.WORKING_CODE &#13;&#10;and c.STOCK_ID = c1.STOCK_ID  Order by RECORD_NUMBER DESC limit 1) as  PACK_RATIO       &#13;&#10;/*,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.ACTIVE_QTY                     &#13;&#10;	      when (c1.R_S_STATUS='C') then c1.ACTIVE_QTY*-1 else NULL end) as DIS_QTY  */    &#13;&#10;from CARD c1&#13;&#10;left join DRUG_GN g  on (c1.WORKING_CODE = g.WORKING_CODE)&#13;&#10;where (c1.STOCK_ID =:stock_id  )                                                           &#13;&#10;         and ce2cymd(c1.OPERATE_DATE) between  :date1 and :date2       &#13;&#10;group by c1.WORKING_CODE,g.DRUG_NAME,c1.STOCK_ID,c1.R_S_NUMBER,c1.LOT_NO,c1.EXPIRED_DATE  &#13;&#10;) T WHERE T.RCV_QTY  is not null&#13;&#10;Order by T.R_S_NUMBER,T.DRUG_NAME DESC&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                                                        &#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME&#13;&#10;&#13;&#10; {ELSE}&#13;&#10;&#13;&#10; select * from DEPT_ID  where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME&#13;&#10;&#13;&#10; {ENDIF}                 " SpecificOptions.Text="" PropData="05704C65667402580470546F7002700A506172616D65746572730100"/>
  </TfrxDataPage>
