  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="qry_sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SET @fy= convert( :fy  using utf8);  &#13;&#10;SELECT T.fw_ym,T.ym,left(T.ym,4) as y,SUBSTRING(T.ym from 5 for 2 ) as m,&#13;&#10;SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE&#13;&#10;FROM (  &#13;&#10;&#13;&#10;/*-----------------------------------------------------------------------------------------*/&#13;&#10;&#13;&#10;SELECT ymx.ym,ymx.fw_ym,i.WORKING_CODE,  i.DEPT_ID,&#13;&#10;&#13;&#10;(SELECT c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        DATE_FORMAT(c.OPERATE_DATE, '%Y%m')  &#60;= ymx.fw_ym /* between concat(@fy-1,'09')  and  ymx.fw_ym*/                          &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1) as FW_VALUE,&#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE ,         &#13;&#10;(SELECT c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        DATE_FORMAT(c.OPERATE_DATE, '%Y%m') &#60;= ymx.ym /*  between concat(@fy-1,'09')  and ymx.ym */                   &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1) as RM_VALUE&#13;&#10;          &#13;&#10;FROM (&#13;&#10;		select concat(@fy-1,'09') as fw_ym,concat(@fy-1,'10') as ym&#13;&#10;		union select concat(@fy-1,'10') as fw_ym,concat(@fy-1,'11') as ym&#13;&#10;		union select concat(@fy-1,'11') as fw_ym,concat(@fy-1,'12') as ym&#13;&#10;		union select concat(@fy-1,'12') as fw_ym,concat(@fy,'01') as ym&#13;&#10;		union select concat(@fy,'01') as fw_ym,concat(@fy,'02') as ym&#13;&#10;		union select concat(@fy,'02') as fw_ym,concat(@fy,'03') as ym&#13;&#10;		union select concat(@fy,'03') as fw_ym,concat(@fy,'04') as ym&#13;&#10;		union select concat(@fy,'04') as fw_ym,concat(@fy,'05') as ym&#13;&#10;		union select concat(@fy,'05') as fw_ym,concat(@fy,'06') as ym&#13;&#10;		union select concat(@fy,'06') as fw_ym,concat(@fy,'07') as ym&#13;&#10;		union select concat(@fy,'07') as fw_ym,concat(@fy,'08') as ym&#13;&#10;		union select concat(@fy,'08') as fw_ym,concat(@fy,'09') as ym&#13;&#10;    ) as ymx&#13;&#10;left join INV_MD i on (1=1)  &#13;&#10;left join (&#13;&#10;/*-----------------------------------------------------------------------------------------*/&#13;&#10;&#13;&#10;           SELECT &#13;&#10;                DATE_FORMAT(c1.OPERATE_DATE,'%Y%m') as ym, c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          			SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.`VALUE`&#13;&#10;                when c1.R_S_STATUS in ('M','E','B','B') then c1.`VALUE`*-1        &#13;&#10;                else 0 end) as RCV_VALUE,&#13;&#10;            		SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.`VALUE` &#13;&#10;	              when (c1.R_S_STATUS in ('C','Z','U')) then c1.`VALUE`*-1 else 0 end) as DIS_VALUE&#13;&#10;            FROM CARD c1 &#13;&#10;           &#13;&#10;            where c1.STOCK_ID=:dept_id                    &#13;&#10;            AND DATE_FORMAT(c1.OPERATE_DATE,'%Y%m') BETWEEN   concat(@fy-1,'10')   AND  concat(@fy,'09')   &#13;&#10;           &#13;&#10;              &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID,DATE_FORMAT(c1.OPERATE_DATE,'%Y%m') &#13;&#10;/*-------------------------------------------------------------------------------------------*/&#13;&#10;    ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID  AND ymx.ym=Cx.ym)&#13;&#10;      &#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)        &#13;&#10;where i.DEPT_ID=:dept_id&#13;&#10;/*AND g.GROUP_CODE&#60;&#62;'600101'*/    &#13;&#10; AND g.IS_ED in (1,2)        &#13;&#10;/*--------------------------------------------------------------------------------------------*/                                                                &#13;&#10;)  as T&#13;&#10;Where  T.ym &#60;= DATE_FORMAT(CURDATE(), '%Y%m')     &#13;&#10;group by T.fw_ym,T.ym,left(T.ym,4),SUBSTRING(T.ym from 5 for 2 )&#13;&#10;order by T.ym ;                               " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="&#13;&#10;{IF SQLSERVER} &#13;&#10;&#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE='' or HIDE is null or HIDE='N') order by DEPT_NAME    &#13;&#10;&#13;&#10;{ELSE} &#13;&#10;&#13;&#10;select * from DEPT_ID  where (HIDE='' or HIDE is null or HIDE='N') order by DEPT_NAME  &#13;&#10;&#13;&#10;{ENDIF}     &#13;&#10;&#13;&#10;&#13;&#10;                                           " SpecificOptions.Text="" PropData="05704C65667402640470546F7003B0000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_herb" UserName="herb" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SET @fy= convert( :fy  using utf8);  &#13;&#10;SELECT T.fw_ym,T.ym,left(T.ym,4) as y,SUBSTRING(T.ym from 5 for 2 ) as m,&#13;&#10;SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE&#13;&#10;FROM (  &#13;&#10;&#13;&#10;/*-----------------------------------------------------------------------------------------*/&#13;&#10;&#13;&#10;SELECT ymx.ym,ymx.fw_ym,i.WORKING_CODE,  i.DEPT_ID,&#13;&#10;&#13;&#10;(SELECT c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        DATE_FORMAT(c.OPERATE_DATE, '%Y%m') between concat(@fy-1,'09')  and  ymx.fw_ym                      &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1) as FW_VALUE,&#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE ,         &#13;&#10;(SELECT c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        DATE_FORMAT(c.OPERATE_DATE, '%Y%m')  between concat(@fy-1,'09')  and ymx.ym            &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1) as RM_VALUE&#13;&#10;          &#13;&#10;FROM (&#13;&#10;		select concat(@fy-1,'09') as fw_ym,concat(@fy-1,'10') as ym&#13;&#10;		union select concat(@fy-1,'10') as fw_ym,concat(@fy-1,'11') as ym&#13;&#10;		union select concat(@fy-1,'11') as fw_ym,concat(@fy-1,'12') as ym&#13;&#10;		union select concat(@fy-1,'12') as fw_ym,concat(@fy,'01') as ym&#13;&#10;		union select concat(@fy,'01') as fw_ym,concat(@fy,'02') as ym&#13;&#10;		union select concat(@fy,'02') as fw_ym,concat(@fy,'03') as ym&#13;&#10;		union select concat(@fy,'03') as fw_ym,concat(@fy,'04') as ym&#13;&#10;		union select concat(@fy,'04') as fw_ym,concat(@fy,'05') as ym&#13;&#10;		union select concat(@fy,'05') as fw_ym,concat(@fy,'06') as ym&#13;&#10;		union select concat(@fy,'06') as fw_ym,concat(@fy,'07') as ym&#13;&#10;		union select concat(@fy,'07') as fw_ym,concat(@fy,'08') as ym&#13;&#10;		union select concat(@fy,'08') as fw_ym,concat(@fy,'09') as ym&#13;&#10;    ) as ymx&#13;&#10;left join INV_MD i on (1=1)  &#13;&#10;left join (&#13;&#10;/*-----------------------------------------------------------------------------------------*/&#13;&#10;&#13;&#10;           SELECT &#13;&#10;                DATE_FORMAT(c1.OPERATE_DATE,'%Y%m') as ym, c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          			SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.`VALUE`&#13;&#10;                when c1.R_S_STATUS in ('M','E','B') then c1.`VALUE`*-1        &#13;&#10;                else 0 end) as RCV_VALUE,&#13;&#10;            		SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.`VALUE` &#13;&#10;	              when (c1.R_S_STATUS in ('C','Z','U') ) then c1.`VALUE`*-1 else 0 end) as DIS_VALUE&#13;&#10;            FROM CARD c1 &#13;&#10;           &#13;&#10;            where c1.STOCK_ID=:dept_id                    &#13;&#10;            AND left(ce2cymd(c1.OPERATE_DATE),6) BETWEEN   concat(@fy-1,'10')   AND  concat(@fy,'09')   &#13;&#10;                                      &#13;&#10;              &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID,DATE_FORMAT(c1.OPERATE_DATE,'%Y%m') &#13;&#10;/*-------------------------------------------------------------------------------------------*/&#13;&#10;    ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID  AND ymx.ym=Cx.ym)&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)        &#13;&#10;where i.DEPT_ID=:dept_id&#13;&#10;AND g.GROUP_CODE='600101'    &#13;&#10;/*--------------------------------------------------------------------------------------------*/                                                                &#13;&#10;)  as T&#13;&#10;Where  T.ym &#60;= DATE_FORMAT(CURDATE(), '%Y%m')     &#13;&#10;group by T.fw_ym,T.ym,left(T.ym,4),SUBSTRING(T.ym from 5 for 2 )&#13;&#10;order by T.ym ;                               " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_ps" UserName="ps" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SET @fy= convert( :fy  using utf8);  &#13;&#10;SELECT T.fw_ym,T.ym,left(T.ym,4) as y,SUBSTRING(T.ym from 5 for 2 ) as m,&#13;&#10;SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE&#13;&#10;FROM (  &#13;&#10;&#13;&#10;/*-----------------------------------------------------------------------------------------*/&#13;&#10;&#13;&#10;SELECT ymx.ym,ymx.fw_ym,i.WORKING_CODE,  i.DEPT_ID,&#13;&#10;&#13;&#10;IFNULL((SELECT c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        DATE_FORMAT(c.OPERATE_DATE, '%Y%m') &#60;=  ymx.fw_ym /* between concat(@fy-1,'09')  and  ymx.fw_ym*/                          &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1),0) as FW_VALUE,&#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE ,         &#13;&#10;(SELECT c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        DATE_FORMAT(c.OPERATE_DATE, '%Y%m') &#60;=  ymx.ym /*  between concat(@fy-1,'09')  and ymx.ym*/                &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1) as RM_VALUE&#13;&#10;          &#13;&#10;FROM (&#13;&#10;		select concat(@fy-1,'09') as fw_ym,concat(@fy-1,'10') as ym&#13;&#10;		union select concat(@fy-1,'10') as fw_ym,concat(@fy-1,'11') as ym&#13;&#10;		union select concat(@fy-1,'11') as fw_ym,concat(@fy-1,'12') as ym&#13;&#10;		union select concat(@fy-1,'12') as fw_ym,concat(@fy,'01') as ym&#13;&#10;		union select concat(@fy,'01') as fw_ym,concat(@fy,'02') as ym&#13;&#10;		union select concat(@fy,'02') as fw_ym,concat(@fy,'03') as ym&#13;&#10;		union select concat(@fy,'03') as fw_ym,concat(@fy,'04') as ym&#13;&#10;		union select concat(@fy,'04') as fw_ym,concat(@fy,'05') as ym&#13;&#10;		union select concat(@fy,'05') as fw_ym,concat(@fy,'06') as ym&#13;&#10;		union select concat(@fy,'06') as fw_ym,concat(@fy,'07') as ym&#13;&#10;		union select concat(@fy,'07') as fw_ym,concat(@fy,'08') as ym&#13;&#10;		union select concat(@fy,'08') as fw_ym,concat(@fy,'09') as ym&#13;&#10;    ) as ymx&#13;&#10;left join INV_MD i on (1=1)  &#13;&#10;left join (&#13;&#10;/*-----------------------------------------------------------------------------------------*/&#13;&#10;&#13;&#10;           SELECT &#13;&#10;                DATE_FORMAT(c1.OPERATE_DATE,'%Y%m') as ym, c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          			SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.`VALUE`&#13;&#10;                when c1.R_S_STATUS in ('M','E','B') then c1.`VALUE`*-1        &#13;&#10;                else 0 end) as RCV_VALUE,&#13;&#10;            		SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.`VALUE` &#13;&#10;	              when (c1.R_S_STATUS in ('C','Z','U') ) then c1.`VALUE`*-1 else 0 end) as DIS_VALUE&#13;&#10;            FROM CARD c1 &#13;&#10;            &#13;&#10;            where c1.STOCK_ID=:dept_id                    &#13;&#10;            AND DATE_FORMAT(c1.OPERATE_DATE, '%Y%m')  BETWEEN   concat(@fy-1,'10')   AND  concat(@fy,'09')   &#13;&#10;           &#13;&#10;              &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID,DATE_FORMAT(c1.OPERATE_DATE,'%Y%m') &#13;&#10;/*-------------------------------------------------------------------------------------------*/&#13;&#10;    ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID  AND ymx.ym=Cx.ym)&#13;&#10;left join DRUG_GN g on (cx.WORKING_CODE=g.WORKING_CODE)        &#13;&#10;where i.DEPT_ID=:dept_id&#13;&#10; AND g.IS_ED in (6)    &#13;&#10;/*--------------------------------------------------------------------------------------------*/                                                                &#13;&#10;)  as T&#13;&#10;Where  T.ym &#60;= DATE_FORMAT(CURDATE(), '%Y%m')     &#13;&#10;group by T.fw_ym,T.ym,left(T.ym,4),SUBSTRING(T.ym from 5 for 2 )&#13;&#10;order by T.ym ;                               " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
