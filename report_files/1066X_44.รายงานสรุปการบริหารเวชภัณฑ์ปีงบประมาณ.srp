<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="44055.5942083449" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  fy ,: string ;&#13;&#10;  Line_no: integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;  e_fy.Text:=COPY( DATEtoYMD(&#60;Date&#62;),1,4) ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10; fy:=inttostr(strtoint(e_fy.text)-543) ;&#13;&#10;&#13;&#10;end ;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  {&#13;&#10;  if (&#60;qry_sum_inv.&#34;FW_VALUE&#34;&#62; &#60;0.1) and (&#60;qry_sum_inv.&#34;RCV_VALUE&#34;&#62;&#60;0.1) and (&#60;qry_sum_inv.&#34;DIS_VALUE&#34;&#62;&#60;0.1) and (&#60;qry_sum_inv.&#34;RM_VALUE&#34;&#62;&#60;0.1)&#13;&#10;  then   MasterData1.visible:=False else  MasterData1.visible:=True ;&#13;&#10;   }&#13;&#10; if   MasterData1.visible then Line_no:=Line_no+1 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure qry_sum_invVALUE_ON_HANDOnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;{&#13;&#10;    if round(&#60;qry_sum_inv.&#34;FW_VALUE&#34;&#62;+&#60;qry_sum_inv.&#34;RCV_VALUE&#34;&#62;-&#60;qry_sum_inv.&#34;DIS_VALUE&#34;&#62;)&#60;&#62;round(&#60;qry_sum_inv.&#34;RM_VALUE&#34;&#62;)&#13;&#10;     then qry_sum_invVALUE_ON_HAND.font.color:=clRed else   qry_sum_invVALUE_ON_HAND.font.color:=clBlack ;&#13;&#10;     }&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
