      <TfrxMemoView Name="Memo2" AllowVectorExport="True" Left="7.55906" Top="4.22047" Width="699.21305" Height="49.13389" Font.Charset="1" Font.Color="0" Font.Height="-21" Font.Name="TH SarabunPSK" Font.Style="1" Frame.Typ="15" Fill.BackColor="15790320" HAlign="haCenter" ParentFont="False" Text="รายงานสรุปการบริหารเวชภัณฑ์ ปีงบประมาณ [e_fy.text]&#13;&#10;คลัง:  [TRIM(cbb_stock.text)] ">
