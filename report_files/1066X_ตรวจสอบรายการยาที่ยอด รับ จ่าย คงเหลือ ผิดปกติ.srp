<TfrxReport Version="6.9.2" DotMatrixReport="False" EngineOptions.SilentMode="True" EngineOptions.NewSilentMode="simSilent" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="45113.6568490625" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  m0,y0,ym_fw,ym1,ym2 : string ;&#13;&#10;  aic1,aic2,aic3,aic4,aic5,aic6,aic7: string ;&#13;&#10;  i: integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  m1.Text:=ReadStringFR(&#60;REPORT_NO&#62;,'m1', COPY( DATEtoYMD(&#60;Date&#62;),5,2)) ;&#13;&#10;   m2.Text:=ReadStringFR(&#60;REPORT_NO&#62;,'m2',COPY( DATEtoYMD(&#60;Date&#62;),5,2));&#13;&#10;    y1.Text:=ReadStringFR(&#60;REPORT_NO&#62;,'y1',COPY( DATEtoYMD(&#60;Date&#62;),1,4)) ;&#13;&#10;     y2.Text:=ReadStringFR(&#60;REPORT_NO&#62;,'y2',COPY( DATEtoYMD(&#60;Date&#62;),1,4)) ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  i:= 0 ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  if   strtoint(m1.text) = 1 then&#13;&#10;  begin&#13;&#10;    m0:='12' ;&#13;&#10;    y0:=inttostr(strtoint(y1.text)-1-543) ;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;&#13;&#10;    if   length(inttostr(strtoint(m1.text)-1)) = 1 then&#13;&#10;    m0:= '0'+inttostr(strtoint(m1.text)-1) else  m0:=inttostr(strtoint(m1.text)-1);&#13;&#10;&#13;&#10;    y0:=inttostr(strtoint(y1.text)-543) ;&#13;&#10;&#13;&#10;  end;&#13;&#10;&#13;&#10;   ym_fw:=y0+m0 ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  if length(m1.text)=1 then&#13;&#10;  begin&#13;&#10;    ym1:=inttostr(strtoint(y1.text)-543)+'0'+m1.text ;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;    ym1:=inttostr(strtoint(y1.text)-543)+m1.text ;&#13;&#10;  end;&#13;&#10;&#13;&#10;&#13;&#10;  if length(m2.text)=1 then&#13;&#10;  begin&#13;&#10;    ym2:=inttostr(strtoint(y2.text)-543)+'0'+m2.text ;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;    ym2:=inttostr(strtoint(y2.text)-543)+m2.text ;&#13;&#10;  end;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure MasterData3OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    i:=i+1 ;&#13;&#10;&#13;&#10;   if i = 1 then&#13;&#10;   begin&#13;&#10;      aic1:='ลงชื่อ ...............................................'+#13&#13;&#10;            +'('+&#60;qry_aic.&#34;TITLE_NAME&#34;&#62;+&#60;qry_aic.&#34;AIC_NAME&#34;&#62;+')'+#13&#13;&#10;            +&#60;qry_aic.&#34;PRESI&#34;&#62; ;&#13;&#10;   end&#13;&#10;   else if i=2 then&#13;&#10;   begin&#13;&#10;      aic2:='ลงชื่อ ...............................................'+#13&#13;&#10;            +'('+&#60;qry_aic.&#34;TITLE_NAME&#34;&#62;+&#60;qry_aic.&#34;AIC_NAME&#34;&#62;+')'+#13&#13;&#10;            +&#60;qry_aic.&#34;PRESI&#34;&#62; ;&#13;&#10;   end&#13;&#10;   else if i=3 then&#13;&#10;   begin&#13;&#10;      aic3:='ลงชื่อ ...............................................'+#13&#13;&#10;            +'('+&#60;qry_aic.&#34;TITLE_NAME&#34;&#62;+&#60;qry_aic.&#34;AIC_NAME&#34;&#62;+')'+#13&#13;&#10;            +&#60;qry_aic.&#34;PRESI&#34;&#62;;&#13;&#10;   end&#13;&#10;   else if i=4 then&#13;&#10;   begin&#13;&#10;      aic4:='ลงชื่อ ...............................................'+#13&#13;&#10;            +'('+&#60;qry_aic.&#34;TITLE_NAME&#34;&#62;+&#60;qry_aic.&#34;AIC_NAME&#34;&#62;+')'+#13&#13;&#10;            +&#60;qry_aic.&#34;PRESI&#34;&#62; ;&#13;&#10;   end&#13;&#10;   else if i=5 then&#13;&#10;   begin&#13;&#10;      aic5:='ลงชื่อ ...............................................'+#13&#13;&#10;            +'('+&#60;qry_aic.&#34;TITLE_NAME&#34;&#62;+&#60;qry_aic.&#34;AIC_NAME&#34;&#62;+')'+#13&#13;&#10;            +&#60;qry_aic.&#34;PRESI&#34;&#62; ;&#13;&#10;   end&#13;&#10;   else if i=6 then&#13;&#10;   begin&#13;&#10;      aic6:='ลงชื่อ ...............................................'+#13&#13;&#10;            +'('+&#60;qry_aic.&#34;TITLE_NAME&#34;&#62;+&#60;qry_aic.&#34;AIC_NAME&#34;&#62;+')'+#13&#13;&#10;            +&#60;qry_aic.&#34;PRESI&#34;&#62; ;&#13;&#10;   end&#13;&#10;   else if i=7 then&#13;&#10;   begin&#13;&#10;      aic7:='ลงชื่อ ...............................................'+#13&#13;&#10;            +'('+&#60;qry_aic.&#34;TITLE_NAME&#34;&#62;+&#60;qry_aic.&#34;AIC_NAME&#34;&#62;+')'+#13&#13;&#10;            +&#60;qry_aic.&#34;PRESI&#34;&#62; ;&#13;&#10;   end ;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;procedure m1OnExit(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  WriteStringFR(&#60;REPORT_NO&#62;,'m1',  m1.text) ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure m2OnExit(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   WriteStringFR(&#60;REPORT_NO&#62;,'m2',  m2.text) ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure y1OnExit(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   WriteStringFR(&#60;REPORT_NO&#62;,'y1',  y1.text) ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure y2OnExit(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   WriteStringFR(&#60;REPORT_NO&#62;,'y2',  y2.text) ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure cbb_stockOnKeyUp(Sender: TfrxComponent; var Key: Word; Shift: Integer);&#13;&#10;begin&#13;&#10;   WriteStringFR(&#60;REPORT_NO&#62;,'cbb_stock', cbb_stock.keyvalue) ;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_stock" DataSetName="stock"/>
    <item DataSet="qry_overall" DataSetName="overall"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
    <item Name="hosp_name"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}   &#13;&#10;&#13;&#10;select * from DEPT_ID (NOLOCK) where&#13;&#10;(HIDE='' or HIDE is null or HIDE='N') and (DEPT_TYPE = 2 or DEPT_TYPE=3)&#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;  &#13;&#10; select * from DEPT_ID  where&#13;&#10;(HIDE='' or HIDE is null or HIDE='N') and (DEPT_TYPE = 2 or DEPT_TYPE=3)&#13;&#10;order by DEPT_NAME&#13;&#10;  &#13;&#10;{ENDIF}                       " SpecificOptions.Text="" PropData="05704C65667402480470546F7002780A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_overall" UserName="overall" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select T.WORKING_CODE,T.DRUG_NAME,&#13;&#10;T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM from (&#13;&#10;select dbo.NLEM(g.IS_ED) as NLEM,g.IS_ED,g.WORKING_CODE,g.DRUG_NAME,                                                                                                                    &#13;&#10;&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;       /* left(c.R_S_DATE,6) &#60;= :ym_fw   */ left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym_fw                                               &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  ) as FW_VALUE,&#13;&#10;          &#13;&#10;isnull(Cx.RCV_VALUE,0) AS RCV_VALUE,isnull(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;       /* left(c.R_S_DATE,6) &#60;= :ym2 */  left(dbo.ce2cymd(c.OPERATE_DATE),6)  &#60;= :ym2                            &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as RM_VALUE            &#13;&#10;from INV_MD  i (NOLOCK)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;         SUM(CASE when c1.R_S_STATUS in ('R','A','I','G','N') then c1.VALUE /*N= Receive from Return*/           &#13;&#10;                          when c1.R_S_STATUS in ('M','E','B','B') then c1.VALUE*-1 else NULL end) as RCV_VALUE,&#13;&#10;           &#13;&#10;       						SUM(CASE when c1.R_S_STATUS in ('S','D','P','T','O')  then c1.[VALUE]  /*O= Drug Return*/  &#13;&#10;	              									 when (c1.R_S_STATUS in ('C','U','Z')) then c1.[VALUE]*-1 else NULL end) as DIS_VALUE&#13;&#10;   						from CARD c1  (NOLOCK)  &#13;&#10;            where  c1.STOCK_ID=:stock                          &#13;&#10;           /* and    left(c1.R_S_DATE,6) between :ym1 and  :ym2  */  and  left(dbo.ce2cymd(c1.OPERATE_DATE),6)  between :ym1 and  :ym2       &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;group by T.NLEM ,T.IS_ED,T.WORKING_CODE,T.DRUG_NAME               &#13;&#10;&#13;&#10;HAVING ROUND(SUM(isnull(T.FW_VALUE,0)) + SUM(isnull(RCV_VALUE,0))  -SUM(isnull(T.DIS_VALUE,0)),2) &#60;&#62; ROUND(SUM(isnull(RM_VALUE,0)),2)&#13;&#10;  &#13;&#10;order by T.DRUG_NAME&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;  &#13;&#10;select T.WORKING_CODE,T.DRUG_NAME,&#13;&#10;T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM from (&#13;&#10;select  NLEM(g.IS_ED) as NLEM,g.IS_ED,g.WORKING_CODE,g.DRUG_NAME,                                                                                                                    &#13;&#10;&#13;&#10;(select  c.REMAIN_VALUE from  CARD c           &#13;&#10;        where &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m%d'),6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC limit 1  ) as FW_VALUE,&#13;&#10;          &#13;&#10;ifnull(Cx.RCV_VALUE,0) AS RCV_VALUE,ifnull(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select  c.REMAIN_VALUE from  CARD c         &#13;&#10;        where &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m%d'),6) &#60;= :ym2              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  limit 1 ) as RM_VALUE            &#13;&#10;from INV_MD  i       &#13;&#10;left join DRUG_GN g   on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;        SUM(CASE when c1.R_S_STATUS in ('R','A','N','I','G') then c1.VALUE   /*N= Receive from Return*/                                                                    &#13;&#10;                          when c1.R_S_STATUS in ('M','E','B','B') then c1.VALUE*-1 else NULL end) as RCV_VALUE,&#13;&#10;           &#13;&#10;       						SUM(CASE when c1.R_S_STATUS in ('S','D','P','T','O')  then c1.VALUE  /*O= Drug Return*/                                                 &#13;&#10;	              									 when (c1.R_S_STATUS in ('C','U','Z')) then c1.VALUE*-1 else NULL end) as DIS_VALUE&#13;&#10;   						from CARD c1     &#13;&#10;            where  c1.STOCK_ID=:stock                          &#13;&#10;            and    left(DATE_FORMAT(c1.OPERATE_DATE,'%Y%m%d'),6) between :ym1 and  :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;group by T.NLEM ,T.IS_ED,T.WORKING_CODE,T.DRUG_NAME               &#13;&#10;&#13;&#10;HAVING ROUND(SUM(ifnull(T.FW_VALUE,0)) + SUM(ifnull(RCV_VALUE,0))  -SUM(ifnull(T.DIS_VALUE,0)),4) &#60;&#62; ROUND(SUM(ifnull(RM_VALUE,0)),4)&#13;&#10;  &#13;&#10;order by T.DRUG_NAME  &#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
