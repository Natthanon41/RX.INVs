<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="42119.8655733102" ReportOptions.Description.Text="" ReportOptions.LastChange="45210.5944818403" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  date1.date:=now  ;&#13;&#10;  date2.date:=now  ;&#13;&#10;&#13;&#10;  qry_dept.close ;&#13;&#10;  qry_dept.open ;&#13;&#10;&#13;&#10;  cbb_dept.keyvalue:=&#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="rp1"/>
    <item DataSet="qry_dept" DataSetName="dept"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select m.DEPT_ID,m.INVOICE_NO,m.RECEIVE_NO,m.PO_NO,dbo.cymd2be(m.PO_DATE) as PODATE,v.COMPANY_NAME as VENDOR_NAME,c.QTY_ORDER,c.QTY_RCV,&#13;&#10;c.COST,c.PACK_RATIO,s1.SALE_UNIT as SUBPACKUNIT,dbo.cymd2be(m.RECEIVE_DATE) as RECEIVEDATE,      &#13;&#10;s2.SALE_UNIT as PACKUNIT,dbo.IS_ED(g.IS_ED) as ED_FLAG,&#13;&#10;CASE when c.FREE_FLAG='N' then c.[VALUE] else 0 end as VALUE_PO,&#13;&#10;CASE when c.FREE_FLAG&#60;&#62;'N' then c.[VALUE] else 0 end as VALUE_FREE,&#13;&#10;c.BUY_UNIT_COST,c.WORKING_CODE,g.DRUG_NAME&#13;&#10;from MS_IVO m (NOLOCK)&#13;&#10;left join MS_IVO_C c (NOLOCK) on (c.RECEIVE_NO=m.RECEIVE_NO and c.REV_FLAG='N')                                                                                                            &#13;&#10;left join COMPANY v (NOLOCK) on (v.COMPANY_CODE=m.VENDOR_CODE)   &#13;&#10;left JOIN PACK_RATIO p on (p.PACK_CODE=c.PACK_CODE)&#13;&#10;left join SALE_UNIT s1 (NOLOCK) on (s1.SU_ID=p.SUBPACK_UNIT)     &#13;&#10;left join SALE_UNIT s2 (NOLOCK) on (s2.SU_ID=p.PACK_UNIT)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE = g.WORKING_CODE)                                                                                                                              &#13;&#10;where&#13;&#10;/* m.RECEIVE_DATE+m.RCV_TIME between :date1 + :time1 and :date2 + :time2   and m.DEPT_ID=:stockid  */  &#13;&#10;m.RECEIVE_NO in (select R_S_NUMBER from CARD (NOLOCK) Where&#13;&#10;convert(varchar,CARD.OPERATE_DATE, 112)+left(convert(varchar,CARD.OPERATE_DATE, 14),2)&#13;&#10;+Substring(convert(varchar, CARD.OPERATE_DATE, 14),4,2) between&#13;&#10; :date1 + :time1 and :date2 + :time2   and CARD.STOCK_ID=:stockid  and  CARD.R_S_STATUS='R'&#13;&#10;)        &#13;&#10;and ( c.REV_FLAG='N' or   c.REV_FLAG='' or c.REV_FLAG is null)                                                                 &#13;&#10;and m.RCV_FLAG='Y'&#13;&#10;and m.TOTAL_ITEM &#62; 0                                             &#13;&#10;order by m.RECEIVE_DATE,m.PO_NO,m.INVOICE_NO                                                                                                                                                    &#13;&#10;&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;  &#13;&#10;select m.AI_NO,m.DEPT_ID,m.INVOICE_NO,m.RECEIVE_NO,m.PO_NO,cymd2be(m.PO_DATE) as PODATE,v.COMPANY_NAME as VENDOR_NAME,c.QTY_ORDER,c.QTY_RCV,&#13;&#10;c.COST,c.PACK_RATIO,s1.SALE_UNIT as SUBPACKUNIT,cymd2be(m.RECEIVE_DATE) as RECEIVEDATE,      &#13;&#10;s2.SALE_UNIT as PACKUNIT,IS_ED(g.IS_ED) as ED_FLAG,&#13;&#10;CASE when c.FREE_FLAG='N' then c.VALUE else 0 end as VALUE_PO,&#13;&#10;CASE when c.FREE_FLAG&#60;&#62;'N' then c.VALUE else 0 end as VALUE_FREE,&#13;&#10;c.BUY_UNIT_COST,c.WORKING_CODE,g.DRUG_NAME&#13;&#10;from MS_IVO m &#13;&#10;left join MS_IVO_C c  on (c.RECEIVE_NO=m.RECEIVE_NO and c.REV_FLAG='N')                                                                                                            &#13;&#10;left join COMPANY v  on (v.COMPANY_CODE=m.VENDOR_CODE)   &#13;&#10;left JOIN PACK_RATIO p on (p.PACK_CODE=c.PACK_CODE)&#13;&#10;left join SALE_UNIT s1  on (s1.SU_ID=p.SUBPACK_UNIT)     &#13;&#10;left join SALE_UNIT s2  on (s2.SU_ID=p.PACK_UNIT)     &#13;&#10;left join DRUG_GN g  on (c.WORKING_CODE = g.WORKING_CODE)                                                                                                                              &#13;&#10;where&#13;&#10;m.RECEIVE_NO in (select R_S_NUMBER from CARD  Where&#13;&#10;DATE_FORMAT(CARD.OPERATE_DATE,'%Y%m%d%H%i') between&#13;&#10;CONCAT( :date1 , :time1 ) and  CONCAT( :date2 , :time2 )  and CARD.STOCK_ID=:stockid  and  CARD.R_S_STATUS='R'&#13;&#10;)        &#13;&#10;and ( c.REV_FLAG='N' or   c.REV_FLAG='' or c.REV_FLAG is null)                                                                 &#13;&#10;and m.RCV_FLAG='Y'&#13;&#10;and m.TOTAL_ITEM &#62; 0                                             &#13;&#10;order by m.RECEIVE_DATE,m.AI_NO,m.RECEIVE_NO   &#13;&#10;&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_dept" UserName="dept" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=2&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;select * from DEPT_ID  where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=2&#13;&#10;&#13;&#10;{endif}                " SpecificOptions.Text="" PropData="05704C656674034C010470546F700308010A506172616D65746572730100"/>
  </TfrxDataPage>
