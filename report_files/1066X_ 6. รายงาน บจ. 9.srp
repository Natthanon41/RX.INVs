  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID  where HIDE='' or HIDE is null or HIDE='N'   order by DEPT_NAME                                                                                 " SpecificOptions.Text="" PropData="05704C6566740388000470546F700390000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="qry_sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SELECT d.DEPT_NAME,T.DEPT_ID,T.WORKING_CODE,T.DRUG_NAME,T.IS_ED,T.NLEM,SUM(FW_QTY) as FW_QTY,SUM(RCV_QTY) as RCV_QTY,SUM(DIS_QTY) as DIS_QTY,SUM(RM_QTY) as RM_QTY      &#13;&#10;from (  &#13;&#10;select i.DEPT_ID,g.DRUG_NAME,i.WORKING_CODE,NLEM(g.IS_ED) as NLEM, g.IS_ED,    &#13;&#10;&#13;&#10;(select  c.REMAIN_QTY from  CARD c  &#13;&#10;        where &#13;&#10;        /*left(c.R_S_DATE,6)*/ce2cymd(c.OPERATE_DATE) between  ce2cymd(CURDATE()-900) and  :ymd_fw                                                &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1) as FW_QTY,&#13;&#10;          &#13;&#10;Cx.RCV_QTY,Cx.DIS_QTY ,&#13;&#10;      &#13;&#10;(select  c.REMAIN_QTY from  CARD c  &#13;&#10;        where &#13;&#10;        /*left(c.R_S_DATE,6)*/ ce2cymd(c.OPERATE_DATE)  between ce2cymd(CURDATE()-900)   and  :ymd1                            &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1 ) as RM_QTY,i.TOTAL_VALUE&#13;&#10;          &#13;&#10;from INV_MD i&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (&#13;&#10;   select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          						SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.ACTIVE_QTY                    &#13;&#10;                   when c1.R_S_STATUS in ('B') then c1.ACTIVE_QTY*-1 &#13;&#10;                   else NULL end) as RCV_QTY,&#13;&#10;            						SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.ACTIVE_QTY                     &#13;&#10;	                     									 when (c1.R_S_STATUS='C') then c1.ACTIVE_QTY*-1 else NULL end) as DIS_QTY      &#13;&#10;            						from CARD c1&#13;&#10;            where (( c1.STOCK_ID in ('OPD01','OPD02','OPD03','OPD04','PHY01') and :rxTypeO = 'O' ) OR  ( c1.STOCK_ID in ('IPD01','IPD02') and :rxTypeI = 'I' ))                                                            &#13;&#10;            /*and left(c1.R_S_DATE,6)*/ and ce2cymd(c1.OPERATE_DATE) between :ym1 and  :ym2     &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx&#13;&#10;            &#13;&#10;             on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)                                                                         &#13;&#10;where (( i.DEPT_ID in ('OPD01','OPD02','OPD03','OPD04','PHY01') and :rxTypeO = 'O' ) OR ( i.DEPT_ID in ('IPD01','IPD02') and :rxTypeI = 'I' ))                                                                 &#13;&#10;and i.WORKING_CODE in ('233150','674015','431033','534138','534186')&#13;&#10;)  as T&#13;&#10;/*where T.TOTAL_VALUE  &#62; 0.99 */&#13;&#10;/*where   FW_VALUE &#62; 0 and   RCV_VALUE &#62; 0 and   DIS_VALUE &#62; 0 and   RM_VALUE &#62; 0   */&#13;&#10;left join DEPT_ID d  on (d.DEPT_ID = T.DEPT_ID)                                                                                                                              &#13;&#10;group by  T.WORKING_CODE,d.DEPT_NAME,T.DEPT_ID,T.DRUG_NAME,T.IS_ED,T.NLEM&#13;&#10;order by T.DEPT_ID,T.DRUG_NAME                          " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_lot_dis" UserName="lot_dis" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DISTINCT LOT_NO from CARD  where&#13;&#10; R_S_STATUS in ('T','S') &#13;&#10; and DEPT_ID=:dept_id&#13;&#10; and ce2cymd(OPERATE_DATE) between :date1 and :date2&#13;&#10; and WORKING_CODE=:working_code                                                                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_mft" UserName="mft" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DISTINCT m.COMPANY_NAME  from CARD c&#13;&#10;left join DRUG_VN v on (c.TRADE_CODE =v.TRADE_CODE)                                                                                                                                   &#13;&#10;left join COMPANY m  on (m.COMPANY_CODE = v.MANUFAC_CODE)                                                                                                                                                                                               &#13;&#10;where&#13;&#10; ( c.STOCK_ID=:stock_id  or  c.DEPT_ID =:dept_id )                                                   &#13;&#10; and ce2cymd(c.OPERATE_DATE) between :date1 and :date2&#13;&#10; and c.WORKING_CODE=:working_code                                                                                      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_lot_rcv" UserName="lot_rcv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DISTINCT LOT_NO from CARD  &#13;&#10; where&#13;&#10; R_S_STATUS in ('R','I','G','A') and DEPT_ID=:dept_id&#13;&#10; and  ce2cymd(OPERATE_DATE) between :date1 and :date2&#13;&#10; and WORKING_CODE=:working_code                                                                    " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_lot_fw" UserName="lot_fw" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DISTINCT LOT_NO from CARD &#13;&#10; where&#13;&#10; R_S_STATUS in ('R','I','G','A') and DEPT_ID=:dept_id&#13;&#10; and  ce2cymd(OPERATE_DATE) between :date1 and :date2&#13;&#10; and WORKING_CODE=:working_code                                                                    " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_sum_inv2" UserName="sum_inv2" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SELECT T.WORKING_CODE,T.DRUG_NAME,T.IS_ED,T.NLEM,SUM(FW_QTY) as FW_QTY,SUM(RCV_QTY) as RCV_QTY,SUM(DIS_QTY) as DIS_QTY,SUM(RM_QTY) as RM_QTY      &#13;&#10;from (  &#13;&#10;select i.DEPT_ID,g.DRUG_NAME,i.WORKING_CODE,NLEM(g.IS_ED) as NLEM, g.IS_ED,    &#13;&#10;&#13;&#10;(select   c.REMAIN_QTY from  CARD c  &#13;&#10;        where &#13;&#10;        /*left(c.R_S_DATE,6)*/ce2cymd(c.OPERATE_DATE) between  ce2cymd(CURDATE()-900) and  :ymd_fw                                                &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC  limit 1 ) as FW_QTY,&#13;&#10;          &#13;&#10;Cx.RCV_QTY,Cx.DIS_QTY ,&#13;&#10;      &#13;&#10;(select   c.REMAIN_QTY from  CARD c  &#13;&#10;        where &#13;&#10;        /*left(c.R_S_DATE,6)*/ ce2cymd(c.OPERATE_DATE)  between ce2cymd(CURDATE()-900)   and  :ymd1                            &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC  limit 1) as RM_QTY,i.TOTAL_VALUE&#13;&#10;          &#13;&#10;from INV_MD i&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (&#13;&#10;   select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          						SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.ACTIVE_QTY                    &#13;&#10;                   when c1.R_S_STATUS in ('B') then c1.ACTIVE_QTY*-1 &#13;&#10;                   else NULL end) as RCV_QTY,&#13;&#10;            						SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.ACTIVE_QTY                     &#13;&#10;	                     									 when (c1.R_S_STATUS='C') then c1.ACTIVE_QTY*-1 else NULL end) as DIS_QTY      &#13;&#10;            						from CARD c1&#13;&#10;            where (( c1.STOCK_ID in ('OPD01','OPD02','OPD03','OPD04','PHY01') and :rxTypeO = 'O' ) OR  ( c1.STOCK_ID in ('IPD01','IPD02') and :rxTypeI = 'I' ))                                                            &#13;&#10;            /*and left(c1.R_S_DATE,6)*/ and ce2cymd(c1.OPERATE_DATE) between :ym1 and  :ym2     &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx&#13;&#10;            &#13;&#10;             on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)                                                                         &#13;&#10;where (( i.DEPT_ID in ('OPD01','OPD02','OPD03','OPD04','PHY01') and :rxTypeO = 'O' ) OR ( i.DEPT_ID in ('IPD01','IPD02') and :rxTypeI = 'I' ))                                                                 &#13;&#10;and i.WORKING_CODE in ('233150','674015','431033','534138','534186')&#13;&#10;)  as T&#13;&#10;/*where T.TOTAL_VALUE  &#62; 0.99 */&#13;&#10;/*where   FW_VALUE &#62; 0 and   RCV_VALUE &#62; 0 and   DIS_VALUE &#62; 0 and   RM_VALUE &#62; 0   */                                                                                                                              &#13;&#10;group by  T.WORKING_CODE,T.DRUG_NAME,T.IS_ED,T.NLEM&#13;&#10;order by T.DRUG_NAME                          " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_lot_dis2" UserName="lot_dis2" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DISTINCT LOT_NO from CARD  where&#13;&#10; R_S_STATUS in ('T','S')&#13;&#10; and  ce2cymd(OPERATE_DATE) between :date1 and :date2&#13;&#10; and WORKING_CODE=:working_code                                                                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_mft2" UserName="mft2" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DISTINCT m.COMPANY_NAME  from CARD c &#13;&#10;left join DRUG_VN v   on (c.TRADE_CODE =v.TRADE_CODE)                                                                                                                                   &#13;&#10;left join COMPANY m   on (m.COMPANY_CODE = v.MANUFAC_CODE)                                                                                                                                                                                               &#13;&#10;where&#13;&#10; ce2cymd(c.OPERATE_DATE) between :date1 and :date2&#13;&#10; and c.WORKING_CODE=:working_code                                                                                      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_lot_rcv2" UserName="lot_rcv2" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DISTINCT LOT_NO from CARD &#13;&#10; where&#13;&#10; R_S_STATUS in ('R','I','G','A') &#13;&#10; and ce2cymd(OPERATE_DATE) between :date1 and :date2&#13;&#10; and WORKING_CODE=:working_code                                                                    " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_lot_fw2" UserName="lot_fw2" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DISTINCT LOT_NO from CARD &#13;&#10; where&#13;&#10; R_S_STATUS in ('R','I','G','A') &#13;&#10; and ce2cymd(OPERATE_DATE) between :date1 and :date2&#13;&#10; and WORKING_CODE=:working_code                                                                    " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
