<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="43066.5917895833" ReportOptions.Description.Text="" ReportOptions.LastChange="43172.6108384491" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  m0,y0,ymd_fw,ymd1,ymd2,dept_opd,dept_ipd,lot_d,lot_r,lot_f,mft_name : string ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;{&#13;&#10;   qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;  }&#13;&#10;&#13;&#10;  date1.date:=now-30 ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure BitBtn1OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;   ymd_fw:=formatdatetime('YYYYMMDD',date1.date-1) ;&#13;&#10;   ymd1:=formatdatetime('YYYYMMDD',date1.date) ;&#13;&#10;   ymd2:=formatdatetime('YYYYMMDD',date2.date) ;&#13;&#10;&#13;&#10;  if rb_opd.checked then&#13;&#10;  begin&#13;&#10;   dept_opd:='O' ;&#13;&#10;   dept_ipd:='O' ;&#13;&#10;  end&#13;&#10;  else if rb_ipd.checked  then&#13;&#10;  begin&#13;&#10;   dept_opd:='I' ;&#13;&#10;   dept_ipd:='I' ;&#13;&#10;  end&#13;&#10;  else if rb_all.checked then&#13;&#10;  begin&#13;&#10;   dept_opd:='O' ;&#13;&#10;   dept_ipd:='I' ;&#13;&#10;  end;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure Memo54OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    qry_lot_dis.close ;&#13;&#10;  qry_lot_dis.open ;&#13;&#10;  lot_d:='' ;&#13;&#10;  while not qry_lot_dis.eof do&#13;&#10;  begin&#13;&#10;    lot_d:=lot_d+qry_lot_dis.fieldbyname('LOT_NO').asstring+', ' ;&#13;&#10;  qry_lot_dis.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;  lot_d:=COPY(lot_d,1,length(lot_d)-2) ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo55OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_lot_rcv.close ;&#13;&#10;  qry_lot_rcv.open ;&#13;&#10;  lot_r:='' ;&#13;&#10;  while not qry_lot_rcv.eof do&#13;&#10;  begin&#13;&#10;    lot_r:=lot_r+qry_lot_rcv.fieldbyname('LOT_NO').asstring+', ' ;&#13;&#10;  qry_lot_rcv.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;   lot_r:=COPY(lot_r,1,length(lot_r)-2) ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo56OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  qry_lot_fw.close ;&#13;&#10;  qry_lot_fw.open ;&#13;&#10;  lot_f:='' ;&#13;&#10;  while not qry_lot_fw.eof do&#13;&#10;  begin&#13;&#10;    lot_f:=lot_f+qry_lot_fw.fieldbyname('LOT_NO').asstring+', ' ;&#13;&#10;  qry_lot_fw.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;  lot_f:=COPY(lot_f,1,length(lot_f)-2) ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure Memo57OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_mft.close ;&#13;&#10;  qry_mft.open ;&#13;&#10;&#13;&#10;  mft_name:='' ;&#13;&#10;&#13;&#10;  while not qry_mft.eof do&#13;&#10;  begin&#13;&#10;    mft_name:=mft_name+trim(qry_mft.fieldbyname('COMPANY_NAME').asstring)+', ' ;&#13;&#10;  qry_mft.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;  mft_name:=COPY(mft_name,1,length(mft_name)-2) ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo15OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  qry_mft2.close ;&#13;&#10;  qry_mft2.open ;&#13;&#10;&#13;&#10;  mft_name:='' ;&#13;&#10;&#13;&#10;  while not qry_mft2.eof do&#13;&#10;  begin&#13;&#10;    mft_name:=mft_name+trim(qry_mft2.fieldbyname('COMPANY_NAME').asstring)+', ' ;&#13;&#10;  qry_mft2.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;  mft_name:=COPY(mft_name,1,length(mft_name)-2) ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo59OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   qry_lot_fw2.close ;&#13;&#10;  qry_lot_fw2.open ;&#13;&#10;  lot_f:='' ;&#13;&#10;  while not qry_lot_fw2.eof do&#13;&#10;  begin&#13;&#10;    lot_f:=lot_f+qry_lot_fw2.fieldbyname('LOT_NO').asstring+', ' ;&#13;&#10;  qry_lot_fw2.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;  lot_f:=COPY(lot_f,1,length(lot_f)-2) ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo58OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;     qry_lot_rcv2.close ;&#13;&#10;  qry_lot_rcv2.open ;&#13;&#10;  lot_r:='' ;&#13;&#10;  while not qry_lot_rcv2.eof do&#13;&#10;  begin&#13;&#10;    lot_r:=lot_r+qry_lot_rcv2.fieldbyname('LOT_NO').asstring+', ' ;&#13;&#10;  qry_lot_rcv2.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;   lot_r:=COPY(lot_r,1,length(lot_r)-2) ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo41OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;       qry_lot_dis2.close ;&#13;&#10;  qry_lot_dis2.open ;&#13;&#10;  lot_d:='' ;&#13;&#10;  while not qry_lot_dis2.eof do&#13;&#10;  begin&#13;&#10;    lot_d:=lot_d+qry_lot_dis2.fieldbyname('LOT_NO').asstring+', ' ;&#13;&#10;  qry_lot_dis2.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;  lot_d:=COPY(lot_d,1,length(lot_d)-2) ;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
