  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_location" UserName="location" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select DISTINCT isnull(LOCATION,'') as LOCATION from INV_SITE (NOLOCK) where DEPT_ID=:dept_id&#13;&#10;ORDER BY LOCATION&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select DISTINCT ifnull(LOCATION,'') as LOCATION&#13;&#10; from INV_SITE  where DEPT_ID=:dept_id&#13;&#10;ORDER BY LOCATION&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_inv_md" UserName="invmd" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER} &#13;&#10;&#13;&#10;select T.* FROM&#13;&#10;(&#13;&#10;select m.WORKING_CODE,isnull(i.TOTAL_VALUE,0) as TOTAL_VALUE,SUM(isnull(i.TOTAL_VALUE,10)*100/i.TOTAL_VALUE_DEPT)&#13;&#10;OVER (ORDER BY i.TOTAL_VALUE DESC) &#13;&#10; as PerCum,  &#13;&#10; ISNULL(convert(int,i.QTY_ON_HAND)%convert(int,i.PACK_RATIO),0) as UNPACK,&#13;&#10; g.DRUG_NAME,isnull(i.PACK_RATIO,m.LAST_PACK_RATIO) as PACK_RATIO,isnull(i.QTY_ON_HAND,0) as QTY_ON_HAND ,isnull(i.LOCATION,isnull(m.LOCATION,'')) as LOCATION &#13;&#10;from INV_MD m (NOLOCK) &#13;&#10;left join (select s.WORKING_CODE,SUM(c.QTY_ON_HAND) as QTY_ON_HAND,SUM(c.LOT_VALUE) as TOTAL_VALUE,MAX(c.PACK_RATIO) as PACK_RATIO  &#13;&#10;,MAX(s.LOCATION) as LOCATION,(select sum(isnull(x.LOT_VALUE,0)) &#13;&#10;from INV_MD_C x (NOLOCK) where x.DEPT_ID='STO01'  ) as TOTAL_VALUE_DEPT &#13;&#10;from INV_SITE s (NOLOCK) &#13;&#10;left join INV_MD_C c (NOLOCK) on (s.TRADE_CODE = c.TRADE_CODE and s.DEPT_ID =c.DEPT_ID ) &#13;&#10;Where &#13;&#10;  isnull(s.LOCATION,'') in ('','1V','2CHE','2CHO','2N','2P','2SH','2SL','2SL1','2SL2','2SL3','3A','3CHO','3H','3HS','3J','3JL','3JP','3L','3M','3R','3T','3V','4A','4E','4EP','4H','4HP','4P','4PA','4S','4SH','4SS','4TB','4V','4X','4Z','IV','M','OR','R','R15','RCHO','VC','X')&#13;&#10;and  s.DEPT_ID='STO01' group by s.WORKING_CODE  ) as i &#13;&#10; on (m.DEPT_ID='STO01' and m.WORKING_CODE = i.WORKING_CODE) &#13;&#10;left join DRUG_GN g (NOLOCK) on (m.WORKING_CODE = g.WORKING_CODE)&#13;&#10;where (g.HIDE='' or g.HIDE is null or g.HIDE='N')&#13;&#10; and isnull(m.ABC_FLAG,'C') in ('A','B','C','') &#13;&#10; and isnull(g.VEN_FLAG,'N') in ('V','E','N','') &#13;&#10; and m.DEPT_ID='STO01'  and i.WORKING_CODE is not null &#13;&#10; ) as T where T.PerCum &#60;=100&#13;&#10; ORDER BY T.LOCATION,T.DRUG_NAME&#13;&#10;&#13;&#10;{ELSE} &#13;&#10;&#13;&#10;select T.* FROM&#13;&#10;(&#13;&#10;select m.WORKING_CODE,ifnull(i.TOTAL_VALUE,0) as TOTAL_VALUE,SUM(ifnull(i.TOTAL_VALUE,10)*100/i.TOTAL_VALUE_DEPT)&#13;&#10;OVER (ORDER BY i.TOTAL_VALUE DESC) &#13;&#10; as PerCum,  &#13;&#10; IFNULL(convert(i.QTY_ON_HAND,int)%convert(i.PACK_RATIO,int),0) as UNPACK,&#13;&#10; g.DRUG_NAME,ifnull(i.PACK_RATIO,m.LAST_PACK_RATIO) as PACK_RATIO,ifnull(i.QTY_ON_HAND,0) as QTY_ON_HAND ,ifnull(i.LOCATION,ifnull(m.LOCATION,'')) as LOCATION &#13;&#10;from INV_MD m  &#13;&#10;left join (select s.WORKING_CODE,SUM(c.QTY_ON_HAND) as QTY_ON_HAND,SUM(c.LOT_VALUE) as TOTAL_VALUE,MAX(c.PACK_RATIO) as PACK_RATIO  &#13;&#10;,MAX(s.LOCATION) as LOCATION,(select sum(ifnull(x.LOT_VALUE,0)) &#13;&#10;from INV_MD_C x  where x.DEPT_ID='STO01'  ) as TOTAL_VALUE_DEPT &#13;&#10;from INV_SITE s  &#13;&#10;left join INV_MD_C c  on (s.TRADE_CODE = c.TRADE_CODE and s.DEPT_ID =c.DEPT_ID ) &#13;&#10;Where &#13;&#10;  ifnull(s.LOCATION,'') in ('','1V','2CHE','2CHO','2N','2P','2SH','2SL','2SL1','2SL2','2SL3','3A','3CHO','3H','3HS','3J','3JL','3JP','3L','3M','3R','3T','3V','4A','4E','4EP','4H','4HP','4P','4PA','4S','4SH','4SS','4TB','4V','4X','4Z','IV','M','OR','R','R15','RCHO','VC','X')&#13;&#10;and  s.DEPT_ID='STO01' group by s.WORKING_CODE  ) as i &#13;&#10; on (m.DEPT_ID='STO01' and m.WORKING_CODE = i.WORKING_CODE) &#13;&#10;left join DRUG_GN g  on (m.WORKING_CODE = g.WORKING_CODE)&#13;&#10;where (g.HIDE='' or g.HIDE is null or g.HIDE='N')&#13;&#10; and ifnull(m.ABC_FLAG,'C') in ('A','B','C','') &#13;&#10; and ifnull(g.VEN_FLAG,'N') in ('V','E','N','') &#13;&#10; and m.DEPT_ID='STO01'  and i.WORKING_CODE is not null &#13;&#10; ) as T where T.PerCum &#60;=100&#13;&#10; ORDER BY T.LOCATION,T.DRUG_NAME&#13;&#10; {ENDIF}         " SpecificOptions.Text="" PropData="05704C6566740394000470546F7003C4000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_inv_md_c" UserName="invmd_c" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select  s.LOCATION, convert(int,i.QTY_ON_HAND)%convert(int,i.PACK_RATIO) as UNPACK, g.DRUG_NAME,v.TRADE_CODE,v.TRADE_NAME,i.*&#13;&#10;from INV_MD_C i (NOLOCK)&#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join DRUG_VN v (NOLOCK) on (i.TRADE_CODE = v.TRADE_CODE)&#13;&#10;left join INV_SITE s (NOLOCK) on (s.TRADE_CODE = i.TRADE_CODE  and s.DEPT_ID = i.DEPT_ID)                                                                                                                                              &#13;&#10;where i.DEPT_ID=:dept_id and i.WORKING_CODE=:WORKING_CODE&#13;&#10;  &#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select  s.LOCATION, CAST(i.QTY_ON_HAND as UNSIGNED)%CAST(i.PACK_RATIO as UNSIGNED) as UNPACK, g.DRUG_NAME,v.TRADE_CODE,v.TRADE_NAME,i.*&#13;&#10;from INV_MD_C i &#13;&#10;left join DRUG_GN g  on (i.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join DRUG_VN v  on (i.TRADE_CODE = v.TRADE_CODE)&#13;&#10;left join INV_SITE s  on (s.TRADE_CODE = i.TRADE_CODE  and s.DEPT_ID = i.DEPT_ID)                                                                                                                                              &#13;&#10;where i.DEPT_ID=:dept_id and i.WORKING_CODE=:WORKING_CODE    &#13;&#10;&#13;&#10;&#13;&#10;{ENDIF}                 " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
