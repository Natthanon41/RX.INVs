<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="42989.6540518866" ReportOptions.Description.Text="" ReportOptions.LastChange="45197.4805079745" ScriptLanguage="PascalScript" ScriptText.Text=" var&#13;&#10;  con_location,conc_location,con_abc,con_ven:string ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  Label4.caption:=&#60;MY_STOCK_NAME&#62; ;&#13;&#10;&#13;&#10;  qry_location.close ;&#13;&#10;  qry_location.open ;&#13;&#10;&#13;&#10;  while not qry_location.eof do&#13;&#10;  begin&#13;&#10;&#13;&#10;     CheckListBox1.items.add(qry_location.fieldbyname('LOCATION').asString) ;&#13;&#10;&#13;&#10;  qry_location.next ;&#13;&#10;  end;&#13;&#10;&#13;&#10;  selectAllOnClick(self) ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure CheckListBox1OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure BitBtn1OnClick(Sender: TfrxComponent);&#13;&#10;var&#13;&#10;  i:integer ;&#13;&#10;  sql,abc,ven:string ;&#13;&#10;  MySQL,SQLServer:String ;&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  qry_inv_md.close ;&#13;&#10;  qry_inv_md.SQL.Text:='' ;&#13;&#10;&#13;&#10;&#13;&#10;  SQLSERVER:=' select T.* FROM';&#13;&#10;  SQLSERVER:=SQLSERVER+'(';&#13;&#10;  SQLSERVER:=SQLSERVER+'select m.WORKING_CODE,isnull(i.TOTAL_VALUE,0) as TOTAL_VALUE,SUM(isnull(i.TOTAL_VALUE,10)*100/i.TOTAL_VALUE_DEPT)';&#13;&#10;  SQLSERVER:=SQLSERVER+'OVER (ORDER BY i.TOTAL_VALUE DESC) ';&#13;&#10;  SQLSERVER:=SQLSERVER+' as PerCum,  ';&#13;&#10;  SQLSERVER:=SQLSERVER+' ISNULL(convert(int,i.QTY_ON_HAND)%convert(int,i.PACK_RATIO),0) as UNPACK,';&#13;&#10;  SQLSERVER:=SQLSERVER+' g.DRUG_NAME,isnull(i.PACK_RATIO,m.LAST_PACK_RATIO) as PACK_RATIO,isnull(i.QTY_ON_HAND,0) as QTY_ON_HAND ,isnull(i.LOCATION,isnull(m.LOCATION,'+''''+''''+')) as LOCATION ';&#13;&#10;  SQLSERVER:=SQLSERVER+'from INV_MD m (NOLOCK) ';&#13;&#10;&#13;&#10;  SQLSERVER:=SQLSERVER+'left join (select s.WORKING_CODE,SUM(c.QTY_ON_HAND) as QTY_ON_HAND,SUM(c.LOT_VALUE) as TOTAL_VALUE,MAX(c.PACK_RATIO) as PACK_RATIO  ';&#13;&#10;  SQLSERVER:=SQLSERVER+',MAX(s.LOCATION) as LOCATION,(select sum(isnull(x.LOT_VALUE,0)) ';&#13;&#10;  SQLSERVER:=SQLSERVER+'from INV_MD_C x (NOLOCK) where x.DEPT_ID='+''''+&#60;MY_STOCK_CODE&#62;+''''+'  ) as TOTAL_VALUE_DEPT ';&#13;&#10;  SQLSERVER:=SQLSERVER+'from INV_SITE s (NOLOCK) ';&#13;&#10;  SQLSERVER:=SQLSERVER+'left join INV_MD_C c (NOLOCK) on (s.TRADE_CODE = c.TRADE_CODE and s.DEPT_ID =c.DEPT_ID ) ';&#13;&#10;  SQLSERVER:=SQLSERVER+'Where ';&#13;&#10;&#13;&#10;&#13;&#10;  sql:='' ;&#13;&#10;&#13;&#10;  for i:= 0 to checkListBox1.items.count - 1 do&#13;&#10;  begin&#13;&#10;    if checkListBox1.checked[i] then sql:=sql+''''+checkListBox1.Items.Strings(i)+''''+',' ;&#13;&#10;  end;&#13;&#10;&#13;&#10;   //----------------------------------------------------------------------------------------&#13;&#10;   if length(sql) &#62; 1 then&#13;&#10;   begin&#13;&#10;     sql:=COPY(sql,1,length(sql)-1);&#13;&#10;   //  sql:='('+sql+','+''''+''''+')' ;&#13;&#10;     sql:='('+sql+')' ;&#13;&#10;&#13;&#10;    // qry_inv_md.sql[13]:=' and c.LOCATION in '+sql ;&#13;&#10;    con_location:= '  isnull(s.LOCATION,'+''''+''''+') in '+sql ;&#13;&#10;    conc_location:= '  and  isnull(s.LOCATION,'+''''+''''+') in '+sql ;&#13;&#10;   end;&#13;&#10;   //----------------------------------------------------------------------------------------&#13;&#10;&#13;&#10;&#13;&#10;   if a.checked or b.checked  or c.checked then&#13;&#10;   begin&#13;&#10;&#13;&#10;     abc:=' and isnull(m.ABC_FLAG,'+''''+'C'+''''+') in (' ;&#13;&#10;&#13;&#10;    if a.checked then abc:=abc+''''+'A'+''''+',' ;&#13;&#10;    if b.checked then abc:=abc+''''+'B'+''''+',' ;&#13;&#10;    if c.checked then abc:=abc+''''+'C'+''''+',' ;&#13;&#10;    if (a.checked) and (b.checked) and (c.checked) then  abc:=abc+''''+''+''''+',' ;&#13;&#10;&#13;&#10;    //  qry_inv_md.sql.text:= qry_inv_md.sql.text +  COPY(abc,1,length(abc)-1)+') ' ;&#13;&#10;    con_abc:=COPY(abc,1,length(abc)-1)+') ' ;&#13;&#10;&#13;&#10;   end;&#13;&#10;&#13;&#10;&#13;&#10;   //----------------------------------------------------------------------------------------&#13;&#10;   if v.checked or e.checked  or n.checked then&#13;&#10;   begin&#13;&#10;&#13;&#10;     ven:=' and isnull(g.VEN_FLAG,'+''''+'N'+''''+') in (' ;&#13;&#10;&#13;&#10;&#13;&#10;     if v.checked then ven:=ven+''''+'V'+''''+',' ;&#13;&#10;     if e.checked then ven:=ven+''''+'E'+''''+',' ;&#13;&#10;     if n.checked then ven:=ven+''''+'N'+''''+',' ;&#13;&#10;     if (v.checked) and (e.checked) and (n.checked) then  ven:=ven+''''+''+''''+',' ;&#13;&#10;&#13;&#10;    // qry_inv_md.sql.text:= qry_inv_md.sql.text + COPY(ven,1,length(ven)-1)+') ' ;&#13;&#10;&#13;&#10;    con_ven:= COPY(ven,1,length(ven)-1)+') ' ;&#13;&#10;    // qry_inv_md.sql.text:= qry_inv_md.sql.text +' order by i.LOCATION,g.DRUG_NAME ' ;&#13;&#10;&#13;&#10;   end;&#13;&#10;   //----------------------------------------------------------------------------------------&#13;&#10;&#13;&#10;&#13;&#10;  SQLSERVER:=SQLSERVER+ con_location   ;&#13;&#10;&#13;&#10;// SQLSERVER:=SQLSERVER+'and c.PACK_RATIO   &#62; 0 ';&#13;&#10; SQLSERVER:=SQLSERVER+'and  s.DEPT_ID='+''''+&#60;MY_STOCK_CODE&#62;+''''+' group by s.WORKING_CODE  ) as i ';&#13;&#10; SQLSERVER:=SQLSERVER+' on (m.DEPT_ID='+''''+&#60;MY_STOCK_CODE&#62;+''''+' and m.WORKING_CODE = i.WORKING_CODE) ' ;&#13;&#10;&#13;&#10; SQLSERVER:=SQLSERVER+'left join DRUG_GN g (NOLOCK) on (m.WORKING_CODE = g.WORKING_CODE)';&#13;&#10;&#13;&#10; SQLSERVER:=SQLSERVER+'where (g.HIDE=' +''''+''''+' or g.HIDE is null or g.HIDE='+''''+'N'+''''+')';&#13;&#10;&#13;&#10;  SQLSERVER:=SQLSERVER+ con_abc   ;&#13;&#10;  SQLSERVER:=SQLSERVER+ con_ven   ;&#13;&#10;&#13;&#10; SQLSERVER:=SQLSERVER+' and m.DEPT_ID='+''''+&#60;MY_STOCK_CODE&#62;+''''+'  and i.WORKING_CODE is not null ';&#13;&#10; SQLSERVER:=SQLSERVER+' ) as T where T.PerCum &#60;='+RM_PERCENT.text;&#13;&#10;&#13;&#10;  if chk_orderCost.checked then&#13;&#10;    SQLSERVER:=SQLSERVER+ ' ORDER BY isnull(T.TOTAL_VALUE,0) DESC '&#13;&#10;  else&#13;&#10;    SQLSERVER:=SQLSERVER+' ORDER BY T.LOCATION,T.DRUG_NAME';&#13;&#10;&#13;&#10; //----------------------------------------------------MySQL------------------------------------------------------------------------------&#13;&#10;&#13;&#10;  MySQL:='select T.* FROM';&#13;&#10;  MySQL:=MySQL+'(';&#13;&#10;  MySQL:=MySQL+'select m.WORKING_CODE,ifnull(i.TOTAL_VALUE,0) as TOTAL_VALUE, ' ;&#13;&#10;  MySQL:=MySQL+'@PercentValue:= @PercentValue + ifnull(i.TOTAL_VALUE,0)*100/i.TOTAL_VALUE_DEPT as PerCum,' ;&#13;&#10;&#13;&#10;  MySQL:=MySQL+' IFNULL(CAST(i.QTY_ON_HAND as UNSIGNED)%CAST(i.PACK_RATIO  as UNSIGNED),0) as UNPACK,';&#13;&#10;  MySQL:=MySQL+' g.DRUG_NAME,ifnull(i.PACK_RATIO,m.LAST_PACK_RATIO) as PACK_RATIO,ifnull(i.QTY_ON_HAND,0) as QTY_ON_HAND ,ifnull(i.LOCATION,ifnull(m.LOCATION,'+''''+''''+')) as LOCATION ';&#13;&#10;&#13;&#10;  MySQL:=MySQL+'from INV_MD m  ';&#13;&#10;  MySQL:=MySQL+'JOIN (SELECT @PercentValue := 0) r  ';&#13;&#10;&#13;&#10;  MySQL:=MySQL+'left join (select s.WORKING_CODE,SUM(c.QTY_ON_HAND) as QTY_ON_HAND,SUM(c.LOT_VALUE) as TOTAL_VALUE,MAX(c.PACK_RATIO) as PACK_RATIO  ';&#13;&#10;  MySQL:=MySQL+',MAX(s.LOCATION) as LOCATION,(select sum(ifnull(x.LOT_VALUE,0)) ';&#13;&#10;  MySQL:=MySQL+'from INV_MD_C x  where x.DEPT_ID='+''''+&#60;MY_STOCK_CODE&#62;+''''+'  ) as TOTAL_VALUE_DEPT ';&#13;&#10;  MySQL:=MySQL+'from INV_SITE s  ';&#13;&#10;  MySQL:=MySQL+'left join INV_MD_C c  on (s.TRADE_CODE = c.TRADE_CODE and s.DEPT_ID =c.DEPT_ID ) ';&#13;&#10;  MySQL:=MySQL+'Where ';&#13;&#10;&#13;&#10;&#13;&#10;  sql:='' ;&#13;&#10;&#13;&#10;  for i:= 0 to checkListBox1.items.count - 1 do&#13;&#10;  begin&#13;&#10;    if checkListBox1.checked[i] then sql:=sql+''''+checkListBox1.Items.Strings(i)+''''+',' ;&#13;&#10;  end;&#13;&#10;&#13;&#10;   //----------------------------------------------------------------------------------------&#13;&#10;   if length(sql) &#62; 1 then&#13;&#10;   begin&#13;&#10;     sql:=COPY(sql,1,length(sql)-1);&#13;&#10;&#13;&#10;     sql:='('+sql+')' ;&#13;&#10;&#13;&#10;    con_location:= '  ifnull(s.LOCATION,'+''''+''''+') in '+sql ;&#13;&#10;    conc_location:= '  and  ifnull(s.LOCATION,'+''''+''''+') in '+sql ;&#13;&#10;   end;&#13;&#10;   //----------------------------------------------------------------------------------------&#13;&#10;&#13;&#10;&#13;&#10;   if a.checked or b.checked  or c.checked then&#13;&#10;   begin&#13;&#10;&#13;&#10;     abc:=' and ifnull(m.ABC_FLAG,'+''''+'C'+''''+') in (' ;&#13;&#10;&#13;&#10;    if a.checked then abc:=abc+''''+'A'+''''+',' ;&#13;&#10;    if b.checked then abc:=abc+''''+'B'+''''+',' ;&#13;&#10;    if c.checked then abc:=abc+''''+'C'+''''+',' ;&#13;&#10;    if (a.checked) and (b.checked) and (c.checked) then  abc:=abc+''''+''+''''+',' ;&#13;&#10;&#13;&#10;    con_abc:=COPY(abc,1,length(abc)-1)+') ' ;&#13;&#10;&#13;&#10;   end;&#13;&#10;&#13;&#10;&#13;&#10;   //----------------------------------------------------------------------------------------&#13;&#10;   if v.checked or e.checked  or n.checked then&#13;&#10;   begin&#13;&#10;&#13;&#10;     ven:=' and ifnull(g.VEN_FLAG,'+''''+'N'+''''+') in (' ;&#13;&#10;&#13;&#10;&#13;&#10;     if v.checked then ven:=ven+''''+'V'+''''+',' ;&#13;&#10;     if e.checked then ven:=ven+''''+'E'+''''+',' ;&#13;&#10;     if n.checked then ven:=ven+''''+'N'+''''+',' ;&#13;&#10;     if (v.checked) and (e.checked) and (n.checked) then  ven:=ven+''''+''+''''+',' ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;    con_ven:= COPY(ven,1,length(ven)-1)+') ' ;&#13;&#10;&#13;&#10;&#13;&#10;   end;&#13;&#10;   //----------------------------------------------------------------------------------------&#13;&#10;&#13;&#10;&#13;&#10;  MySQL:=MySQL+ con_location   ;&#13;&#10;&#13;&#10; MySQL:=MySQL+'and  s.DEPT_ID='+''''+&#60;MY_STOCK_CODE&#62;+''''+' group by s.WORKING_CODE  ) as i ';&#13;&#10; MySQL:=MySQL+' on (m.DEPT_ID='+''''+&#60;MY_STOCK_CODE&#62;+''''+' and m.WORKING_CODE = i.WORKING_CODE) ' ;&#13;&#10;&#13;&#10; MySQL:=MySQL+'left join DRUG_GN g  on (m.WORKING_CODE = g.WORKING_CODE)';&#13;&#10;&#13;&#10; MySQL:=MySQL+'where (g.HIDE=' +''''+''''+' or g.HIDE is null or g.HIDE='+''''+'N'+''''+')';&#13;&#10;&#13;&#10;  MySQL:=MySQL+ con_abc   ;&#13;&#10;  MySQL:=MySQL+ con_ven   ;&#13;&#10;&#13;&#10; MySQL:=MySQL+' and m.DEPT_ID='+''''+&#60;MY_STOCK_CODE&#62;+''''+'  and i.WORKING_CODE is not null ';&#13;&#10; MySQL:=MySQL+' ) as T where T.PerCum &#60;='+RM_PERCENT.text;&#13;&#10;&#13;&#10;  if chk_orderCost.checked then&#13;&#10;    MySQL:=MySQL+ ' ORDER BY ifnull(T.TOTAL_VALUE,0) DESC '&#13;&#10;  else&#13;&#10;    MySQL:=MySQL+' ORDER BY T.LOCATION,T.DRUG_NAME';&#13;&#10;&#13;&#10;  qry_inv_md.SQL.Text:='{IF SQLSERVER} '+SQLSERVER+' {ELSE} '+MySQL+' {ENDIF}' ;&#13;&#10; // Showmessage( qry_inv_md.sql.text);&#13;&#10;  qry_inv_md.open ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_inv_md_c.close ;&#13;&#10;//  qry_inv_md_c.sql[6]:=(conc_location)  ;&#13;&#10;  qry_inv_md_c.open ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure selectAllOnClick(Sender: TfrxComponent);&#13;&#10;var&#13;&#10; i:integer ;&#13;&#10;begin&#13;&#10;&#13;&#10;  for i:=0 to CheckListBox1.items.count -1 do&#13;&#10;  begin&#13;&#10;&#13;&#10;    CheckListBox1.checked[i]:= selectAll.checked ;&#13;&#10;&#13;&#10;  end;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure RM_PERCENTOnExit(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if trim(RM_PERCENT.text)='' then RM_PERCENT.text:='100' ;&#13;&#10;  if strtofloat(trim(RM_PERCENT.text)) &#62;100 then RM_PERCENT.text:='100' ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  con_location:='' ;&#13;&#10;  con_abc:='' ;&#13;&#10;  con_ven:='' ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure chk_OrderLocateDnameOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   if chk_OrderLocateDname.checked then chk_orderCost.checked:=False ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure chk_orderCostOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    if chk_orderCost.checked then chk_OrderLocateDname.checked:=False ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="frxReport1OnReportPrint">
  <Datasets>
    <item DataSet="qry_location" DataSetName="location"/>
    <item DataSet="qry_inv_md" DataSetName="invmd"/>
    <item DataSet="qry_inv_md_c" DataSetName="invmd_c"/>
  </Datasets>
