<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="42979.4310091898" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.8324388426" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; ym0:string ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_datetime.close ;&#13;&#10;  qry_datetime.open ;&#13;&#10;&#13;&#10;  m1.text:=formatdatetime('MM',&#60;qry_datetime.&#34;TODAY&#34;&#62;) ;&#13;&#10;  y1.text:=inttostr(strtoint(formatdatetime('YYYY',&#60;qry_datetime.&#34;TODAY&#34;&#62;))+543) ;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure BitBtn1OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if   length(inttostr(strtoint(m1.text))) = 1 then&#13;&#10;    begin&#13;&#10;     ym0:= inttostr(strtoint(y1.text)-543)+ '0'+inttostr(strtoint(m1.text)) ;&#13;&#10;    end&#13;&#10;    else&#13;&#10;    begin&#13;&#10;     ym0:=inttostr(strtoint(y1.text)-543)+m1.text ;&#13;&#10;    end;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_budget_amt" DataSetName="budget"/>
    <item DataSet="qry_dept" DataSetName="dept"/>
    <item DataSet="qry_datetime" DataSetName="qry_datetime"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_budget_amt" UserName="budget" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;&#13;&#10;  &#13;&#10;select t.BUDGET_NAME,b.BUDGET_AMOUNT,&#13;&#10;isnull(po.BUY_BF,0) as BUY_BF,&#13;&#10;isnull(po.BUY_THIS_MONTH,0) as BUY_THIS_MONTH,  &#13;&#10;isnull(po.TOTAL_BUY_PO,0) as TOTAL_BUY,&#13;&#10;b.BUDGET_AMOUNT- isnull(po.TOTAL_BUY_PO,0) as  REMAIN_BUDGET,&#13;&#10; isnull(po.TOTAL_BUY_PO,0)*100/isnull(b.BUDGET_AMOUNT,1) as PERCENT_OF_PO  ,&#13;&#10;  &#13;&#10;&#13;&#10;( select SUM(T.RM_COST) from (select (select top 1 c.REMAIN_COST from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6)  &#60;=   :ymd0            &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as RM_COST&#13;&#10;from INV_MD i (NOLOCK)&#13;&#10;left join DEPT_ID d (NOLOCK) on i.DEPT_ID =d.DEPT_ID where d.DEPT_TYPE=2) as T ) as TOTAL_INV&#13;&#10;  &#13;&#10;from BDG_AMT b (NOLOCK)&#13;&#10;left join BDG_TYPE t (NOLOCK) on (t.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;  &#13;&#10;left join (select p.BUDGET_TYPE,&#13;&#10;SUM(CASE when left(p.REQ_APP_DATE,6) = :ymd0  then p.TOTAL_COST_AD else 0 end) as BUY_THIS_MONTH,&#13;&#10;SUM(CASE when left(p.REQ_APP_DATE,6) &#60; :ymd0 then p.TOTAL_COST_AD else 0 end) as BUY_BF,     &#13;&#10;SUM(p.TOTAL_COST) as TOTAL_BUY_PO                    &#13;&#10;from MS_PO p (NOLOCK) &#13;&#10;where  dbo.ThaiFiscalYear(p.REQ_APP_DATE)=dbo.ThaiFiscalYear(:ymd2)  and left(p.REQ_APP_DATE,6) &#60;= :ymd0                        &#13;&#10;group by p.BUDGET_TYPE) as po&#13;&#10;on (po.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;where b.FISCAL_YEAR=dbo.ThaiFiscalYear(:ymd2 )&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;&#13;&#10;select t.BUDGET_NAME,b.BUDGET_AMOUNT,&#13;&#10;ifnull(po.BUY_BF,0) as BUY_BF,&#13;&#10;ifnull(po.BUY_THIS_MONTH,0) as BUY_THIS_MONTH,  &#13;&#10;ifnull(po.TOTAL_BUY_PO,0) as TOTAL_BUY,&#13;&#10;b.BUDGET_AMOUNT- ifnull(po.TOTAL_BUY_PO,0) as  REMAIN_BUDGET,&#13;&#10; ifnull(po.TOTAL_BUY_PO,0)*100/ifnull(b.BUDGET_AMOUNT,1) as PERCENT_OF_PO  ,&#13;&#10;  &#13;&#10;&#13;&#10;( select SUM(T.RM_COST) from (select (select c.REMAIN_COST from  CARD c       &#13;&#10;        where &#13;&#10;        left(ce2cymd(c.OPERATE_DATE),6)  &#60;=   :ymd0            &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1) as RM_COST&#13;&#10;from INV_MD i&#13;&#10;left join DEPT_ID d on i.DEPT_ID =d.DEPT_ID where d.DEPT_TYPE=2) as T ) as TOTAL_INV&#13;&#10;  &#13;&#10;from BDG_AMT b&#13;&#10;left join BDG_TYPE t on (t.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;  &#13;&#10;left join (select p.BUDGET_TYPE,&#13;&#10;SUM(CASE when left(p.REQ_APP_DATE,6) = :ymd0  then p.TOTAL_COST_AD else 0 end) as BUY_THIS_MONTH,&#13;&#10;SUM(CASE when left(p.REQ_APP_DATE,6) &#60; :ymd0 then p.TOTAL_COST_AD else 0 end) as BUY_BF,     &#13;&#10;SUM(p.TOTAL_COST) as TOTAL_BUY_PO                    &#13;&#10;from MS_PO p&#13;&#10;where  ThaiFiscalYear(p.REQ_APP_DATE)=ThaiFiscalYear(:ymd2)  and left(p.REQ_APP_DATE,6) &#60;= :ymd0                        &#13;&#10;group by p.BUDGET_TYPE) as po&#13;&#10;on (po.BUDGET_TYPE = b.BUDGET_TYPE)&#13;&#10;where b.FISCAL_YEAR=ThaiFiscalYear(:ymd2 )    &#13;&#10;&#13;&#10;&#13;&#10;{endif}      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_dept" UserName="dept" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=1                                                                                              " SpecificOptions.Text="" PropData="05704C65667403AC000470546F700384000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_datetime" UserName="qry_datetime" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;  &#13;&#10;select getDate() AS TODAY&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;select now()                         &#13;&#10;  &#13;&#10;{endif}      " SpecificOptions.Text="" PropData="05704C6566740384000470546F7002480A506172616D65746572730100"/>
  </TfrxDataPage>
