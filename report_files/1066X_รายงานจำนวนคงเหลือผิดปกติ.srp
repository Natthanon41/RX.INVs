  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp" UserName="rp" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;&#13;&#10;select i.WORKING_CODE,g.DRUG_NAME,i.QTY_ON_HAND as INVALL,c.QTY_ON_HAND as INVLOT&#13;&#10;from INV_MD i (NOLOCK) &#13;&#10;left join (&#13;&#10;select c.WORKING_CODE,SUM(QTY_ON_HAND) as QTY_ON_HAND from INV_MD_C c where &#13;&#10;c.DEPT_ID=:stock &#13;&#10;Group by c.WORKING_CODE&#13;&#10;) as c on (c.WORKING_CODE = i.WORKING_CODE)&#13;&#10;left join DRUG_GN g (NOLOCK) on (g.WORKING_CODE = i.WORKING_CODE)&#13;&#10;Where i.QTY_ON_HAND &#60;&#62; c.QTY_ON_HAND&#13;&#10;and i.DEPT_ID =:stock &#13;&#10;&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;&#13;&#10;select i.WORKING_CODE,g.DRUG_NAME,i.QTY_ON_HAND as INVALL,c.QTY_ON_HAND as INVLOT                   &#13;&#10;from INV_MD i&#13;&#10;left join (&#13;&#10;select c.WORKING_CODE,SUM(QTY_ON_HAND) as QTY_ON_HAND from INV_MD_C c where &#13;&#10;c.DEPT_ID=:stock &#13;&#10;Group by c.WORKING_CODE&#13;&#10;) as c on (c.WORKING_CODE = i.WORKING_CODE)&#13;&#10;left join DRUG_GN g on (g.WORKING_CODE = i.WORKING_CODE)&#13;&#10;Where i.QTY_ON_HAND &#60;&#62; c.QTY_ON_HAND&#13;&#10;and i.DEPT_ID =:stock &#13;&#10;    &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;{endif}      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where (HIDE='' or HIDE is null or HIDE='N')  " SpecificOptions.Text="" PropData="05704C65667402380470546F700384000A506172616D65746572730100"/>
