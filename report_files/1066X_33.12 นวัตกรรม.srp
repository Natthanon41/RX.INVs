<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.9008937037" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  date1.date:=strtodate('1/10/2010') ;&#13;&#10;  date2.date:=strtodate('30/9/2015') ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry1" DataSetName="qry1"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry1" UserName="qry1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER} &#13;&#10;&#13;&#10; IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[ThaiFiscalYear]') AND type in (N'FN', N'IF', N'TF', N'FS', N'FT'))&#13;&#10;    BEGIN&#13;&#10;    execute dbo.sp_executesql @statement = N'&#13;&#10;    &#13;&#10;        CREATE FUNCTION [dbo].[ThaiFiscalYear] (@date_cymd char(8))&#13;&#10;        RETURNS char(4) AS&#13;&#10;        BEGIN&#13;&#10;&#13;&#10;	   declare @result char(4)&#13;&#10;&#13;&#10;	   if substring(@date_cymd,5,2) &#60;= 09&#13;&#10;              set @result = convert(char(4),convert(int,substring(@date_cymd,1,4))+543)&#13;&#10;           else&#13;&#10;              set @result = convert(char(4),convert(int, substring(@date_cymd,1,4))+544)&#13;&#10;&#13;&#10;	Return @result&#13;&#10;&#13;&#10;        END&#13;&#10;    '&#13;&#10;    END&#13;&#10;select&#13;&#10;dbo.ThaiFiscalYear(c.R_S_DATE) as FISCAL_YEAR,&#13;&#10;g.DRUG_NAME,  &#13;&#10;v.TRADE_NAME,&#13;&#10;v.[24DIGIT],&#13;&#10;v.TMTID,&#13;&#10;s.SALE_UNIT,c.COST/c.ACTIVE_QTY as UNIT_COST,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.ACTIVE_QTY&#13;&#10;         when c.R_S_STATUS in ('B') then c.ACTIVE_QTY*-1 else NULL end    &#13;&#10;) as QTY_RCV,SUM(c.COST) as TOTAL_COST,b.BUDGET_NAME&#13;&#10;from CARD c (NOLOCK)&#13;&#10;left join DRUG_GN g (NOLOCK) on (g.WORKING_CODE=c.WORKING_CODE)&#13;&#10;left join DRUG_VN v (NOLOCK) on (v.TRADE_CODE=c.TRADE_CODE)&#13;&#10;left join SALE_UNIT s (NOLOCK) on (g.SALE_UNIT_ID =s.SU_ID)&#13;&#10;left join BDG_TYPE b (NOLOCK) on (b.BUDGET_TYPE=c.BDG_TYPE)&#13;&#10;where c.R_S_DATE between :date1  and :date2          &#13;&#10;and c.R_S_STATUS in ('R','I','G','A','B')&#13;&#10;and c.ACTIVE_QTY &#62; 0&#13;&#10;GROUP BY dbo.ThaiFiscalYear(c.R_S_DATE),&#13;&#10;g.DRUG_NAME,v.TRADE_NAME,v.[24DIGIT],v.TMTID,s.SALE_UNIT,c.COST/c.ACTIVE_QTY,b.BUDGET_NAME    &#13;&#10;&#13;&#10;{ELSE} &#13;&#10;&#13;&#10;select&#13;&#10;ThaiFiscalYear(c.R_S_DATE) as FISCAL_YEAR,&#13;&#10;g.DRUG_NAME,  &#13;&#10;v.TRADE_NAME,&#13;&#10;v.24DIGIT,&#13;&#10;v.TMTID,&#13;&#10;s.SALE_UNIT,c.COST/c.ACTIVE_QTY as UNIT_COST,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.ACTIVE_QTY&#13;&#10;         when c.R_S_STATUS in ('B') then c.ACTIVE_QTY*-1 else NULL end    &#13;&#10;) as QTY_RCV,SUM(c.COST) as TOTAL_COST,b.BUDGET_NAME&#13;&#10;from CARD c &#13;&#10;left join DRUG_GN g  on (g.WORKING_CODE=c.WORKING_CODE)&#13;&#10;left join DRUG_VN v  on (v.TRADE_CODE=c.TRADE_CODE)&#13;&#10;left join SALE_UNIT s  on (g.SALE_UNIT_ID =s.SU_ID)&#13;&#10;left join BDG_TYPE b  on (b.BUDGET_TYPE=c.BDG_TYPE)&#13;&#10;where c.R_S_DATE between :date1  and :date2          &#13;&#10;and c.R_S_STATUS in ('R','I','G','A','B')&#13;&#10;and c.ACTIVE_QTY &#62; 0&#13;&#10;GROUP BY ThaiFiscalYear(c.R_S_DATE),&#13;&#10;g.DRUG_NAME,v.TRADE_NAME,v.24DIGIT,v.TMTID,s.SALE_UNIT,c.COST/c.ACTIVE_QTY,b.BUDGET_NAME  &#13;&#10;&#13;&#10;{ENDIF}     &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
