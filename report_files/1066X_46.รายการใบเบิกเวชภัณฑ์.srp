<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="45237.6626756713" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  date1.date:=now ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="frxReport1OnReportPrint">
  <Datasets>
    <item DataSet="qry_rp" DataSetName="rp"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp" UserName="rp" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;  &#13;&#10;SELECT DISTINCT S.SUB_PO_NO,t.DIST_TYPE_NAME,D.DEPT_NAME,S.SUB_PO_DATE,S.TOTAL_ITEM,S.TOTAL_VALUE,SM.CONFIRM_FLAG,&#13;&#10;CASE When s.R_S_STATUS='R' then 'ขอเบิก'&#13;&#10;     When s.R_S_STATUS='T' then 'โอน'    &#13;&#10;ELSE ''&#13;&#10;END as DIST                                        &#13;&#10;FROM SM_PO(NOLOCK) S   &#13;&#10;left join DEPT_ID D(NOLOCK) on (S.DEPT_ID=D.DEPT_ID)&#13;&#10;left join SM_PO_C SM(NOLOCK) on (SM.SUB_PO_NO=S.SUB_PO_NO) &#13;&#10;LEFT JOIN  DIST_TYPE t (NOLOCK) on (t.DIST_TYPE_CODE = s.DIST_TYPE)                                                                                               &#13;&#10;WHERE S.STOCK_ID=:STOCK AND S.TOTAL_ITEM&#62;0 AND SM.CONFIRM_FLAG ='Y'                                                                                                                                           &#13;&#10;      AND S.SUB_PO_DATE BETWEEN :date1 AND :date2&#13;&#10;      AND s.R_S_STATUS in ('T','R')                                                                                                            &#13;&#10;order by S.DEPT_ID,S.SUB_PO_DATE&#13;&#10;&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;&#13;&#10;SELECT DISTINCT S.SUB_PO_NO,t.DIST_TYPE_NAME,D.DEPT_NAME,S.SUB_PO_DATE,S.TOTAL_ITEM,S.TOTAL_VALUE,SM.CONFIRM_FLAG,  &#13;&#10;CASE When s.R_S_STATUS='R' then 'ขอเบิก'&#13;&#10;     When s.R_S_STATUS='T' then 'โอน'    &#13;&#10;ELSE ''&#13;&#10;END as DIST  &#13;&#10;FROM SM_PO S&#13;&#10;left join DEPT_ID D on (S.DEPT_ID=D.DEPT_ID)&#13;&#10;left join SM_PO_C SM on (SM.SUB_PO_NO=S.SUB_PO_NO) &#13;&#10;LEFT JOIN  DIST_TYPE t on (t.DIST_TYPE_CODE = s.DIST_TYPE)                                                                                               &#13;&#10;WHERE S.STOCK_ID=:STOCK AND S.TOTAL_ITEM&#62;0 AND SM.CONFIRM_FLAG ='Y'                                                                                                                                           &#13;&#10;      AND S.SUB_PO_DATE BETWEEN :date1 AND :date2&#13;&#10;      AND s.R_S_STATUS in ('T','R')          &#13;&#10;order by S.DEPT_ID, S.SUB_PO_DATE    &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;{endif}      &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select CONCAT(DEPT_ID,' ',DEPT_NAME) as ITEM_NAME, DEPT_ID,DEPT_NAME                      &#13;&#10; from DEPT_ID where HIDE='' or HIDE is null or HIDE='N'&#13;&#10; ORDER BY DEPT_ID                                       &#13;&#10;&#13;&#10;                " SpecificOptions.Text="" PropData="05704C65667402580470546F7003A0000A506172616D65746572730100"/>
  </TfrxDataPage>
