<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" EngineOptions.SilentMode="True" EngineOptions.NewSilentMode="simSilent" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="45239.570642662" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; input_year : integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  monthx.text:= formatdatetime('mm',now-29) ;&#13;&#10;  yearx.text:=  inttostr(strtoint(formatdatetime('YYYY',now-30))+543) ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  date1.date:=now-30 ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure monthxOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;    input_year:= strtoint(yearx.text)-543 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="frxReport1OnReportPrint">
  <Datasets>
    <item DataSet="qry_smpo" DataSetName="rp1"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
    <item DataSet="qry_sumvalue" DataSetName="sumvalue"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_smpo" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;SELECT c.WORKING_CODE, g.DRUG_NAME, IS_ED(g.IS_ED) AS ISED, s.SALE_UNIT, SUM(c.QTY_RCV) AS qty, SUM(c.VALUE) AS valuex&#13;&#10;FROM sm_po_c c&#13;&#10;LEFT JOIN sm_po o ON o.SUB_PO_NO = c.SUB_PO_NO&#13;&#10;LEFT JOIN drug_gn g ON g.WORKING_CODE = c.WORKING_CODE&#13;&#10;LEFT JOIN sale_unit s ON s.SU_ID = g.SALE_UNIT_ID&#13;&#10;WHERE c.CONFIRM_DATE BETWEEN :date1 and :date2&#13;&#10;AND o.STOCK_ID =:stock_id&#13;&#10;AND c.CANCEL_DISP IS NULL     &#13;&#10;GROUP BY c.WORKING_CODE, g.DRUG_NAME, IS_ED(g.IS_ED), s.SALE_UNIT&#13;&#10;&#13;&#10;ORDER BY SUM(c.VALUE) DESC&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;SELECT c.WORKING_CODE, g.DRUG_NAME, IS_ED(g.IS_ED) AS ISED, s.SALE_UNIT, SUM(c.QTY_RCV) AS qty, SUM(c.VALUE) AS valuex&#13;&#10;FROM sm_po_c c&#13;&#10;LEFT JOIN sm_po o ON o.SUB_PO_NO = c.SUB_PO_NO&#13;&#10;LEFT JOIN drug_gn g ON g.WORKING_CODE = c.WORKING_CODE&#13;&#10;LEFT JOIN sale_unit s ON s.SU_ID = g.SALE_UNIT_ID&#13;&#10;WHERE c.CONFIRM_DATE BETWEEN :date1 and :date2&#13;&#10;AND o.STOCK_ID =:stock_id&#13;&#10;AND c.CANCEL_DISP IS NULL     &#13;&#10;GROUP BY c.WORKING_CODE, g.DRUG_NAME, IS_ED(g.IS_ED), s.SALE_UNIT&#13;&#10;&#13;&#10;ORDER BY SUM(c.VALUE) DESC    &#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                                                        &#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME&#13;&#10;&#13;&#10; {ELSE}&#13;&#10;&#13;&#10; select * from DEPT_ID  where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME&#13;&#10;&#13;&#10; {ENDIF}                 " SpecificOptions.Text="" PropData="05704C65667402580470546F7002700A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_sumvalue" UserName="sumvalue" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;SELECT SUM(c.VALUE) AS valuex&#13;&#10;FROM sm_po_c c&#13;&#10;LEFT JOIN sm_po o ON o.SUB_PO_NO = c.SUB_PO_NO&#13;&#10;&#13;&#10;WHERE c.CONFIRM_DATE BETWEEN :date1 and :date2&#13;&#10;AND o.STOCK_ID =:stock_id&#13;&#10;&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;SELECT SUM(c.VALUE) AS valuex&#13;&#10;FROM sm_po_c c&#13;&#10;LEFT JOIN sm_po o ON o.SUB_PO_NO = c.SUB_PO_NO&#13;&#10;&#13;&#10;WHERE c.CONFIRM_DATE BETWEEN :date1 and :date2&#13;&#10;AND o.STOCK_ID =:stock_id    &#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
