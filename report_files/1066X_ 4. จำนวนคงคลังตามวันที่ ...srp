<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43172.6151642245" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; MOD_QTY: STRING  ;&#13;&#10;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;procedure Memo8OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   if &#60;sum_inv.&#34;MOD_ONHAND&#34;&#62; &#62; '0' then  MOD_QTY:='(+'+inttostr(&#60;sum_inv.&#34;MOD_ONHAND&#34;&#62;)+')' else MOD_QTY:='' ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_sum_inv" DataSetName="sum_inv"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
    <item Name="hosp_name"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                             &#13;&#10;select T.GROUP_CODE,T.ED_NAME_GROUP,T.DRUG_NAME,T.WORKING_CODE,T.RM_QTY,T.PACK_RATIO,&#13;&#10;convert(int,T.RM_QTY)%convert(int,ISNULL(T.PACK_RATIO,1)) as MOD_ONHAND,&#13;&#10;floor(T.RM_QTY/isnull(T.PACK_RATIO,1)) as RM_PACK                                  &#13;&#10;from&#13;&#10;(    &#13;&#10;select g.GROUP_CODE,e.NAME as ED_NAME_GROUP,i.WORKING_CODE,g.DRUG_NAME,ISNULL(i.LAST_PACK_RATIO,i.FIRST_PACK_RATIO) as PACK_RATIO,                                    &#13;&#10;isnull((select top 1 c.REMAIN_QTY from  CARD c (NOLOCK)&#13;&#10;        where &#13;&#10;        c.R_S_DATE  &#60;=  :date1                                                 &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ),0) as RM_QTY,i.QTY_ON_HAND,&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        c.R_S_DATE  &#60;=  :date1             &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as RM_VALUE            &#13;&#10;from INV_MD  i (NOLOCK)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join ED_GROUP e (NOLOCK) on (g.GROUP_CODE = e.CODE)&#13;&#10;where g.HIDE='N'&#13;&#10;and i.DEPT_ID=:dept_id                                              &#13;&#10;) as T&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;select T.GROUP_CODE,T.ED_NAME_GROUP,T.DRUG_NAME,T.WORKING_CODE,T.RM_QTY,T.PACK_RATIO,&#13;&#10;convert(T.RM_QTY,int)%convert(IFNULL(T.PACK_RATIO,1),int) as MOD_ONHAND,&#13;&#10;floor(T.RM_QTY/IFNULL(T.PACK_RATIO,1)) as RM_PACK                                  &#13;&#10;from&#13;&#10;(    &#13;&#10;select g.GROUP_CODE,e.NAME as ED_NAME_GROUP,i.WORKING_CODE,g.DRUG_NAME,IFNULL(i.LAST_PACK_RATIO,i.FIRST_PACK_RATIO) as PACK_RATIO,                                    &#13;&#10;IFNULL((select   c.REMAIN_QTY from  CARD c &#13;&#10;        where &#13;&#10;        c.R_S_DATE  &#60;=  :date1                                                 &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1 ),0) as RM_QTY,i.QTY_ON_HAND,&#13;&#10;(select   c.REMAIN_VALUE from  CARD c        &#13;&#10;        where &#13;&#10;        c.R_S_DATE  &#60;=  :date1             &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1 ) as RM_VALUE            &#13;&#10;from INV_MD  i      &#13;&#10;left join DRUG_GN g  on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join ED_GROUP e  on (g.GROUP_CODE = e.CODE)&#13;&#10;where g.HIDE='N'&#13;&#10;and i.DEPT_ID=:dept_id                                              &#13;&#10;) as T&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                             &#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE=''&#13;&#10;or HIDE is null&#13;&#10;or HIDE='N'            &#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select * from DEPT_ID  where HIDE=''&#13;&#10;or HIDE is null&#13;&#10;or HIDE='N'            &#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData="05704C65667402480470546F7002780A506172616D65746572730100"/>
  </TfrxDataPage>
