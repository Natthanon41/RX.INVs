<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.0840935532" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  date1.date:=now ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:=&#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp" DataSetName="rp"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
    <item DataSet="qry_uprc" DataSetName="uprc"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp" UserName="rp" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;&#13;&#10;select g.DRUG_NAME,s.SUB_COMMIT_DES,e.NAME as ED_NAME,h.HOSP_LIST_DESC,g.SALE_UNIT,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.ACTIVE_QTY&#13;&#10;         when c.R_S_STATUS in ('B') then c.ACTIVE_QTY*-1 else NULL end) as R_QTY,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.[VALUE]             &#13;&#10;         when c.R_S_STATUS in ('B') then  c.[VALUE]*-1 else NULL end) as R_AMT,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('T','S')then c.ACTIVE_QTY &#13;&#10;         when c.R_S_STATUS='C' then c.ACTIVE_QTY*-1&#13;&#10;         else NULL end) as S_QTY,    &#13;&#10;SUM(CASE when c.R_S_STATUS in ('T','S')  then  c.[VALUE] &#13;&#10;         when (c.R_S_STATUS='C') then  c.[VALUE]*-1 else NULL end) as S_AMT  ,&#13;&#10;(select top 1 x.UNIT_PRICE from DRUG_VN x where x.WORKING_CODE=c.WORKING_CODE order by x.LAST_BUY DESC) as UPRC,&#13;&#10;(select top 1 z.BUY_UNIT_COST  from PACK_RATIO  z where z.WORKING_CODE=c.WORKING_CODE order by  z.LAST_BUY DESC) as UPRC2                            &#13;&#10;from CARD c (NOLOCK)&#13;&#10;left join DRUG_VN v (NOLOCK) on (c.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join ED_GROUP e (NOLOCK) on (g.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s (NOLOCK) on (e.SUB_COMMIT_CODE=s.SUB_COMMIT_CODE)&#13;&#10;left join HOSP_LIST h (NOLOCK) on (v.HOSP_LIST=h.HOSP_LIST_CODE)                                                                                                                                &#13;&#10;where c.STOCK_ID=:stock&#13;&#10;and c.R_S_DATE between :date1 and :date2        &#13;&#10;group by g.DRUG_NAME,s.SUB_COMMIT_DES,e.NAME,h.HOSP_LIST_DESC,g.SALE_UNIT,c.WORKING_CODE                             &#13;&#10;order by g.DRUG_NAME              &#13;&#10;&#13;&#10;{ELSE}&#13;&#10;   &#13;&#10;select g.DRUG_NAME,s.SUB_COMMIT_DES,e.NAME as ED_NAME,h.HOSP_LIST_DESC,g.SALE_UNIT,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.ACTIVE_QTY&#13;&#10;         when c.R_S_STATUS in ('B') then c.ACTIVE_QTY*-1 else NULL end) as R_QTY,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('R','I','G','A') then c.VALUE             &#13;&#10;         when c.R_S_STATUS in ('B') then  c.VALUE*-1 else NULL end) as R_AMT,&#13;&#10;SUM(CASE when c.R_S_STATUS in ('T','S')then c.ACTIVE_QTY &#13;&#10;         when c.R_S_STATUS='C' then c.ACTIVE_QTY*-1&#13;&#10;         else NULL end) as S_QTY,    &#13;&#10;SUM(CASE when c.R_S_STATUS in ('T','S')  then  c.VALUE &#13;&#10;         when (c.R_S_STATUS='C') then  c.VALUE * -1 else NULL end) as S_AMT  ,&#13;&#10;(select top 1 x.UNIT_PRICE from DRUG_VN x where x.WORKING_CODE=c.WORKING_CODE order by x.LAST_BUY DESC) as UPRC,&#13;&#10;(select top 1 z.BUY_UNIT_COST  from PACK_RATIO  z where z.WORKING_CODE=c.WORKING_CODE order by  z.LAST_BUY DESC) as UPRC2                            &#13;&#10;from CARD c &#13;&#10;left join DRUG_VN v  on (c.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join DRUG_GN g  on (c.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join ED_GROUP e  on (g.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s  on (e.SUB_COMMIT_CODE=s.SUB_COMMIT_CODE)&#13;&#10;left join HOSP_LIST h  on (v.HOSP_LIST=h.HOSP_LIST_CODE)                                                                                                                                &#13;&#10;where c.STOCK_ID=:stock&#13;&#10;and c.R_S_DATE between :date1 and :date2        &#13;&#10;group by g.DRUG_NAME,s.SUB_COMMIT_DES,e.NAME,h.HOSP_LIST_DESC,g.SALE_UNIT,c.WORKING_CODE                             &#13;&#10;order by g.DRUG_NAME  &#13;&#10;&#13;&#10;&#13;&#10;{ENDIF}    &#13;&#10;&#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;&#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10; and INV_TYPE='99'&#13;&#10;  &#13;&#10; {ELSE}&#13;&#10;&#13;&#10;&#13;&#10;select * from DEPT_ID  where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10; and INV_TYPE='99'  &#13;&#10;&#13;&#10; {ENDIF}    &#13;&#10;&#13;&#10;  " SpecificOptions.Text="" PropData="05704C656674025A0470546F7002770A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_uprc" UserName="uprc" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="" SpecificOptions.Text="" PropData="05704C65667402580470546F7003BC000A506172616D65746572730100"/>
  </TfrxDataPage>
