<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.8906351736" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; input_year : integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  monthx.text:= formatdatetime('mm',now-29) ;&#13;&#10;  yearx.text:=  inttostr(strtoint(formatdatetime('YYYY',now-30))+543) ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  date1.date:=now-30 ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure monthxOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;    input_year:= strtoint(yearx.text)-543 ;&#13;&#10;{&#13;&#10;&#13;&#10;    qry_EMS_RE_M.close ;&#13;&#10;    qry_EMS_RE_M.sql[0]:=' select top ' + N_ITEMS.text ;&#13;&#10;    qry_EMS_RE_M.open ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;    qry_BMS_RE_M2.close ;&#13;&#10;    qry_BMS_RE_M2.sql[0]:=' select top '+N_ITEMS.text ;&#13;&#10;    qry_BMS_RE_M2.open ;&#13;&#10;&#13;&#10;}&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_EMS_RE_M" DataSetName="BMS_RE_M"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
    <item DataSet="qry_BMS_RE_M2" DataSetName="BMS_RE_M2"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_EMS_RE_M" UserName="BMS_RE_M" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER} &#13;&#10;&#13;&#10; select top 50&#13;&#10;  T.* from (&#13;&#10;select c1.WORKING_CODE, d.DRUG_NAME,dbo.IS_ED(d.IS_ED) as ED,h.HOSP_LIST_DESC,s.SUB_COMMIT_DES,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.ACTIVE_QTY &#13;&#10;         when c1.R_S_STATUS in ('B') then c1.ACTIVE_QTY*-1 else NULL end&#13;&#10;) as qty_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.[VALUE] &#13;&#10;         when c1.R_S_STATUS in ('B') then c1.[VALUE]*-1 else NULL end&#13;&#10;) as val_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.ACTIVE_QTY &#13;&#10;when (c1.R_S_STATUS='C') then c1.ACTIVE_QTY*-1 else NULL end) as qty_s,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.[VALUE] &#13;&#10;when (c1.R_S_STATUS='C') then c1.[VALUE]*-1 else NULL end) as val_s&#13;&#10;from CARD c1  (NOLOCK)   &#13;&#10;left join DRUG_GN d (NOLOCK) on (c1.WORKING_CODE = d.WORKING_CODE)&#13;&#10;left join DRUG_VN v (NOLOCK) on (c1.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join ED_GROUP e (NOLOCK) on (d.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s (NOLOCK) on (e.SUB_COMMIT_CODE=s.SUB_COMMIT_CODE)&#13;&#10;left join HOSP_LIST h (NOLOCK) on (v.HOSP_LIST=h.HOSP_LIST_CODE)   &#13;&#10;where  c1.STOCK_ID=:stock_id&#13;&#10;and c1.R_S_DATE between :date1 and :date2                                                            &#13;&#10;group by c1.WORKING_CODE,d.DRUG_NAME,dbo.IS_ED(d.IS_ED),h.HOSP_LIST_DESC,s.SUB_COMMIT_DES    &#13;&#10; ) as T&#13;&#10; order by T.val_r DESC  &#13;&#10;   &#13;&#10;{ELSE} &#13;&#10;&#13;&#10; select&#13;&#10;  T.* from (&#13;&#10;select c1.WORKING_CODE, d.DRUG_NAME,IS_ED(d.IS_ED) as ED,h.HOSP_LIST_DESC,s.SUB_COMMIT_DES,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.ACTIVE_QTY &#13;&#10;         when c1.R_S_STATUS in ('B') then c1.ACTIVE_QTY*-1 else NULL end&#13;&#10;) as qty_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.VALUE &#13;&#10;         when c1.R_S_STATUS in ('B') then c1.VALUE*-1 else NULL end&#13;&#10;) as val_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.ACTIVE_QTY &#13;&#10;when (c1.R_S_STATUS='C') then c1.ACTIVE_QTY*-1 else NULL end) as qty_s,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.VALUE   &#13;&#10;when (c1.R_S_STATUS='C') then c1.VALUE*-1 else NULL end) as val_s&#13;&#10;from CARD c1     &#13;&#10;left join DRUG_GN d  on (c1.WORKING_CODE = d.WORKING_CODE)&#13;&#10;left join DRUG_VN v  on (c1.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join ED_GROUP e  on (d.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s  on (e.SUB_COMMIT_CODE=s.SUB_COMMIT_CODE)&#13;&#10;left join HOSP_LIST h  on (v.HOSP_LIST=h.HOSP_LIST_CODE)   &#13;&#10;where  c1.STOCK_ID=:stock_id&#13;&#10;and c1.R_S_DATE between :date1 and :date2                                                            &#13;&#10;group by c1.WORKING_CODE,d.DRUG_NAME,IS_ED(d.IS_ED),h.HOSP_LIST_DESC,s.SUB_COMMIT_DES    &#13;&#10; ) as T&#13;&#10; order by T.val_r DESC   limit 50  &#13;&#10;&#13;&#10;{ENDIF}&#13;&#10;&#13;&#10;                                    " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}  &#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME  &#13;&#10;{ELSE}            &#13;&#10; select * from DEPT_ID  where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME  &#13;&#10;{ENDIF}     " SpecificOptions.Text="" PropData="05704C65667402580470546F7002700A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_BMS_RE_M2" UserName="BMS_RE_M2" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER} &#13;&#10;select top 50&#13;&#10;   T.* from (&#13;&#10;select c1.WORKING_CODE, d.DRUG_NAME,dbo.IS_ED(d.IS_ED) as ED,h.HOSP_LIST_DESC,s.SUB_COMMIT_DES,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.ACTIVE_QTY &#13;&#10;         when c1.R_S_STATUS in ('B') then c1.ACTIVE_QTY*-1 else NULL end&#13;&#10;) as qty_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.[VALUE] &#13;&#10;         when c1.R_S_STATUS in ('B') then c1.[VALUE]*-1 else NULL end&#13;&#10;) as val_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.ACTIVE_QTY &#13;&#10;when (c1.R_S_STATUS='C') then c1.ACTIVE_QTY*-1 else NULL end) as qty_s,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.[VALUE] &#13;&#10;when (c1.R_S_STATUS='C') then c1.[VALUE]*-1 else NULL end) as val_s&#13;&#10;from CARD c1  (NOLOCK)   &#13;&#10;left join DRUG_GN d (NOLOCK) on (c1.WORKING_CODE = d.WORKING_CODE)&#13;&#10;left join DRUG_VN v (NOLOCK) on (c1.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join ED_GROUP e (NOLOCK) on (d.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s (NOLOCK) on (e.SUB_COMMIT_CODE=s.SUB_COMMIT_CODE)&#13;&#10;left join HOSP_LIST h (NOLOCK) on (v.HOSP_LIST=h.HOSP_LIST_CODE)   &#13;&#10;where  c1.STOCK_ID=:stock_id                         &#13;&#10;and c1.R_S_DATE between :date1 and :date2     &#13;&#10;group by c1.WORKING_CODE,d.DRUG_NAME,dbo.IS_ED(d.IS_ED),h.HOSP_LIST_DESC,s.SUB_COMMIT_DES    &#13;&#10; ) as T&#13;&#10; order by T.val_s DESC    &#13;&#10;{ELSE}          &#13;&#10;select&#13;&#10;   T.* from (&#13;&#10;select c1.WORKING_CODE, d.DRUG_NAME,IS_ED(d.IS_ED) as ED,h.HOSP_LIST_DESC,s.SUB_COMMIT_DES,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.ACTIVE_QTY &#13;&#10;         when c1.R_S_STATUS in ('B') then c1.ACTIVE_QTY*-1 else NULL end&#13;&#10;) as qty_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.[VALUE] &#13;&#10;         when c1.R_S_STATUS in ('B') then c1.VALUE*-1 else NULL end&#13;&#10;) as val_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.ACTIVE_QTY &#13;&#10;when (c1.R_S_STATUS='C') then c1.ACTIVE_QTY*-1 else NULL end) as qty_s,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.VALUE&#13;&#10;when (c1.R_S_STATUS='C') then c1.VALUE*-1 else NULL end) as val_s&#13;&#10;from CARD c1     &#13;&#10;left join DRUG_GN d  on (c1.WORKING_CODE = d.WORKING_CODE)&#13;&#10;left join DRUG_VN v  on (c1.TRADE_CODE=v.TRADE_CODE)&#13;&#10;left join ED_GROUP e  on (d.GROUP_CODE=e.CODE)&#13;&#10;left join SUB_COM s  on (e.SUB_COMMIT_CODE=s.SUB_COMMIT_CODE)&#13;&#10;left join HOSP_LIST h  on (v.HOSP_LIST=h.HOSP_LIST_CODE)   &#13;&#10;where  c1.STOCK_ID=:stock_id                         &#13;&#10;and c1.R_S_DATE between :date1 and :date2     &#13;&#10;group by c1.WORKING_CODE,d.DRUG_NAME,IS_ED(d.IS_ED),h.HOSP_LIST_DESC,s.SUB_COMMIT_DES    &#13;&#10; ) as T&#13;&#10; order by T.val_s DESC    limit 50                   &#13;&#10;{ENDIF}     &#13;&#10;&#13;&#10;&#13;&#10;  " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
