<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" EngineOptions.SilentMode="True" EngineOptions.NewSilentMode="simSilent" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="45240.5675810185" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; ymd_fw,ymd1,ymd2 ,: string ;&#13;&#10;  Line_no: integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  IF StrToInt(FormatDateTime('MM',NOW))  &#62; 9 THEN&#13;&#10;    y1.Text:=IntToStr(StrToInt(FormatDateTime('YYYY',NOW))+1+543)&#13;&#10;  ELSE&#13;&#10;    y1.Text:=IntToStr(StrToInt(FormatDateTime('YYYY',NOW))+543)   ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  ymd_fw:= inttostr(strtoint(y1.text) - 1 - 543) + '-09-30' ;&#13;&#10;&#13;&#10;  ymd1:=inttostr(strtoint(y1.text) -1 - 543)+'-10-01' ;&#13;&#10;  ymd2:=inttostr(strtoint(y1.text) - 543)+'-09-30' ;&#13;&#10;&#13;&#10;&#13;&#10; end ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure Memo23OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    Line_no:=Line_no+1 ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo22OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   Line_no:=Line_no+1 ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;{&#13;&#10;  if (&#60;qry_sum_inv.&#34;FW_VALUE&#34;&#62; &#60;0.1) and (&#60;qry_sum_inv.&#34;RCV_VALUE&#34;&#62;&#60;0.1) and (&#60;qry_sum_inv.&#34;DIS_VALUE&#34;&#62;&#60;0.1) and (&#60;qry_sum_inv.&#34;RM_VALUE&#34;&#62;&#60;0.1)&#13;&#10;  then   MasterData1.visible:=False else  MasterData1.visible:=True ;&#13;&#10;  }&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_sum_inv" DataSetName="qry_sum_inv"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
    <item DataSet="UniDACQuery1" DataSetName="UniDACQuery1"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="qry_sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;    &#13;&#10;  &#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM from (    &#13;&#10;select NLEM(g.IS_ED) as NLEM,g.IS_ED,                                                &#13;&#10;&#13;&#10;(select  c.REMAIN_VALUE from  CARD c           &#13;&#10;        where &#13;&#10;         c.OPERATE_DATE &#60;= :ymd_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  limit 1) as FW_VALUE,&#13;&#10;          &#13;&#10;IFNULL(Cx.RCV_VALUE,0) AS RCV_VALUE,IFNULL(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select  c.REMAIN_VALUE from  CARD c         &#13;&#10;        where &#13;&#10;        c.OPERATE_DATE &#60;= :ymd_rm              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0          &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  limit 1 ) as RM_VALUE            &#13;&#10;from INV_MD  i       &#13;&#10;left join DRUG_GN g   on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;         SUM(CASE when c1.R_S_STATUS in ('R','A','N','I','G') then c1.VALUE         &#13;&#10;         when c1.R_S_STATUS in ('M','E','B','B') then c1.VALUE*-1 else NULL end) as RCV_VALUE,             &#13;&#10;         						SUM(CASE when c1.R_S_STATUS in ('T','S','P','D','O')   then c1.VALUE&#13;&#10;when c1.R_S_STATUS in ('C','Z','U') then c1.VALUE*-1 else NULL end) as DIS_VALUE    &#13;&#10;   						from CARD c1     &#13;&#10;            where  c1.STOCK_ID=:dept                          &#13;&#10;            and   c1.OPERATE_DATE between   :ymd1 and  :ymd2    &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:dept and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;group by T.NLEM ,T.IS_ED       &#13;&#10;HAVING (SUM(IFNULL(T.FW_VALUE,0))+ SUM(IFNULL(RCV_VALUE,0))+ SUM(IFNULL(T.DIS_VALUE,0))+SUM(IFNULL(RM_VALUE,0)) &#62; 0 )&#13;&#10;order by  T.IS_ED    &#13;&#10;  &#13;&#10;&#13;&#10;{ENDIF}    &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="&#13;&#10;{IF SQLSERVER}&#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE='' or HIDE is null or HIDE='N'  &#13;&#10;&#13;&#10; {ELSE}&#13;&#10;&#13;&#10;&#13;&#10;select * from DEPT_ID  where HIDE='' or HIDE is null or HIDE='N'  &#13;&#10;&#13;&#10; {ENDIF}&#13;&#10;   " SpecificOptions.Text="" PropData="05704C65667402640470546F7003EC000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="UniDACQuery1" UserName="UniDACQuery1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="/*        &#13;&#10;SELECT T.NLEM,SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE&#13;&#10;from (  &#13;&#10;select i.WORKING_CODE,dbo.IS_ED(g.IS_ED) as NLEM,&#13;&#10;&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) &#60;= :ym_fw                         &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.RECORD_NUMBER DESC ) as FW_VALUE,&#13;&#10;          &#13;&#10;(select sum(c.[VALUE]) from MS_IVO_C c&#13;&#10;    left join MS_IVO s on (c.RECEIVE_NO=s.RECEIVE_NO)&#13;&#10;    where c.WORKING_CODE=i.WORKING_CODE &#13;&#10;    and s.DEPT_ID=i.DEPT_ID &#13;&#10;    and c.RCV_FLAG='Y' and c.REV_FLAG='N'&#13;&#10;    and left(s.RECEIVE_DATE,6)=:ym1 ) as RCV_VALUE ,&#13;&#10;      &#13;&#10;(select sum(c.[VALUE]) from SM_PO_C c&#13;&#10;    left join SM_PO s on (c.SUB_PO_NO=s.SUB_PO_NO)&#13;&#10;    where c.WORKING_CODE=i.WORKING_CODE &#13;&#10;    and s.STOCK_ID=i.DEPT_ID &#13;&#10;    and c.CONFIRM_FLAG='Y'&#13;&#10;    and (c.CANCEL_DISP=''  or c.CANCEL_DISP is null)&#13;&#10;    and left(s.SUB_PO_DATE,6)=:ym2 ) as DIS_VALUE ,&#13;&#10;      &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) &#60;= :ym3              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.RECORD_NUMBER DESC ) as RM_VALUE,i.TOTAL_VALUE&#13;&#10;          &#13;&#10;from INV_MD i&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;where i.DEPT_ID=:dept  and   g.WORKING_CODE is not null                                                  &#13;&#10;)  as T&#13;&#10;group by T.NLEM&#13;&#10;&#13;&#10;*/        " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
