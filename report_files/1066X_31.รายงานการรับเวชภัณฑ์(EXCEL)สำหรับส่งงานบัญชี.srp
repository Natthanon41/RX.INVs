<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="42119.8655733102" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.894783669" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  date1.date:=now  ;&#13;&#10;  date2.date:=now  ;&#13;&#10;&#13;&#10;  qry_dept.close ;&#13;&#10;  qry_dept.open ;&#13;&#10;&#13;&#10;  cbb_dept.keyvalue:=&#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="rp1"/>
    <item DataSet="qry_dept" DataSetName="dept"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER} &#13;&#10;&#13;&#10;select m.DEPT_ID,m.INVOICE_NO,m.RECEIVE_NO,m.PO_NO,&#13;&#10;substring(m.RECEIVE_DATE,1,4)+'-'+substring(m.RECEIVE_DATE,5,2)+'-'+substring(m.RECEIVE_DATE,7,2) as RCVDATE&#13;&#10;,v.COMPANY_NAME as VENDOR_NAME,c.QTY_ORDER,c.QTY_RCV,&#13;&#10;c.COST,c.PACK_RATIO,s1.SALE_UNIT as SUBPACKUNIT,&#13;&#10;s2.SALE_UNIT as PACKUNIT,dbo.IS_ED(g.IS_ED) as ED_FLAG,&#13;&#10;CASE when c.FREE_FLAG='N' then c.[VALUE] else 0 end as VALUE_PO,&#13;&#10;CASE when c.FREE_FLAG&#60;&#62;'N' then c.[VALUE] else 0 end as VALUE_FREE,&#13;&#10;c.BUY_UNIT_COST,c.WORKING_CODE,g.DRUG_NAME&#13;&#10;from MS_IVO m (NOLOCK)&#13;&#10;left join MS_IVO_C c (NOLOCK) on (c.RECEIVE_NO=m.RECEIVE_NO and c.REV_FLAG='N')                                                                                                            &#13;&#10;left join COMPANY v (NOLOCK) on (v.COMPANY_CODE=m.VENDOR_CODE)   &#13;&#10;left JOIN PACK_RATIO p on (p.PACK_CODE=c.PACK_CODE)&#13;&#10;left join SALE_UNIT s1 (NOLOCK) on (s1.SU_ID=p.SUBPACK_UNIT)     &#13;&#10;left join SALE_UNIT s2 (NOLOCK) on (s2.SU_ID=p.PACK_UNIT)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE = g.WORKING_CODE)                                                                                                                              &#13;&#10;where m.RECEIVE_DATE between :date1 and :date2  and m.DEPT_ID=:stockid&#13;&#10;and c.REV_FLAG='N'&#13;&#10;order by m.RECEIVE_DATE  &#13;&#10;  &#13;&#10;{ELSE} &#13;&#10;&#13;&#10;select m.DEPT_ID,m.INVOICE_NO,m.RECEIVE_NO,m.PO_NO,  &#13;&#10;concat(substring(m.RECEIVE_DATE,1,4),'-',substring(m.RECEIVE_DATE,5,2),'-',substring(m.RECEIVE_DATE,7,2))   as RCVDATE                                &#13;&#10;,v.COMPANY_NAME as VENDOR_NAME,c.QTY_ORDER,c.QTY_RCV,&#13;&#10;c.COST,c.PACK_RATIO,s1.SALE_UNIT as SUBPACKUNIT,&#13;&#10;s2.SALE_UNIT as PACKUNIT,IS_ED(g.IS_ED) as ED_FLAG,&#13;&#10;CASE when c.FREE_FLAG='N' then c.VALUE else 0 end as VALUE_PO,&#13;&#10;CASE when c.FREE_FLAG&#60;&#62;'N' then c.VALUE else 0 end as VALUE_FREE,&#13;&#10;c.BUY_UNIT_COST,c.WORKING_CODE,g.DRUG_NAME&#13;&#10;from MS_IVO m &#13;&#10;left join MS_IVO_C c  on (c.RECEIVE_NO=m.RECEIVE_NO and c.REV_FLAG='N')                                                                                                            &#13;&#10;left join COMPANY v  on (v.COMPANY_CODE=m.VENDOR_CODE)   &#13;&#10;left JOIN PACK_RATIO p on (p.PACK_CODE=c.PACK_CODE)&#13;&#10;left join SALE_UNIT s1  on (s1.SU_ID=p.SUBPACK_UNIT)     &#13;&#10;left join SALE_UNIT s2  on (s2.SU_ID=p.PACK_UNIT)     &#13;&#10;left join DRUG_GN g  on (c.WORKING_CODE = g.WORKING_CODE)                                                                                                                              &#13;&#10;where m.RECEIVE_DATE between :date1 and :date2  and m.DEPT_ID=:stockid&#13;&#10;and c.REV_FLAG='N'&#13;&#10;order by m.RECEIVE_DATE  &#13;&#10;&#13;&#10;{ENDIF}     &#13;&#10;&#13;&#10;&#13;&#10;                                                                                                                                          &#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_dept" UserName="dept" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="&#13;&#10;{IF SQLSERVER} &#13;&#10;&#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=2     &#13;&#10;&#13;&#10;{ELSE} &#13;&#10;&#13;&#10;select * from DEPT_ID  where (HIDE is null or HIDE='' or HIDE='N') and DEPT_TYPE=2  &#13;&#10;&#13;&#10;{ENDIF}     " SpecificOptions.Text="" PropData="05704C656674034C010470546F700308010A506172616D65746572730100"/>
  </TfrxDataPage>
