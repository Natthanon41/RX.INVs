    <TfrxUniDACQuery Name="qry_drug_gn" UserName="drug_gn" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select * from DRUG_GN (NOLOCK) where ( dbo.IS_ED(IS_ED) ='' or  IS_ED =''  or IS_ED is null  )&#13;&#10;and (HIDE='N' or HIDE='' or HIDE is null )   and MOD_SYS = (select MOD_SYS from DEPT_ID (NOLOCK) &#13;&#10;Where DEPT_ID=:dept_id )&#13;&#10;and WORKING_CODE is not null and WORKING_CODE&#60;&#62;''        &#13;&#10;&#13;&#10;{ELSE}&#13;&#10;  &#13;&#10;select * from DRUG_GN  where ( IS_ED(IS_ED) ='' or  IS_ED =''  or IS_ED is null or IS_ED(IS_ED) is null&#13;&#10;or NLEM(IS_ED)='' )&#13;&#10;and (HIDE='N' or HIDE='' or HIDE is null )   &#13;&#10;and MOD_SYS = (select MOD_SYS from DEPT_ID  Where dept_id=:dept_id )&#13;&#10;and WORKING_CODE is not null and WORKING_CODE&#60;&#62;''        &#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
