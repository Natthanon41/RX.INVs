  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where HIDE='' or HIDE is null or HIDE='N'   order by DEPT_NAME                                                                                 " SpecificOptions.Text="" PropData="05704C6566740388000470546F700390000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_inno_item" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select g.DRUG_NAME,&#13;&#10;SUM(CASE when v.HOSP_LIST = 8 then c.COST else  0 end) as INNO,&#13;&#10;SUM(CASE when  (v.HOSP_LIST&#60;&#62; 8  or v.HOSP_LIST is null ) then c.COST else  0 end) as GEN,&#13;&#10;SUM(c.COST) as ALL_BUY,&#13;&#10;SUM(CASE when v.HOSP_LIST = 8 then c.COST else  0 end)*100/SUM(c.COST) as PERCENT_INNO&#13;&#10;FROM&#13;&#10;MS_PO_C c&#13;&#10;left join DRUG_VN v on (c.TRADE_CODE = v.TRADE_CODE)&#13;&#10;left join DRUG_GN g on (v.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join MS_PO m on (c.PO_NO = m.PO_NO)&#13;&#10;where m.REQ_APP_DATE between :date1  and :date2  &#13;&#10;and ( c.WORKING_CODE in (select WORKING_CODE from DRUG_VN where HOSP_LIST = 8) or g.HOSP_LIST = 8)&#13;&#10;and c.REV_FLAG='N'      &#13;&#10;group by g.DRUG_NAME&#13;&#10;having  SUM(c.COST)&#62; 0                        " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
