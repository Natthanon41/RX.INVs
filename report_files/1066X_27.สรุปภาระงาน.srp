<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.8668328472" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  date1.date:=now-30 ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp" DataSetName="rp"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp" UserName="rp" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER} &#13;&#10;&#13;&#10;SELECT T.USER_ID,SUM(PO) as PO, SUM(ITEM_PO) as ITEM_PO,&#13;&#10;SUM(IVO) as IVO, SUM(IVO_ITEM) as IVO_ITEM,SUM(DIS) as DIS,SUM(DIS_ITEM) as DIS_ITEM,SUM(ACC) as ACC,SUM(ACC_ITEM) as ACC_ITEM&#13;&#10;FROM(    &#13;&#10;select c.USER_ID, COUNT(DISTINCT m.REF_NO) as PO, COUNT(c.WORKING_CODE) as ITEM_PO,&#13;&#10;0 as IVO, 0 as IVO_ITEM,0 as DIS,0 as DIS_ITEM,0 as ACC,0 as ACC_ITEM&#13;&#10;from MS_PO_C c (NOLOCK)&#13;&#10;left join MS_PO m (NOLOCK) on (c.PO_NO=m.PO_NO)&#13;&#10;where c.PO_DATE BETWEEN :d1  and :d2&#13;&#10;group by c.USER_ID&#13;&#10;UNION&#13;&#10;select c.USER_ID, 0 as PO, 0 as ITEM_PO,&#13;&#10;COUNT(DISTINCT m.RECEIVE_NO) as IVO, COUNT(c.WORKING_CODE) as IVO_ITEM,0 as DIS,0 as DIS_ITEM,0 as ACC,0 as ACC_ITEM&#13;&#10;from MS_IVO_C c (NOLOCK)&#13;&#10;left join MS_IVO m (NOLOCK) on (c.INVOICE_NO = m.INVOICE_NO)&#13;&#10;where m.RECEIVE_DATE BETWEEN :d1  and :d2&#13;&#10;group by c.USER_ID&#13;&#10;UNION&#13;&#10;select c.USER_ID, 0 as PO, 0 as ITEM_PO,&#13;&#10;0 as IVO, 0 as IVO_ITEM,COUNT(DISTINCT c.SUB_PO_NO) as DIS,COUNT(c.WORKING_CODE) as DIS_ITEM,0 as ACC,0 as ACC_ITEM&#13;&#10;from SM_PO_C c (NOLOCK)&#13;&#10;left join SM_PO m (NOLOCK) on (c.SUB_PO_NO = m.SUB_PO_NO)&#13;&#10;where m.SUB_PO_DATE BETWEEN :d1  and :d2&#13;&#10;group by c.USER_ID&#13;&#10;UNION&#13;&#10;select a.USER_ID, 0 as PO, 0 as ITEM_PO,&#13;&#10;0 as IVO, 0 as IVO_ITEM,0 as DIS,0 as DIS_ITEM,&#13;&#10;COUNT(DISTINCT a.REQ_NO) as ACC,COUNT(a.WORKING_CODE) as ACC_ITEM&#13;&#10;from ACCR_DISP a (NOLOCK)&#13;&#10;where a.REQ_DATE BETWEEN :d1  and :d2&#13;&#10;group by a.USER_ID) as T&#13;&#10;GROUP BY T.USER_ID  &#13;&#10;  &#13;&#10;{ELSE} &#13;&#10;&#13;&#10;SELECT T.USER_ID,SUM(PO) as PO, SUM(ITEM_PO) as ITEM_PO,&#13;&#10;SUM(IVO) as IVO, SUM(IVO_ITEM) as IVO_ITEM,SUM(DIS) as DIS,SUM(DIS_ITEM) as DIS_ITEM,SUM(ACC) as ACC,SUM(ACC_ITEM) as ACC_ITEM&#13;&#10;FROM(    &#13;&#10;select c.USER_ID, COUNT(DISTINCT m.REF_NO) as PO, COUNT(c.WORKING_CODE) as ITEM_PO,&#13;&#10;0 as IVO, 0 as IVO_ITEM,0 as DIS,0 as DIS_ITEM,0 as ACC,0 as ACC_ITEM&#13;&#10;from MS_PO_C c &#13;&#10;left join MS_PO m  on (c.PO_NO=m.PO_NO)&#13;&#10;where c.PO_DATE BETWEEN :d1  and :d2&#13;&#10;group by c.USER_ID&#13;&#10;UNION&#13;&#10;select c.USER_ID, 0 as PO, 0 as ITEM_PO,&#13;&#10;COUNT(DISTINCT m.RECEIVE_NO) as IVO, COUNT(c.WORKING_CODE) as IVO_ITEM,0 as DIS,0 as DIS_ITEM,0 as ACC,0 as ACC_ITEM&#13;&#10;from MS_IVO_C c &#13;&#10;left join MS_IVO m  on (c.INVOICE_NO = m.INVOICE_NO)&#13;&#10;where m.RECEIVE_DATE BETWEEN :d1  and :d2&#13;&#10;group by c.USER_ID&#13;&#10;UNION&#13;&#10;select c.USER_ID, 0 as PO, 0 as ITEM_PO,&#13;&#10;0 as IVO, 0 as IVO_ITEM,COUNT(DISTINCT c.SUB_PO_NO) as DIS,COUNT(c.WORKING_CODE) as DIS_ITEM,0 as ACC,0 as ACC_ITEM&#13;&#10;from SM_PO_C c &#13;&#10;left join SM_PO m  on (c.SUB_PO_NO = m.SUB_PO_NO)&#13;&#10;where m.SUB_PO_DATE BETWEEN :d1  and :d2&#13;&#10;group by c.USER_ID&#13;&#10;UNION&#13;&#10;select a.USER_ID, 0 as PO, 0 as ITEM_PO,&#13;&#10;0 as IVO, 0 as IVO_ITEM,0 as DIS,0 as DIS_ITEM,&#13;&#10;COUNT(DISTINCT a.REQ_NO) as ACC,COUNT(a.WORKING_CODE) as ACC_ITEM&#13;&#10;from ACCR_DISP a &#13;&#10;where a.REQ_DATE BETWEEN :d1  and :d2&#13;&#10;group by a.USER_ID) as T&#13;&#10;GROUP BY T.USER_ID  &#13;&#10;&#13;&#10;{ENDIF}     &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER} &#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE='' or HIDE is null  or HIDE = 'N' )&#13;&#10;and INV_TYPE='99'  &#13;&#10;&#13;&#10;{ELSE} &#13;&#10;&#13;&#10;select * from DEPT_ID  where (HIDE='' or HIDE is null or HIDE = 'N' )&#13;&#10;and INV_TYPE='99'  &#13;&#10;&#13;&#10;{ENDIF}     &#13;&#10;&#13;&#10;&#13;&#10;  " SpecificOptions.Text="" PropData="05704C65667402380470546F700384000A506172616D65746572730100"/>
  </TfrxDataPage>
