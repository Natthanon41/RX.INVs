<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="43189.663930162" ReportOptions.Description.Text="" ReportOptions.LastChange="43199.4849054398" ScriptLanguage="PascalScript" ScriptText.Text="begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry1" DataSetName="rp1"/>
  </Datasets>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                             &#13;&#10;select T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM from (&#13;&#10;select dbo.NLEM(g.IS_ED) as NLEM,g.IS_ED,                                                &#13;&#10;&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  ) as FW_VALUE,&#13;&#10;          &#13;&#10;isnull(Cx.RCV_VALUE,0) AS RCV_VALUE,isnull(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym2              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as RM_VALUE            &#13;&#10;from INV_MD  i (NOLOCK)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;        SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.[VALUE]           &#13;&#10;                         when c1.R_S_STATUS in ('M','E','B','B') then c1.[VALUE]*-1 else NULL end) as RCV_VALUE,&#13;&#10;           &#13;&#10;       						SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.[VALUE]&#13;&#10;	      									 when (c1.R_S_STATUS in ('C','Z','U')) then c1.[VALUE]*-1 else NULL end) as DIS_VALUE&#13;&#10;   						from CARD c1  (NOLOCK)  &#13;&#10;            where  c1.STOCK_ID=:stock                          &#13;&#10;            and    left(dbo.ce2cymd(c1.OPERATE_DATE),6) between :ym1 and  :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;where (isnull(T.FW_VALUE,0)+isnull(T.RCV_VALUE,0)+isnull(T.DIS_VALUE,0)+ isnull(T.RM_VALUE,0)) &#62; 0                 &#13;&#10;group by T.NLEM ,T.IS_ED       &#13;&#10;--HAVING (SUM(ISNULL(T.FW_VALUE,0))+ SUM(ISNULL(RCV_VALUE,0))+ SUM(ISNULL(T.DIS_VALUE,0))+SUM(ISNULL(RM_VALUE,0)) &#62; 0 )&#13;&#10;order by  T.IS_ED&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;  &#13;&#10;select T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM from (    &#13;&#10;select NLEM(g.IS_ED) as NLEM,g.IS_ED,                                                &#13;&#10;&#13;&#10;(select  c.REMAIN_VALUE from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  limit 1) as FW_VALUE,&#13;&#10;          &#13;&#10;isnull(Cx.RCV_VALUE,0) AS RCV_VALUE,isnull(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select  c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) &#60;= :ym2              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC  limit 1 ) as RM_VALUE            &#13;&#10;from INV_MD  i (NOLOCK)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;         SUM(CASE when c1.R_S_STATUS in ('R','I','G','A','N') then c1.VALUE         &#13;&#10;         when c1.R_S_STATUS in ('B','M') then c1.VALUE*-1 else NULL end) as RCV_VALUE,&#13;&#10;           &#13;&#10;       						SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.VALUE&#13;&#10;	      									 when (c1.R_S_STATUS='C') then c1.VALUE*-1 else NULL end) as DIS_VALUE&#13;&#10;   						from CARD c1  (NOLOCK)  &#13;&#10;            where  c1.STOCK_ID=:stock                          &#13;&#10;            and    left(c1.R_S_DATE,6) between :ym1 and  :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;group by T.NLEM ,T.IS_ED       &#13;&#10;HAVING (SUM(ISNULL(T.FW_VALUE,0))+ SUM(ISNULL(RCV_VALUE,0))+ SUM(ISNULL(T.DIS_VALUE,0))+SUM(ISNULL(RM_VALUE,0)) &#62; 0 )&#13;&#10;order by  T.IS_ED&#13;&#10;&#13;&#10;{ENDIF}  " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
  <TfrxReportPage Name="Page1" HGuides.Text="" VGuides.Text="" PaperWidth="210" PaperHeight="297" PaperSize="9" LeftMargin="10" RightMargin="10" TopMargin="10" BottomMargin="10" ColumnWidth="0" ColumnPositions.Text="" Frame.Typ="0" MirrorMode="0">
