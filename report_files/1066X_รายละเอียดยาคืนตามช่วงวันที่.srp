<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.8220295486" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; t,r :extended ;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  date1.date:=now -30 ;&#13;&#10;  date2.date:=now  ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   DialogPage1.visible:=False ;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rtn" DataSetName="rtn"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rtn" UserName="rtn" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}        &#13;&#10;&#13;&#10;select g.DRUG_NAME,v.TRADE_NAME, d.DEPT_NAME, r.RETURN_REASON,i.TOTAL_COST,i.RETURN_COST,i.TOTAL_QTY,i.RETURN_QTY,&#13;&#10;r.RETURN_REASON    &#13;&#10;from INV_RTN_C i (NOLOCK)&#13;&#10;left join RTN_REASON r (NOLOCK) on (i.REASON_ID = r.ID)&#13;&#10;left join INV_RTN m (NOLOCK) on (i.RETURN_NO = m.RETURN_NO)&#13;&#10;left join DEPT_ID d (NOLOCK) on (d.DEPT_ID = m.DEPT_ID)&#13;&#10;left join DRUG_VN v (NOLOCK) on (v.TRADE_CODE = i.TRADE_CODE)&#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE = g.WORKING_CODE)                                                                                                                                                &#13;&#10;where m.STOCK_ID=:stock_id&#13;&#10;and m.RETURN_DATE BETWEEN :date1 and :date2&#13;&#10;and i.CANCEL_FLAG='N'&#13;&#10;and i.RCV_FLAG='Y'&#13;&#10;order by m.RETURN_DATE&#13;&#10;&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;&#13;&#10;select g.DRUG_NAME,v.TRADE_NAME, d.DEPT_NAME, r.RETURN_REASON,i.TOTAL_COST,i.RETURN_COST,i.TOTAL_QTY,i.RETURN_QTY,&#13;&#10;r.RETURN_REASON    &#13;&#10;from INV_RTN_C i &#13;&#10;left join RTN_REASON r on (i.REASON_ID = r.ID)&#13;&#10;left join INV_RTN m on (i.RETURN_NO = m.RETURN_NO)&#13;&#10;left join DEPT_ID d on (d.DEPT_ID = m.DEPT_ID)&#13;&#10;left join DRUG_VN v on (v.TRADE_CODE = i.TRADE_CODE)&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE = g.WORKING_CODE)                                                                                                                                                &#13;&#10;where m.STOCK_ID=:stock_id&#13;&#10;and m.RETURN_DATE BETWEEN :date1 and :date2&#13;&#10;and i.CANCEL_FLAG='N'&#13;&#10;and i.RCV_FLAG='Y'&#13;&#10;order by m.RETURN_DATE  &#13;&#10;&#13;&#10;{endif}      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where HIDE='' or HIDE is null  or HIDE ='N'&#13;&#10;and DEPT_TYPE in (2,3)                                                 &#13;&#10;order by DEPT_NAME                                        " SpecificOptions.Text="" PropData="05704C656674030C010470546F7003A8000A506172616D65746572730100"/>
  </TfrxDataPage>
