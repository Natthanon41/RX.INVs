  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}   &#13;&#10;&#13;&#10;select * from DEPT_ID (NOLOCK) where&#13;&#10;(HIDE='' or HIDE is null or HIDE='N') and (DEPT_TYPE = 2 or DEPT_TYPE=3)&#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;  &#13;&#10; select * from DEPT_ID  where&#13;&#10;(HIDE='' or HIDE is null or HIDE='N') and (DEPT_TYPE = 2 or DEPT_TYPE=3)&#13;&#10;order by DEPT_NAME&#13;&#10;  &#13;&#10;{ENDIF}                       " SpecificOptions.Text="" PropData="05704C65667402480470546F7002780A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_overall" UserName="overall" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select T.WORKING_CODE,T.DRUG_NAME,&#13;&#10;T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM, SUM(TOTAL_VALUE) as ONHAND_VALUE  &#13;&#10;from (&#13;&#10;select dbo.NLEM(g.IS_ED) as NLEM,g.IS_ED,g.WORKING_CODE,g.DRUG_NAME,                                                                                                                    &#13;&#10;&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;       /* left(c.R_S_DATE,6) &#60;= :ym_fw   */ left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym_fw                                               &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  ) as FW_VALUE,&#13;&#10;          &#13;&#10;isnull(Cx.RCV_VALUE,0) AS RCV_VALUE,isnull(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;       /* left(c.R_S_DATE,6) &#60;= :ym2 */  left(dbo.ce2cymd(c.OPERATE_DATE),6)  &#60;= :ym2                            &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC ) as RM_VALUE ,i.TOTAL_VALUE               &#13;&#10;from INV_MD  i (NOLOCK)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;         SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.VALUE         &#13;&#10;                          when c1.R_S_STATUS in ('M','E','B','B') then c1.VALUE*-1 else NULL end) as RCV_VALUE,&#13;&#10;           &#13;&#10;       						SUM(CASE when c1.R_S_STATUS in ('S','D','P')  then c1.[VALUE]&#13;&#10;	              									 when (c1.R_S_STATUS in ('C','U','Z')) then c1.[VALUE]*-1 else NULL end) as DIS_VALUE&#13;&#10;   						from CARD c1  (NOLOCK)  &#13;&#10;            where  c1.STOCK_ID=:stock                          &#13;&#10;           /* and    left(c1.R_S_DATE,6) between :ym1 and  :ym2  */  and  left(dbo.ce2cymd(c1.OPERATE_DATE),6)  between :ym1 and  :ym2       &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;group by T.NLEM ,T.IS_ED,T.WORKING_CODE,T.DRUG_NAME               &#13;&#10;&#13;&#10;HAVING ROUND(SUM(RM_VALUE),2)&#60;&#62; ROUND(SUM(TOTAL_VALUE),2)            &#13;&#10;  &#13;&#10;order by T.DRUG_NAME&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;  &#13;&#10;select T.WORKING_CODE,T.DRUG_NAME,&#13;&#10;T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM, SUM(TOTAL_VALUE) as ONHAND_VALUE&#13;&#10; from (&#13;&#10;select  NLEM(g.IS_ED) as NLEM,g.IS_ED,g.WORKING_CODE,g.DRUG_NAME,                                                                                                                    &#13;&#10;&#13;&#10;(select  c.REMAIN_VALUE from  CARD c           &#13;&#10;        where &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m%d'),6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC limit 1  ) as FW_VALUE,&#13;&#10;          &#13;&#10;ifnull(Cx.RCV_VALUE,0) AS RCV_VALUE,ifnull(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select  c.REMAIN_VALUE from  CARD c         &#13;&#10;        where &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m%d'),6) &#60;= :ym2              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  limit 1 ) as RM_VALUE  ,i.TOTAL_VALUE              &#13;&#10;from INV_MD  i       &#13;&#10;left join DRUG_GN g   on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;        SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.VALUE         &#13;&#10;                          when c1.R_S_STATUS in ('M','E','B','B') then c1.VALUE*-1 else NULL end) as RCV_VALUE,&#13;&#10;           &#13;&#10;       						SUM(CASE when c1.R_S_STATUS in ('S','D','P')  then c1.VALUE  &#13;&#10;	              									 when (c1.R_S_STATUS in ('C','U','Z')) then c1.VALUE*-1 else NULL end) as DIS_VALUE&#13;&#10;   						from CARD c1     &#13;&#10;            where  c1.STOCK_ID=:stock                          &#13;&#10;            and  left(DATE_FORMAT(c1.OPERATE_DATE,'%Y%m%d'),6)  between :ym1 and  :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;group by T.NLEM ,T.IS_ED,T.WORKING_CODE,T.DRUG_NAME               &#13;&#10;&#13;&#10;HAVING ROUND(SUM(RM_VALUE),2)&#60;&#62; ROUND(SUM(TOTAL_VALUE),2)            &#13;&#10;&#13;&#10;  &#13;&#10;order by T.DRUG_NAME  &#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
