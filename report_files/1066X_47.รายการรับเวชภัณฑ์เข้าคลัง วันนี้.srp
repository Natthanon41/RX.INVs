  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp" UserName="rp" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;&#13;&#10;  &#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;SELECT i.RECEIVE_NO,i.RECEIVE_DATE,i.INVOICE_NO,co.KEY_WORD,co.COMPANY_NAME,c.WORKING_CODE,g.DRUG_NAME,v.TRADE_NAME,&#13;&#10;c.QTY_RCV,c.PACK_RATIO,c.EXPIRED_DATE,c.LOT_NO,c.LOCATION ,s.SALE_UNIT                                              &#13;&#10;FROM  MS_IVO i &#13;&#10;LEFT JOIN MS_IVO_C c on (c.RECEIVE_NO = i.RECEIVE_NO)&#13;&#10;LEFT JOIN COMPANY co on (co.COMPANY_CODE = i. VENDOR_CODE)&#13;&#10;LEFT JOIN DRUG_GN g on (g.WORKING_CODE = c.WORKING_CODE)&#13;&#10;LEFT JOIN DRUG_VN v on (v.TRADE_CODE = c.TRADE_CODE)&#13;&#10;LEFT JOIN SALE_UNIT s on (g.SALE_UNIT_ID=s.SU_ID)                                                                                                                            &#13;&#10;WHERE /*i.RECEIVE_DATE = DATE_FORMAT( ADDDATE( CURDATE(), INTERVAL -2 DAY) ,'%Y%m%d')  */    &#13;&#10; i.RECEIVE_DATE = DATE_FORMAT( CURDATE() ,'%Y%m%d')           &#13;&#10;AND i.DEPT_ID=:stock_id                                               &#13;&#10;&#13;&#10;&#13;&#10;{endif}      &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;                " SpecificOptions.Text="" PropData="05704C65667402760470546F700390000A506172616D657465727301010644204E616D653D2273746F636B5F6964222044617461547970653D226674537472696E67222045787072657373696F6E3D226362625F73746F636B2E6B657976616C7565220000"/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID where HIDE='' or HIDE is null or HIDE='N'&#13;&#10;&#13;&#10;                " SpecificOptions.Text="" PropData="05704C65667402740470546F7002480A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_inv_md_c" UserName="rp2" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select g.DRUG_NAME,i.*,s.SALE_UNIT                                                      &#13;&#10;from INV_MD_C  i&#13;&#10;left join DRUG_GN g on (g.WORKING_CODE =i.WORKING_CODE)&#13;&#10;LEFT JOIN SALE_UNIT s on (g.SALE_UNIT_ID=s.SU_ID)    &#13;&#10;Where DEPT_ID=:dept_id&#13;&#10;AND i.WORKING_CODE=:working_code                                                                     " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
