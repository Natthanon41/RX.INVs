  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="qry_sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="&#13;&#10;{IF SQLSERVER}&#13;&#10;&#13;&#10;select T2.DEPT_ID,T2.DEPT_NAME,T2.DEPT_TYPE,&#13;&#10;SUM(CASE when T2.NLEM = 'ED' then T2.FW_VALUE else 0 end) as FW_VALUE_ED,&#13;&#10;SUM(CASE when T2.NLEM = 'NED' then T2.FW_VALUE else 0 end) as FW_VALUE_NED,&#13;&#10;SUM(CASE when T2.NLEM not in ('ED','NED') then T2.FW_VALUE else 0 end) as FW_VALUE_NA,&#13;&#10;SUM(CASE when T2.NLEM = 'ED' then T2.RCV_VALUE else 0 end) as RCV_VALUE_ED,&#13;&#10;SUM(CASE when T2.NLEM = 'NED' then T2.RCV_VALUE else 0 end) as RCV_VALUE_NED,&#13;&#10;SUM(CASE when T2.NLEM not in ('ED','NED') then T2.RCV_VALUE else 0 end) as RCV_VALUE_NA,&#13;&#10;SUM(CASE when T2.NLEM = 'ED' then T2.DIS_VALUE2 else 0 end) as DIS_VALUE_ED,&#13;&#10;SUM(CASE when T2.NLEM = 'NED' then T2.DIS_VALUE2 else 0 end) as DIS_VALUE_NED,&#13;&#10;SUM(CASE when T2.NLEM not in ('ED','NED') then T2.DIS_VALUE2 else 0 end) as DIS_VALUE_NA,&#13;&#10;SUM(CASE when T2.NLEM = 'ED' then T2.RM_VALUE else 0 end) as RM_VALUE_ED,&#13;&#10;SUM(CASE when T2.NLEM = 'NED' then T2.RM_VALUE else 0 end) as RM_VALUE_NED,&#13;&#10;SUM(CASE when T2.NLEM not in ('ED','NED') then T2.RM_VALUE else 0 end) as RM_VALUE_NA&#13;&#10;from (&#13;&#10;SELECT  d.DEPT_ID,d.DEPT_TYPE,d.DEPT_NAME,T.NLEM,SUM(isnull(FW_VALUE,0)) as FW_VALUE,SUM(isnull(RCV_VALUE,0)) as RCV_VALUE,&#13;&#10;SUM(isnull(DIS_VALUE,0)) as DIS_VALUE,SUM(isnull(RM_VALUE,0)) as RM_VALUE,&#13;&#10;SUM(isnull(FW_VALUE,0)) + SUM(isnull(RCV_VALUE,0)) - SUM(isnull(RM_VALUE,0))  DIS_VALUE2                              &#13;&#10;from ( &#13;&#10; &#13;&#10;select i.DEPT_ID,i.WORKING_CODE,dbo.IS_ED(g.IS_ED) as NLEM,&#13;&#10;&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) between  left(dbo.ce2cymd(GETDATE()-300),6) and  :ym_fw                                             &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by   c.OPERATE_DATE DESC ) as FW_VALUE,&#13;&#10;          &#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE,&#13;&#10;      &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  between  left(dbo.ce2cymd(GETDATE()-300),6) and  :ym1                    &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by  c.OPERATE_DATE DESC ) as RM_VALUE,i.TOTAL_VALUE&#13;&#10;          &#13;&#10;from INV_MD  i (NOLOCK)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;             			SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.[VALUE] else NULL end) as RCV_VALUE,																	       &#13;&#10;             						SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.[VALUE] &#13;&#10;	                     									 when (c1.R_S_STATUS='C') then c1.[VALUE]*-1 else NULL end) as DIS_VALUE&#13;&#10;						from CARD c1  (NOLOCK)  &#13;&#10;            where  left(c1.R_S_DATE,6)= :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)    &#13;&#10;where  g.WORKING_CODE is not null &#13;&#10;&#13;&#10;                                                 &#13;&#10;)  as T&#13;&#10;/*where T.TOTAL_VALUE  &#62; 0.99 */&#13;&#10;left join DEPT_ID d on (d.DEPT_ID=T.DEPT_ID) &#13;&#10;where d.HOSP_TYPE=1    and  d.DEPT_TYPE&#60;&#62;0   and (d.HIDE='N' or d.HIDE='' or d.HIDE is null)                 &#13;&#10;/*and   FW_VALUE &#62; 0 and   RCV_VALUE &#62; 0 and   DIS_VALUE &#62; 0 and   RM_VALUE &#62; 0    */         &#13;&#10;group by T.NLEM,T.DEPT_ID,d.DEPT_NAME,d.DEPT_TYPE,d.DEPT_ID                 &#13;&#10;) as T2&#13;&#10;group  by T2.DEPT_NAME,T2.DEPT_TYPE,T2.DEPT_ID             &#13;&#10;order by   T2.DEPT_TYPE,T2.DEPT_ID   ASC&#13;&#10;&#13;&#10;  &#13;&#10;{ELSE}&#13;&#10;  &#13;&#10;select T2.DEPT_ID,T2.DEPT_NAME,T2.DEPT_TYPE,&#13;&#10;SUM(CASE when T2.NLEM = 'ED' then T2.FW_VALUE else 0 end) as FW_VALUE_ED,&#13;&#10;SUM(CASE when T2.NLEM = 'NED' then T2.FW_VALUE else 0 end) as FW_VALUE_NED,&#13;&#10;SUM(CASE when T2.NLEM not in ('ED','NED') then T2.FW_VALUE else 0 end) as FW_VALUE_NA,&#13;&#10;SUM(CASE when T2.NLEM = 'ED' then T2.RCV_VALUE else 0 end) as RCV_VALUE_ED,&#13;&#10;SUM(CASE when T2.NLEM = 'NED' then T2.RCV_VALUE else 0 end) as RCV_VALUE_NED,&#13;&#10;SUM(CASE when T2.NLEM not in ('ED','NED') then T2.RCV_VALUE else 0 end) as RCV_VALUE_NA,&#13;&#10;SUM(CASE when T2.NLEM = 'ED' then T2.DIS_VALUE2 else 0 end) as DIS_VALUE_ED,&#13;&#10;SUM(CASE when T2.NLEM = 'NED' then T2.DIS_VALUE2 else 0 end) as DIS_VALUE_NED,&#13;&#10;SUM(CASE when T2.NLEM not in ('ED','NED') then T2.DIS_VALUE2 else 0 end) as DIS_VALUE_NA,&#13;&#10;SUM(CASE when T2.NLEM = 'ED' then T2.RM_VALUE else 0 end) as RM_VALUE_ED,&#13;&#10;SUM(CASE when T2.NLEM = 'NED' then T2.RM_VALUE else 0 end) as RM_VALUE_NED,&#13;&#10;SUM(CASE when T2.NLEM not in ('ED','NED') then T2.RM_VALUE else 0 end) as RM_VALUE_NA&#13;&#10;from (&#13;&#10;SELECT  d.DEPT_ID,d.DEPT_TYPE,d.DEPT_NAME,T.NLEM,SUM(ifnull(FW_VALUE,0)) as FW_VALUE,SUM(ifnull(RCV_VALUE,0)) as RCV_VALUE,&#13;&#10;SUM(isfull(DIS_VALUE,0)) as DIS_VALUE,SUM(ifnull(RM_VALUE,0)) as RM_VALUE,&#13;&#10;SUM(isfull(Ff_VALUE,0)) + SUM(ifnull(RCV_VALUE,0)) - SUM(ifnull(RM_VALUE,0))  DIS_VALUE2                              &#13;&#10;from ( &#13;&#10; &#13;&#10;select i.DEPT_ID,i.WORKING_CODE,IS_ED(g.IS_ED) as NLEM,&#13;&#10;&#13;&#10;(select  c.REMAIN_VALUE from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) between  left(ce2cymd(GETDATE()-300),6) and  :ym_fw                                             &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by   c.OPERATE_DATE DESC LIMIT 1 ) as FW_VALUE,&#13;&#10;          &#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE,&#13;&#10;      &#13;&#10;(select  c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  between  left(ce2cymd(GETDATE()-300),6) and  :ym1                    &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by  c.OPERATE_DATE DESC LIMIT 1 ) as RM_VALUE,i.TOTAL_VALUE&#13;&#10;          &#13;&#10;from INV_MD  i      &#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;             			SUM(CASE when c1.R_S_STATUS in ('R','I','G','A') then c1.VALUE else NULL end) as RCV_VALUE,																	       &#13;&#10;             						SUM(CASE when c1.R_S_STATUS in ('T','S')  then c1.VALUE &#13;&#10;	                     									 when (c1.R_S_STATUS='C') then c1.VALUE*-1 else NULL end) as DIS_VALUE&#13;&#10;						from CARD c1   &#13;&#10;            where  left(c1.R_S_DATE,6)= :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)    &#13;&#10;where  g.WORKING_CODE is not null &#13;&#10;&#13;&#10;                                                 &#13;&#10;)  as T&#13;&#10;/*where T.TOTAL_VALUE  &#62; 0.99 */&#13;&#10;left join DEPT_ID d on (d.DEPT_ID=T.DEPT_ID) &#13;&#10;where d.HOSP_TYPE=1    and  d.DEPT_TYPE&#60;&#62;0   and (d.HIDE='N' or d.HIDE='' or d.HIDE is null)                 &#13;&#10;/*and   FW_VALUE &#62; 0 and   RCV_VALUE &#62; 0 and   DIS_VALUE &#62; 0 and   RM_VALUE &#62; 0    */         &#13;&#10;group by T.NLEM,T.DEPT_ID,d.DEPT_NAME,d.DEPT_TYPE,d.DEPT_ID                 &#13;&#10;) as T2&#13;&#10;group  by T2.DEPT_NAME,T2.DEPT_TYPE,T2.DEPT_ID             &#13;&#10;order by   T2.DEPT_TYPE,T2.DEPT_ID   ASC  &#13;&#10;&#13;&#10;{ENDIF}    &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;                                                  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DEPT_ID (NOLOCK) where HIDE='' or HIDE is null&#13;&#10;order by DEPT_NAME                                        " SpecificOptions.Text="" PropData="05704C65667402640470546F7003EC000A506172616D65746572730100"/>
  </TfrxDataPage>
