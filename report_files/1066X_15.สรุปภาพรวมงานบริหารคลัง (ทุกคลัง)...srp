<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.1275908333" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  m0,y0,m_1,ym0,ym1 ,: string ;&#13;&#10;  Line_no: integer ;&#13;&#10;  DIS_SUB_STOCK_VALUE,STOCK_DISP_ED,STOCK_DISP_NED:Extended ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  m1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),5,2) ;&#13;&#10;    y1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),1,4) ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  if   inttostr(strtoint(m1.text)) = '1' then&#13;&#10;  begin&#13;&#10;&#13;&#10;     m0:='12' ;&#13;&#10;     y0:=inttostr(strtoint(y1.text)-1-543) ;&#13;&#10;     m_1:='01' ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;&#13;&#10;    if   length(inttostr(strtoint(m1.text)-1)) = 1 then&#13;&#10;    begin&#13;&#10;      m0:= '0'+inttostr(strtoint(m1.text)-1);&#13;&#10;&#13;&#10;        if   length(inttostr(strtoint(m1.text))) = 1 then  m_1:= '0'+inttostr(strtoint(m1.text))&#13;&#10;        else m_1:= m1.text;&#13;&#10;&#13;&#10;    end&#13;&#10;    else&#13;&#10;    begin&#13;&#10;      m0:= inttostr(strtoint(m1.text)-1);&#13;&#10;      m_1:= m1.text;&#13;&#10;    end;&#13;&#10;&#13;&#10;   y0:=inttostr(strtoint(y1.text)-543) ;&#13;&#10;&#13;&#10;  end;&#13;&#10;&#13;&#10;  ym0:= y0 + m0 ;&#13;&#10;  ym1:=inttostr(strtoint(y1.text)-543)+m_1 ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10; end ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure Memo23OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;   if &#60;qry_sum_inv.&#34;DEPT_TYPE&#34;&#62; = 3 then  STOCK_DISP_ED:=STOCK_DISP_ED + &#60;qry_sum_inv.&#34;DIS_VALUE_ED&#34;&#62; ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo22OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   Line_no:=Line_no+1 ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;     if &#60;qry_sum_inv.&#34;DEPT_TYPE&#34;&#62; = 3 then DIS_SUB_STOCK_VALUE:=DIS_SUB_STOCK_VALUE+&#60;qry_sum_inv.&#34;DIS_VALUE_ED&#34;&#62;+&#60;qry_sum_inv.&#34;DIS_VALUE_NED&#34;&#62; ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10; DIS_SUB_STOCK_VALUE:= 0 ;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure Memo33OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   if (&#60;qry_sum_inv.&#34;FW_VALUE_NA&#34;&#62; &#62; 0) or (&#60;qry_sum_inv.&#34;RCV_VALUE_NA&#34;&#62; &#62;0)&#13;&#10;   or (&#60;qry_sum_inv.&#34;DIS_VALUE_NA&#34;&#62;&#62;0) or (&#60;qry_sum_inv.&#34;RM_VALUE_NA&#34;&#62;&#62;0)&#13;&#10;   then    Memo33.text:='C1' else  Memo33.text:='' ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo24OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   if &#60;qry_sum_inv.&#34;DEPT_TYPE&#34;&#62; = 3 then  STOCK_DISP_NED:=STOCK_DISP_NED + &#60;qry_sum_inv.&#34;DIS_VALUE_NED&#34;&#62; ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
