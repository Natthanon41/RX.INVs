  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select g.IS_ED,dbo.NLEM(g.IS_ED) as NLEM,SUM(i.TOTAL_COST) as TOTAL_COST,SUM(i.TOTAL_VALUE) as TOTAL_VALUE&#13;&#10;from INV_MD i (NOLOCK)                &#13;&#10;Left join DRUG_GN g (NOLOCK) on (g.WORKING_CODE = i.WORKING_CODE)&#13;&#10;Where i.DEPT_ID=:dept_id&#13;&#10;Group By dbo.NLEM(g.IS_ED),g.IS_ED&#13;&#10;Order By g.IS_ED&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;select * from (                                           &#13;&#10;select g.IS_ED,NLEM(g.IS_ED) as NLEM,SUM(i.TOTAL_COST) as TOTAL_COST,SUM(i.TOTAL_VALUE) as TOTAL_VALUE&#13;&#10;from INV_MD i                 &#13;&#10;Left join DRUG_GN g  on (g.WORKING_CODE = i.WORKING_CODE)&#13;&#10;Where i.DEPT_ID=:dept_id&#13;&#10;Group By NLEM(g.IS_ED),g.IS_ED&#13;&#10;Order By g.IS_ED&#13;&#10;) as T&#13;&#10;Where  NLEM&#60;&#62;'' and  TOTAL_VALUE &#60;&#62;0                                                &#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
