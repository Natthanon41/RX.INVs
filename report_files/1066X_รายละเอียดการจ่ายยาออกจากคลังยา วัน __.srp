<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" EngineOptions.SilentMode="True" EngineOptions.NewSilentMode="simSilent" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="45230.4947988889" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; input_year : integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  monthx.text:= formatdatetime('mm',now-29) ;&#13;&#10;  yearx.text:=  inttostr(strtoint(formatdatetime('YYYY',now-30))+543) ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  date1.date:=now-30 ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure monthxOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;    input_year:= strtoint(yearx.text)-543 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="frxReport1OnReportPrint">
  <Datasets>
    <item DataSet="qry_stockcard" DataSetName="rp1"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_stockcard" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select CASE when c.FREE_FLAG&#60;&#62;'Y' then '' else c.FREE_FLAG END as FREE_FLAG,  n.WORKING_CODE,n.DRUG_NAME,concat(trim(n.DRUG_NAME),' &#60;FONT color=&#34;clBlue&#34;&#62;(',trim(t.TRADE_NAME),')&#60;/FONT&#62;') as GV_NAME,u.SALE_UNIT,f.DFORM_NAME as DOSAGE_FORM,t.TRADE_NAME,&#13;&#10;CASE when R_S_STATUS='R'  then CONCAT('รับจากบริษัท',' (',TRIM(b.COMMON_DES),')')    when R_S_STATUS='N'  then 'รับยาคืน'  when R_S_STATUS='M'  then 'ยกเลิกรับคืน' when R_S_STATUS='O'  then 'คืนกลับ'   when R_S_STATUS='E'  then 'ยกเลิกคืน'&#13;&#10;when R_S_STATUS='I'  then 'รับจากคลัง'  when R_S_STATUS='D' then 'ปรับลดคงคลัง' when R_S_STATUS='U' then 'ปรับเพิ่มคงคลัง' &#13;&#10;when R_S_STATUS='T' then 'โอน'&#13;&#10;when R_S_STATUS='S' then 'จ่าย'&#13;&#10;when R_S_STATUS='G' then 'รับโอน'&#13;&#10;when R_S_STATUS='A' then 'ยกเลิกรับ'&#13;&#10;when R_S_STATUS='C' then 'ยกเลิกจ่าย'&#13;&#10;when R_S_STATUS='B' then 'ถูกยกเลิกรับ' when R_S_STATUS='P' then 'ขาย' when R_S_STATUS='Z' then 'ยกเลิกขาย'&#13;&#10;else 'ผิดพลาด' end as RS_STATUS,CASE when  c.R_S_STATUS='R' then  v.COMPANY_NAME else d.DEPT_NAME  end as DEPTNAME,c.R_S_NUMBER,ymd2dmy(c.EXPIRED_DATE) as XPIRE_DATE,&#13;&#10;c.OPERATE_DATE,CASE when  R_S_STATUS in ('R','A') then&#13;&#10;concat('ใบรับ: ',ifnull(c.R_S_NUMBER,''),'&#60;BR&#62;&#60;FONT color=&#34;clBlue&#34;&#62;ใบซื้อ:',trim(ifnull(r.PO_NO,'')),'&#60;/FONT&#62;','&#60;BR&#62;&#60;FONT color=&#34;clRed&#34;&#62;ใบส่ง:',trim(ifnull(r.INVOICE_NO,'')),'&#60;/FONT&#62;')&#13;&#10;else&#13;&#10;concat('ใบเบิก: ',ifnull(c.R_S_NUMBER,'')) end  as R_S_REF,  CASE when c.ACTIVE_QTY &#62; 0 then (c.VALUE*c.ACTIVE_PACK/c.ACTIVE_QTY) else 0 end as UNIT_COST&#13;&#10;,c.ACTIVE_QTY,c.REMAIN_QTY,concat(convert((c.ACTIVE_QTY/c.ACTIVE_PACK),char),' x ',convert(c.ACTIVE_PACK,char)) as QTY_PACK,b.COMMON_DES,&#13;&#10;c.COST,c.VALUE,c.LOT_NO,convert(c.EXPIRED_DATE,date) as EXPIREDDATE,c.*,i.*,n.*&#13;&#10;from CARD c&#13;&#10;left join MS_IVO r  on (r.RECEIVE_NO= c.R_S_NUMBER) left join BUYCOMMON b on (r.BUY_COMMON = b.COMMON_CODE)&#13;&#10;left join DRUG_GN n on (c.WORKING_CODE=n.WORKING_CODE)&#13;&#10;left join COMPANY v  on (c.DEPT_ID=convert(v.COMPANY_CODE,char))&#13;&#10;left join DEPT_ID d  on (c.DEPT_ID=d.DEPT_ID)&#13;&#10;left join SALE_UNIT u  on (n.SALE_UNIT_ID=u.SU_ID)&#13;&#10;left join DOSAGE_FORM f on (f.DFORM_ID=n.DFORM_ID)&#13;&#10;left join INV_MD i on (c.WORKING_CODE = i.WORKING_CODE  and i.DEPT_ID = c.STOCK_ID )&#13;&#10;left join DRUG_VN t on (c.TRADE_CODE = t.TRADE_CODE)&#13;&#10;where c.STOCK_ID=:stock_id and  ce2cymd(c.OPERATE_DATE) between  :date1   and :date2&#13;&#10;and c.R_S_STATUS in ('S','P','D','C','Z','U')                                             " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME&#13;&#10;&#13;&#10; {ELSE}&#13;&#10;&#13;&#10;&#13;&#10; select * from DEPT_ID  where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME&#13;&#10;&#13;&#10; {ENDIF}                 " SpecificOptions.Text="" PropData="05704C65667402580470546F7002700A506172616D65746572730100"/>
  </TfrxDataPage>
