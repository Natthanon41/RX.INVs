  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                                     &#13;&#10;select * from (&#13;&#10;select i.WORKING_CODE,g.DRUG_NAME, i.LAST_PACK_RATIO,  dbo.IS_ED(g.IS_ED) as NLEM,                                          &#13;&#10;&#13;&#10;(select top 1 c.REMAIN_QTY from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by /*c.R_S_DATE DESC,*/c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC ) as FW_QTY,&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by /*c.R_S_DATE DESC,*/c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC ) as FW_VALUE,            &#13;&#10;Cx.RCV_QTY,isnull(Cx.RCV_VALUE,0) as RCV_VALUE ,Cx.DIS_QTY ,Cx.DIS_VALUE,&#13;&#10;      &#13;&#10;isnull((select top 1 c.REMAIN_QTY from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym2                    &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ),0) as RM_QTY,i.QTY_ON_HAND,&#13;&#10;                &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym2              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as RM_VALUE            &#13;&#10;from INV_MD  i (NOLOCK)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.ACTIVE_QTY &#13;&#10;                 when c1.R_S_STATUS in ('M','E','B') then c1.ACTIVE_QTY*-1 else NULL end&#13;&#10;) as RCV_QTY,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.[VALUE]           &#13;&#10;                 when c1.R_S_STATUS in ('M','E','B') then c1.[VALUE]*-1 else NULL end&#13;&#10;) as RCV_VALUE,    &#13;&#10;						SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.ACTIVE_QTY &#13;&#10;										 when (c1.R_S_STATUS in ('C','Z','U')) then c1.ACTIVE_QTY*-1 else NULL end) as DIS_QTY,&#13;&#10;						SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.[VALUE] &#13;&#10;										 when (c1.R_S_STATUS in ('C','Z','U')) then c1.[VALUE]*-1 else NULL end) as DIS_VALUE&#13;&#10;						from CARD c1  (NOLOCK)  &#13;&#10;            where  c1.STOCK_ID=:stock1                            &#13;&#10;            and    left(dbo.ce2cymd(c1.OPERATE_DATE),6) between :ym1 and  :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock2 and   g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;where (isnull(T.FW_QTY,0)+isnull(T.RCV_QTY,0)+isnull(T.DIS_QTY,0)+ isnull(T.RM_QTY,0)) &#62; 0                                                                                                                                                 &#13;&#10;ORDER BY T.NLEM,T.DRUG_NAME&#13;&#10;&#13;&#10;  &#13;&#10;{ELSE}&#13;&#10;&#13;&#10;  &#13;&#10;select * from (&#13;&#10;select i.WORKING_CODE,g.DRUG_NAME, i.LAST_PACK_RATIO,  IS_ED(g.IS_ED) as NLEM,                                          &#13;&#10;&#13;&#10;(select c.REMAIN_QTY from  CARD c          &#13;&#10;        where &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m'),6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by /*c.R_S_DATE DESC,*/c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC limit 1) as FW_QTY,&#13;&#10;          &#13;&#10;Cx.RCV_QTY,Cx.DIS_QTY ,Cx.DIS_VALUE,&#13;&#10;      &#13;&#10;ifnull((select c.REMAIN_QTY from  CARD c        &#13;&#10;        where &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m'),6) &#60;= :ym2                   &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE and  c.REMAIN_VALUE &#62;=0     &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC limit 1),0) as RM_QTY,i.QTY_ON_HAND,&#13;&#10;(select c.REMAIN_VALUE from  CARD c        &#13;&#10;        where &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m'),6) &#60;= :ym2              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE and  c.REMAIN_VALUE &#62;=0     &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1) as RM_VALUE            &#13;&#10;from INV_MD  i      &#13;&#10;left join DRUG_GN g  on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.ACTIVE_QTY &#13;&#10;         when c1.R_S_STATUS in ('M','E','B') then c1.ACTIVE_QTY*-1 else NULL end&#13;&#10;) as RCV_QTY,          &#13;&#10;SUM(CASE when c1.R_S_STATUS in ('S','P','D','T')  then c1.ACTIVE_QTY when (c1.R_S_STATUS in ('C','Z','U') ) then c1.ACTIVE_QTY*-1 else NULL end) as DIS_QTY,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('S','P','D','T')  then c1.VALUE &#13;&#10;when (c1.R_S_STATUS in ('C','Z','U') ) then c1.VALUE*-1 else NULL end) as DIS_VALUE  &#13;&#10;						from CARD c1    &#13;&#10;            where  c1.STOCK_ID=:stock1                           &#13;&#10;            and    left(DATE_FORMAT(c1.OPERATE_DATE,'%Y%m'),6) between :ym1 and  :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock2 and   g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;where (ifnull(T.FW_QTY,0)+ifnull(T.RCV_QTY,0)+ifnull(T.DIS_QTY,0)+ ifnull(T.RM_QTY,0)) &#62; 0                                                                                                                                                 &#13;&#10;ORDER BY T.NLEM, T.DRUG_NAME  &#13;&#10;{ENDIF}                   " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                             &#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE='' or HIDE is null or HIDE='N') and (DEPT_TYPE = 2 or DEPT_TYPE=3)&#13;&#10;order by DEPT_NAME&#13;&#10;{ELSE}&#13;&#10;select * from DEPT_ID  where (HIDE='' or HIDE is null or HIDE='N') and (DEPT_TYPE = 2 or DEPT_TYPE=3)&#13;&#10;order by DEPT_NAME  &#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData="05704C65667402480470546F7002780A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_aic" UserName="qry_aic" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select a.*,CASE when a.PRESID_FLAG='Y' then 'ประธานกรรมการ'  else   'กรรมการ'  end as PRESI ,n.[POSITION] ,n.TITLE_NAME&#13;&#10;from AIC a&#13;&#10;left join AIC_NAME n on a.AIC_CODE=n.AIC_CODE&#13;&#10;where a.REF_NO=:ref_no&#13;&#10;order by a.PRESID_FLAG DESC,a.AIC_CODE ASC&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select a.*,CASE when a.PRESID_FLAG='Y' then 'ประธานกรรมการ'  else   'กรรมการ'  end as PRESI ,n.POSITION ,n.TITLE_NAME&#13;&#10;from AIC a&#13;&#10;left join AIC_NAME n on a.AIC_CODE=n.AIC_CODE&#13;&#10;where a.REF_NO=:ref_no&#13;&#10;order by a.PRESID_FLAG DESC,a.AIC_CODE ASC&#13;&#10;  &#13;&#10;&#13;&#10;{ENDIF}                &#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_last_cost" UserName="last_cost" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" Master="qry_sum_inv" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select top 1 LAST_BUY_COST,LAST_PACK_RATIO from DRUG_VN (NOLOCK)&#13;&#10;where WORKING_CODE=:wk&#13;&#10;and LAST_PACK_RATIO &#62; 0 &#13;&#10;order by LAST_BUY DESC&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select LAST_BUY_COST,LAST_PACK_RATIO from DRUG_VN &#13;&#10;where WORKING_CODE=:wk&#13;&#10;and LAST_PACK_RATIO &#62; 0 &#13;&#10;order by LAST_BUY DESC&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData="05704C65667402540470546F70033C010A506172616D65746572730101061E204E616D653D22776B222044617461547970653D226674537472696E67220001061E204E616D653D22776B222044617461547970653D226674537472696E67220000"/>
    <TfrxUniDACQuery Name="qry_overall" UserName="overall" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                             &#13;&#10;select T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM from (&#13;&#10;select dbo.NLEM(g.IS_ED) as NLEM,g.IS_ED,                                                &#13;&#10;&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  (NOLOCK)        &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  ) as FW_VALUE,&#13;&#10;          &#13;&#10;isnull(Cx.RCV_VALUE,0) AS RCV_VALUE,isnull(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c (NOLOCK)       &#13;&#10;        where &#13;&#10;        left(dbo.ce2cymd(c.OPERATE_DATE),6) &#60;= :ym2              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as RM_VALUE            &#13;&#10;from INV_MD  i (NOLOCK)     &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;        SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.[VALUE]           &#13;&#10;                         when c1.R_S_STATUS in ('M','E','B','B') then c1.[VALUE]*-1 else NULL end) as RCV_VALUE,&#13;&#10;           &#13;&#10;       						SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.[VALUE]&#13;&#10;	      									 when c1.R_S_STATUS in ('C','Z','U') then c1.[VALUE]*-1 else NULL end) as DIS_VALUE&#13;&#10;   						from CARD c1  (NOLOCK)  &#13;&#10;            where  c1.STOCK_ID=:stock                          &#13;&#10;            and    left(dbo.ce2cymd(c1.OPERATE_DATE),6) between :ym1 and  :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;where (isnull(T.FW_VALUE,0)+isnull(T.RCV_VALUE,0)+isnull(T.DIS_VALUE,0)+ isnull(T.RM_VALUE,0)) &#62; 0                 &#13;&#10;group by T.NLEM ,T.IS_ED       &#13;&#10;--HAVING (SUM(ISNULL(T.FW_VALUE,0))+ SUM(ISNULL(RCV_VALUE,0))+ SUM(ISNULL(T.DIS_VALUE,0))+SUM(ISNULL(RM_VALUE,0)) &#62; 0 )&#13;&#10;order by  T.IS_ED&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;select T.IS_ED,T.NLEM,SUM(T.FW_VALUE) as FW,SUM(RCV_VALUE) as  RCV,SUM(T.DIS_VALUE) as DIS,SUM(RM_VALUE) as RM from (    &#13;&#10;select NLEM(g.IS_ED) as NLEM,g.IS_ED,                                                &#13;&#10;&#13;&#10;(select  c.REMAIN_VALUE from  CARD c           &#13;&#10;        where &#13;&#10;        left(ce2cymd(c.OPERATE_DATE),6) &#60;= :ym_fw                                  &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  limit 1) as FW_VALUE,&#13;&#10;          &#13;&#10;IFNULL(Cx.RCV_VALUE,0) AS RCV_VALUE,IFNULL(Cx.DIS_VALUE,0) as DIS_VALUE ,&#13;&#10;   &#13;&#10;(select  c.REMAIN_VALUE from  CARD c         &#13;&#10;        where &#13;&#10;        left(ce2cymd(c.OPERATE_DATE),6) &#60;= :ym2              &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0          &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC,c.RECORD_NUMBER DESC  limit 1 ) as RM_VALUE            &#13;&#10;from INV_MD  i       &#13;&#10;left join DRUG_GN g   on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;         SUM(CASE when c1.R_S_STATUS in ('R','A','N','I','G') then c1.VALUE         &#13;&#10;         when c1.R_S_STATUS in ('M','E','B','B') then c1.VALUE*-1 else NULL end) as RCV_VALUE,             &#13;&#10;         						SUM(CASE when c1.R_S_STATUS in ('T','S','P','D','O')   then c1.VALUE&#13;&#10;when c1.R_S_STATUS in ('C','Z','U') then c1.VALUE*-1 else NULL end) as DIS_VALUE    &#13;&#10;   						from CARD c1     &#13;&#10;            where  c1.STOCK_ID=:stock                          &#13;&#10;            and    left(ce2cymd(c1.OPERATE_DATE),6) between :ym1 and  :ym2&#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)   &#13;&#10;where  i.DEPT_ID=:stock and g.WORKING_CODE is not null            &#13;&#10;) as T&#13;&#10;group by T.NLEM ,T.IS_ED       &#13;&#10;HAVING (SUM(IFNULL(T.FW_VALUE,0))+ SUM(IFNULL(RCV_VALUE,0))+ SUM(IFNULL(T.DIS_VALUE,0))+SUM(IFNULL(RM_VALUE,0)) &#62; 0 )&#13;&#10;order by  T.IS_ED&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
