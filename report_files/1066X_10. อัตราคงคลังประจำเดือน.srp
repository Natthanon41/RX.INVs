  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="qry_sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SELECT SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE&#13;&#10;from (  &#13;&#10;select i.WORKING_CODE,IS_ED(g.IS_ED) as NLEM,&#13;&#10;&#13;&#10;(select   c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m'),6) &#60;=   :ym_fw                         &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC  limit 1) as FW_VALUE,&#13;&#10;          &#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE ,&#13;&#10;      &#13;&#10;(select  c.REMAIN_VALUE from  CARD c  &#13;&#10;        where                                               &#13;&#10;        left(DATE_FORMAT(c.OPERATE_DATE,'%Y%m'),6) &#60;=   :ym1                &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC  limit 1 ) as RM_VALUE,i.TOTAL_VALUE&#13;&#10;          &#13;&#10;from INV_MD i&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (&#13;&#10;   select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.VALUE         &#13;&#10;when c1.R_S_STATUS in ('M','E','B','B') then c1.VALUE*-1 else NULL end) as RCV_VALUE,    &#13;&#10;                  &#13;&#10;SUM(CASE when c1.R_S_STATUS in ('S','P','D')   then c1.VALUE&#13;&#10;when  (c1.R_S_STATUS in ('C','Z','U'))  then c1.VALUE*-1 else NULL end) as DIS_VALUE&#13;&#10;            from CARD c1&#13;&#10;            where c1.STOCK_ID=:dept0     &#13;&#10;            and left(DATE_FORMAT(c1.OPERATE_DATE,'%Y%m'),6) = :ym2  &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)    &#13;&#10;where i.DEPT_ID=:dept  and   g.WORKING_CODE is not null                                                                      &#13;&#10;)  as T&#13;&#10;/*where T.TOTAL_VALUE  &#62; 0.99 */&#13;&#10;/*where   FW_VALUE &#62; 0 and   RCV_VALUE &#62; 0 and   DIS_VALUE &#62; 0 and   RM_VALUE &#62; 0   */            &#13;&#10;      " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                               &#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE='' or HIDE is null or HIDE='N'&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select * from DEPT_ID  where HIDE='' or HIDE is null or HIDE='N'&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData="05704C65667402640470546F7003EC000A506172616D65746572730100"/>
  </TfrxDataPage>
