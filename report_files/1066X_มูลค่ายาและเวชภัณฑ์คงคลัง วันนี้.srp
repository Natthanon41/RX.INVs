  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_inv" UserName="inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER} &#13;&#10;&#13;&#10;SELECT CASE WHEN g.IS_ED in (1,2) THEN 'เวชภัณฑ์ยา' ELSE NLEM(g.IS_ED) END as NLEM_GR,&#13;&#10;NLEM(g.IS_ED) as NLEM,SUM(i.TOTAL_VALUE) as TOTAL_VALUE&#13;&#10;FROM INV_MD i &#13;&#10;LEFT JOIN DRUG_GN g on (g.WORKING_CODE = i.WORKING_CODE)&#13;&#10;GROUP BY CASE WHEN g.IS_ED in (1,2) THEN 'เวชภัณฑ์ยา' ELSE NLEM(g.IS_ED) END,NLEM(g.IS_ED)&#13;&#10;HAVING SUM(i.TOTAL_VALUE) &#62; 0&#13;&#10;ORDER BY  g.IS_ED  &#13;&#10;&#13;&#10;  &#13;&#10;{ELSE} &#13;&#10;  SELECT CASE WHEN g.IS_ED in (1,2) THEN 'เวชภัณฑ์ยา' ELSE NLEM(g.IS_ED) END as NLEM_GR,&#13;&#10;NLEM(g.IS_ED) as NLEM,SUM(i.TOTAL_VALUE) as TOTAL_VALUE&#13;&#10;FROM INV_MD i &#13;&#10;LEFT JOIN DRUG_GN g on (g.WORKING_CODE = i.WORKING_CODE)&#13;&#10;GROUP BY CASE WHEN g.IS_ED in (1,2) THEN 'เวชภัณฑ์ยา' ELSE NLEM(g.IS_ED) END,NLEM(g.IS_ED)&#13;&#10;HAVING SUM(i.TOTAL_VALUE) &#62; 0&#13;&#10;ORDER BY  g.IS_ED  &#13;&#10;&#13;&#10;{ENDIF}&#13;&#10;&#13;&#10;  &#13;&#10;&#13;&#10;    " SpecificOptions.Text="" PropData="05704C65667402480470546F7002300A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="&#13;&#10;{IF SQLSERVER} &#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE=''&#13;&#10;or HIDE is null&#13;&#10;or HIDE='N'            &#13;&#10;order by DEPT_NAME  &#13;&#10;&#13;&#10;{ELSE} &#13;&#10;&#13;&#10;select * from DEPT_ID  where HIDE=''&#13;&#10;or HIDE is null&#13;&#10;or HIDE='N'            &#13;&#10;order by DEPT_NAME  &#13;&#10;&#13;&#10;{ENDIF}   &#13;&#10;&#13;&#10;&#13;&#10;                                        " SpecificOptions.Text="" PropData="05704C65667402480470546F7002780A506172616D65746572730100"/>
  </TfrxDataPage>
