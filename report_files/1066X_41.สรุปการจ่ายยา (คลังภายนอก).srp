<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.9276117593" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; input_year : integer ;&#13;&#10; ym:string ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  monthx.text:= formatdatetime('mm',now-29) ;&#13;&#10;  yearx.text:=  inttostr(strtoint(formatdatetime('YYYY',now))+543) ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure monthxOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;    input_year:= strtoint(yearx.text)-543 ;&#13;&#10;    ym:=  inttostr(input_year) + monthx.text ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_EMS_RE_M" DataSetName="BMS_RE_M"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_EMS_RE_M" UserName="BMS_RE_M" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="&#13;&#10;{IF SQLSERVER} &#13;&#10;&#13;&#10;select  T.* from (&#13;&#10;select  c1.DEPT_ID,e.DEPT_NAME, c1.WORKING_CODE, d.DRUG_NAME,s.SALE_UNIT,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.ACTIVE_QTY &#13;&#10;         when c1.R_S_STATUS in ('M','E','B','B') then c1.ACTIVE_QTY*-1 else NULL end&#13;&#10;) as qty_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G')  then c1.[VALUE] &#13;&#10;         when c1.R_S_STATUS in ('M','E','B','B') then c1.[VALUE]*-1 else NULL end&#13;&#10;) as val_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.ACTIVE_QTY &#13;&#10;when (c1.R_S_STATUS in ('C','Z','U')) then c1.ACTIVE_QTY*-1 else NULL end) as qty_s,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.[VALUE] &#13;&#10;when (c1.R_S_STATUS in ('C','Z','U')) then c1.[VALUE]*-1 else NULL end) as val_s&#13;&#10;from CARD c1  (NOLOCK)   &#13;&#10;left join DRUG_GN d (NOLOCK) on (c1.WORKING_CODE = d.WORKING_CODE) &#13;&#10;left join DEPT_ID e (NOLOCK) on (c1.DEPT_ID=e.DEPT_ID)&#13;&#10;left join SALE_UNIT s  (NOLOCK) on (d.SALE_UNIT_ID=s.SU_ID)&#13;&#10;where    left(dbo.ce2cymd(c1.OPERATE_DATE),6)= :ym                                &#13;&#10;and c1.DEPT_ID in (select DEPT_ID from DEPT_ID where HOSP_TYPE in (2,3) )&#13;&#10;group by  c1.DEPT_ID,e.DEPT_NAME,c1.WORKING_CODE,d.DRUG_NAME,s.SALE_UNIT   &#13;&#10; ) as T&#13;&#10; where T.qty_s &#62; 0                                        &#13;&#10; order by T.DEPT_ID,T.DRUG_NAME,T.WORKING_CODE,T.DEPT_NAME,T.SALE_UNIT    &#13;&#10;&#13;&#10;{ELSE} &#13;&#10;&#13;&#10; select  T.* from (&#13;&#10;select  c1.DEPT_ID,e.DEPT_NAME, c1.WORKING_CODE, d.DRUG_NAME,s.SALE_UNIT,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.ACTIVE_QTY &#13;&#10;         when c1.R_S_STATUS in ('M','E','B','B') then c1.ACTIVE_QTY*-1 else NULL end&#13;&#10;) as qty_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G')  then c1.VALUE&#13;&#10;         when c1.R_S_STATUS in ('M','E','B','B') then c1.VALUE*-1 else NULL end&#13;&#10;) as val_r,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.ACTIVE_QTY &#13;&#10;when (c1.R_S_STATUS in ('C','Z','U')) then c1.ACTIVE_QTY*-1 else NULL end) as qty_s,&#13;&#10;SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.VALUE&#13;&#10;when (c1.R_S_STATUS in ('C','Z','U')) then c1.VALUE*-1 else NULL end) as val_s&#13;&#10;from CARD c1     &#13;&#10;left join DRUG_GN d  on (c1.WORKING_CODE = d.WORKING_CODE) &#13;&#10;left join DEPT_ID e  on (c1.DEPT_ID=e.DEPT_ID)&#13;&#10;left join SALE_UNIT s   on (d.SALE_UNIT_ID=s.SU_ID)&#13;&#10;where    left(ce2cymd(c1.OPERATE_DATE),6)= :ym                                &#13;&#10;and c1.DEPT_ID in (select DEPT_ID from DEPT_ID where HOSP_TYPE in (2,3) )&#13;&#10;group by  c1.DEPT_ID,e.DEPT_NAME,c1.WORKING_CODE,d.DRUG_NAME,s.SALE_UNIT   &#13;&#10; ) as T&#13;&#10; where T.qty_s &#62; 0                                        &#13;&#10; order by T.DEPT_ID,T.DRUG_NAME,T.WORKING_CODE,T.DEPT_NAME,T.SALE_UNIT  &#13;&#10;&#13;&#10;{ENDIF}     &#13;&#10;&#13;&#10;&#13;&#10;       " SpecificOptions.Text="" PropData="05704C65667402540470546F7002340A506172616D65746572730101062E204E616D653D22796D222044617461547970653D226674537472696E67222045787072657373696F6E3D22796D220001062E204E616D653D22796D222044617461547970653D226674537472696E67222045787072657373696F6E3D22796D220000"/>
  </TfrxDataPage>
