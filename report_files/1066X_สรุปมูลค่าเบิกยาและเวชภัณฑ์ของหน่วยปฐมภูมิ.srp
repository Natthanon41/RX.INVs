<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.894756169" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  ym,m,ymd ,: string ;&#13;&#10;  Line_no: integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  m1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),5,2) ;&#13;&#10;    y1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),1,4) ;&#13;&#10;&#13;&#10;  qry_dist_type.close ;&#13;&#10;  qry_dist_type.open ;&#13;&#10;&#13;&#10;  // qry_dist_type.first ;&#13;&#10;  cbb_distType.keyvalue:=1 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;   if strtoint(m1.text) &#60; 10 then m:='0'+inttostr(strtoint(m1.text)) else m:=m1.text ;&#13;&#10;   ym:=inttostr(strtoint(y1.text)-543)+m  ;&#13;&#10;   ymd:=ym+'01' ;&#13;&#10;&#13;&#10; end ;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  line_no:= 0 ;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure GroupHeader1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   line_no:=line_no+1 ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_rp1" DataSetName="rp1"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
    <item DataSet="qry_dist_type" DataSetName="dist_type"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp1" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;  &#13;&#10;select  d.DEPT_NAME,s.SUB_PO_NO,SUM(CASE when g.IS_ED in (1,2) then c.[VALUE] else 0 end) as MED,&#13;&#10;SUM(CASE when g.IS_ED not in (1,2) then c.[VALUE] else 0 end) as MEDSUP,&#13;&#10;(select SUM(s2.TOTAL_VALUE) from SM_PO s2 (NOLOCK) where s2.TOTAL_VALUE &#62; 0 &#13;&#10;and s2.STOCK_ID=s.STOCK_ID and s2.DEPT_ID=s.DEPT_ID &#13;&#10;and s2.SUB_PO_DATE &#62;= dbo.BEGIN_FY(getdate()) and  s2.SUB_PO_DATE &#60; :ymd /* and s2.SUB_PO_NO=s.SUB_PO_NO */) as BF,&#13;&#10;(select SUM(s2.TOTAL_VALUE) from SM_PO s2 (NOLOCK) where s2.TOTAL_VALUE &#62; 0    &#13;&#10;and s2.STOCK_ID=s.STOCK_ID and s2.DEPT_ID=s.DEPT_ID &#13;&#10;and s2.SUB_PO_DATE between dbo.BEGIN_FY(getdate()) and :ym +'31'  ) as BUY_ALL                   &#13;&#10;from SM_PO_C c (NOLOCK) &#13;&#10;left join SM_PO s (NOLOCK) on (c.SUB_PO_NO = s.SUB_PO_NO)&#13;&#10;left join DRUG_GN g (NOLOCK) on (c.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join DEPT_ID d (NOLOCK) on (d.DEPT_ID = s.DEPT_ID)&#13;&#10;where d.HOSP_TYPE=2 and left(s.SUB_PO_DATE,6)=:ym2        &#13;&#10;and s.STOCK_ID=:stock_id&#13;&#10;and s.DIST_TYPE=:disttype    &#13;&#10;and s.TOTAL_ITEM &#62; 0&#13;&#10;and (c.CANCEL_DISP='' or c.CANCEL_DISP is null or c.CANCEL_DISP='N')&#13;&#10;and c.CONFIRM_FLAG='Y'    &#13;&#10;GROUP BY d.DEPT_NAME,s.SUB_PO_NO,s.STOCK_ID,s.DEPT_ID&#13;&#10;order by d.DEPT_NAME&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;&#13;&#10;select  d.DEPT_NAME,s.SUB_PO_NO,SUM(CASE when g.IS_ED in (1,2) then c.`VALUE` else 0 end) as MED,&#13;&#10;SUM(CASE when g.IS_ED not in (1,2) then c.`VALUE` else 0 end) as MEDSUP,&#13;&#10;(select SUM(s2.TOTAL_VALUE) from SM_PO s2 where s2.TOTAL_VALUE &#62; 0 &#13;&#10;and s2.STOCK_ID=s.STOCK_ID and s2.DEPT_ID=s.DEPT_ID &#13;&#10;and s2.SUB_PO_DATE &#62;= BEGIN_FY(CURRENT_DATE()) and  s2.SUB_PO_DATE &#60; :ymd /* and s2.SUB_PO_NO=s.SUB_PO_NO */) as BF,&#13;&#10;(select SUM(s2.TOTAL_VALUE) from SM_PO s2 where s2.TOTAL_VALUE &#62; 0    &#13;&#10;and s2.STOCK_ID=s.STOCK_ID and s2.DEPT_ID=s.DEPT_ID &#13;&#10;and s2.SUB_PO_DATE between BEGIN_FY(CURRENT_DATE()) and :ym +'31'  ) as BUY_ALL                   &#13;&#10;from SM_PO_C c &#13;&#10;left join SM_PO s on (c.SUB_PO_NO = s.SUB_PO_NO)&#13;&#10;left join DRUG_GN g on (c.WORKING_CODE = g.WORKING_CODE)&#13;&#10;left join DEPT_ID d on (d.DEPT_ID = s.DEPT_ID)&#13;&#10;where d.HOSP_TYPE=2 and left(s.SUB_PO_DATE,6)=:ym2        &#13;&#10;and s.STOCK_ID=:stock_id&#13;&#10;and s.DIST_TYPE=:disttype    &#13;&#10;and s.TOTAL_ITEM &#62; 0&#13;&#10;and (c.CANCEL_DISP='' or c.CANCEL_DISP is null or c.CANCEL_DISP='N')&#13;&#10;and c.CONFIRM_FLAG='Y'    &#13;&#10;GROUP BY d.DEPT_NAME,s.SUB_PO_NO,s.STOCK_ID,s.DEPT_ID&#13;&#10;order by d.DEPT_NAME&#13;&#10;    &#13;&#10;&#13;&#10;&#13;&#10;{endif}            &#13;&#10;  " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{if sqlserver}&#13;&#10;  &#13;&#10;select * from DEPT_ID (nolock) where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;and DEPT_TYPE=2                                         &#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{else}&#13;&#10;&#13;&#10;select * from DEPT_ID where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;and DEPT_TYPE=2                                         &#13;&#10;order by DEPT_NAME    &#13;&#10;&#13;&#10;{endif}      " SpecificOptions.Text="" PropData="05704C65667402640470546F7003EC000A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_dist_type" UserName="dist_type" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select * from DIST_TYPE                                           " SpecificOptions.Text="" PropData="05704C65667403E4000470546F7003CC000A506172616D65746572730100"/>
  </TfrxDataPage>
