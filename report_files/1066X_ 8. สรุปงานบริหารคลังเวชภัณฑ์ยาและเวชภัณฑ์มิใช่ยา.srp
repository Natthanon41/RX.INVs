<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43550.6791011574" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  m0,y0,m_1,ym0,ym1 ,: string ;&#13;&#10;  Line_no: integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  m1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),5,2) ;&#13;&#10;    y1.Text:=COPY( DATEtoYMD(&#60;Date&#62;),1,4) ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  if   inttostr(strtoint(m1.text)) = '1' then&#13;&#10;  begin&#13;&#10;&#13;&#10;     m0:='12' ;&#13;&#10;     y0:=inttostr(strtoint(y1.text)-1-543) ;&#13;&#10;     m_1:='01' ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;&#13;&#10;    if   length(inttostr(strtoint(m1.text)-1)) = 1 then&#13;&#10;    begin&#13;&#10;      m0:= '0'+inttostr(strtoint(m1.text)-1);&#13;&#10;&#13;&#10;        if   length(inttostr(strtoint(m1.text))) = 1 then  m_1:= '0'+inttostr(strtoint(m1.text))&#13;&#10;        else m_1:= m1.text;&#13;&#10;&#13;&#10;    end&#13;&#10;    else&#13;&#10;    begin&#13;&#10;      m0:= inttostr(strtoint(m1.text)-1);&#13;&#10;      m_1:= m1.text;&#13;&#10;    end;&#13;&#10;&#13;&#10;   y0:=inttostr(strtoint(y1.text)-543) ;&#13;&#10;&#13;&#10;  end;&#13;&#10;&#13;&#10;  ym0:= y0 + m0 ;&#13;&#10;  ym1:=inttostr(strtoint(y1.text)-543)+m_1 ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10; end ;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  if (&#60;qry_sum_inv.&#34;FW_VALUE&#34;&#62; &#60;0.1) and (&#60;qry_sum_inv.&#34;RCV_VALUE&#34;&#62;&#60;0.1) and (&#60;qry_sum_inv.&#34;DIS_VALUE&#34;&#62;&#60;0.1) and (&#60;qry_sum_inv.&#34;RM_VALUE&#34;&#62;&#60;0.1)&#13;&#10;  then   MasterData1.visible:=False else  MasterData1.visible:=True ;&#13;&#10;&#13;&#10; if   MasterData1.visible then Line_no:=Line_no+1 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure qry_sum_invVALUE_ON_HANDOnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    if round(&#60;qry_sum_inv.&#34;FW_VALUE&#34;&#62;+&#60;qry_sum_inv.&#34;RCV_VALUE&#34;&#62;-&#60;qry_sum_inv.&#34;DIS_VALUE&#34;&#62;)&#60;&#62;round(&#60;qry_sum_inv.&#34;RM_VALUE&#34;&#62;)&#13;&#10;     then qry_sum_invVALUE_ON_HAND.font.color:=clRed else   qry_sum_invVALUE_ON_HAND.font.color:=clBlack ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_sum_inv" DataSetName="qry_sum_inv"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="qry_sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                             &#13;&#10;SELECT T.IS_ED,T.NLEM,SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE&#13;&#10;from (  &#13;&#10;select i.WORKING_CODE,dbo.NLEM(g.IS_ED) as NLEM, g.IS_ED,    &#13;&#10;&#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        /*left(c.R_S_DATE,6)*/ left(dbo.ce2cymd(c.OPERATE_DATE),6) between  left(dbo.ce2cymd(GETDATE()-900),6) and   :ym_fw                         &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as FW_VALUE,&#13;&#10;          &#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE ,&#13;&#10;      &#13;&#10;(select top 1 c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        /*left(c.R_S_DATE,6)*/ left(dbo.ce2cymd(c.OPERATE_DATE),6)  between  left(dbo.ce2cymd(GETDATE()-900),6)   and   :ym1                &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC ) as RM_VALUE,i.TOTAL_VALUE&#13;&#10;          &#13;&#10;from INV_MD i&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (&#13;&#10;   select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          						SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.[VALUE]&#13;&#10;                   when c1.R_S_STATUS in ('M','E','B') then c1.[VALUE]*-1        &#13;&#10;                   else NULL end) as RCV_VALUE,&#13;&#10;            						SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.[VALUE] &#13;&#10;	                     									 when (c1.R_S_STATUS in ('C','Z','U')) then c1.[VALUE]*-1 else NULL end) as DIS_VALUE&#13;&#10;            						from CARD c1&#13;&#10;            where c1.STOCK_ID=:dept0     &#13;&#10;            /*and left(c1.R_S_DATE,6)*/ and left(dbo.ce2cymd(c1.OPERATE_DATE),6) = :ym2  &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)    &#13;&#10;where i.DEPT_ID=:dept  and   g.WORKING_CODE is not null                                                                      &#13;&#10;)  as T&#13;&#10;/*where T.TOTAL_VALUE  &#62; 0.99 */&#13;&#10;/*where   FW_VALUE &#62; 0 and   RCV_VALUE &#62; 0 and   DIS_VALUE &#62; 0 and   RM_VALUE &#62; 0   */                                                                              &#13;&#10;group by T.IS_ED,T.NLEM&#13;&#10;order by T.IS_ED&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;&#13;&#10;SELECT T.NLEM,SUM(FW_VALUE) as FW_VALUE,SUM(RCV_VALUE) as RCV_VALUE,SUM(DIS_VALUE) as DIS_VALUE,SUM(RM_VALUE) as RM_VALUE&#13;&#10;from (  &#13;&#10;select i.WORKING_CODE,NLEM(g.IS_ED) as NLEM,&#13;&#10;&#13;&#10;(select  c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6) &#60;=   :ym_fw                         &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE  and  c.REMAIN_VALUE &#62;=0                                    &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1 ) as FW_VALUE,&#13;&#10;          &#13;&#10;Cx.RCV_VALUE,Cx.DIS_VALUE ,&#13;&#10;      &#13;&#10;(select  c.REMAIN_VALUE from  CARD c  &#13;&#10;        where &#13;&#10;        left(c.R_S_DATE,6)  &#60;=   :ym1                &#13;&#10;        and c.WORKING_CODE=i.WORKING_CODE   and  c.REMAIN_VALUE &#62;=0           &#13;&#10;        and c.STOCK_ID=i.DEPT_ID order by c.OPERATE_DATE DESC limit 1 ) as RM_VALUE,i.TOTAL_VALUE&#13;&#10;          &#13;&#10;from INV_MD i&#13;&#10;left join DRUG_GN g on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (&#13;&#10;   select c1.WORKING_CODE,c1.STOCK_ID,&#13;&#10;          						SUM(CASE when c1.R_S_STATUS in ('R','A','N','O','I','G') then c1.VALUE&#13;&#10;                   when c1.R_S_STATUS in ('M','E','B') then c1.VALUE*-1    &#13;&#10;                   else NULL end) as RCV_VALUE,&#13;&#10;            						SUM(CASE when c1.R_S_STATUS in ('S','P','D')  then c1.VALUE &#13;&#10;	                     									 when (c1.R_S_STATUS in ('C','Z','U')) then c1.VALUE*-1 else NULL end) as DIS_VALUE&#13;&#10;            						from CARD c1&#13;&#10;            where c1.STOCK_ID=:dept0     &#13;&#10;            and left(c1.R_S_DATE,6) = :ym2  &#13;&#10;            group by c1.WORKING_CODE,c1.STOCK_ID ) as Cx on (Cx.WORKING_CODE = i.WORKING_CODE  and Cx.STOCK_ID=i.DEPT_ID)    &#13;&#10;where i.DEPT_ID=:dept  and   g.WORKING_CODE is not null                                                                      &#13;&#10;)  as T&#13;&#10;/*where T.TOTAL_VALUE  &#62; 0.99 */&#13;&#10;/*where   FW_VALUE &#62; 0 and   RCV_VALUE &#62; 0 and   DIS_VALUE &#62; 0 and   RM_VALUE &#62; 0   */                                                                              &#13;&#10;group by T.NLEM  &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select * from DEPT_ID (NOLOCK) where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select * from DEPT_ID  where (HIDE='' or HIDE is null or HIDE='N')&#13;&#10;order by DEPT_NAME&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData="05704C65667402640470546F7003EC000A506172616D65746572730100"/>
  </TfrxDataPage>
