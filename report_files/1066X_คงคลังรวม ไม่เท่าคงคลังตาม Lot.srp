<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="43231.4524318287" ReportOptions.Description.Text="" ReportOptions.LastChange="43231.4956433218" ScriptLanguage="PascalScript" ScriptText.Text="begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="qry_inv" DataSetName="rp1"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_inv" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;  &#13;&#10;select i.WORKING_CODE,g.DRUG_NAME,i.QTY_ON_HAND,ISNULL(ic.QTY_LOT,0) as QTY_LOT  from INV_MD i (NOLOCK)&#13;&#10;left join &#13;&#10;( select  c.WORKING_CODE,SUM(c.QTY_ON_HAND) as QTY_LOT &#13;&#10;from INV_MD_C c (NOLOCK)&#13;&#10;Where c.DEPT_ID=:stock_id                &#13;&#10;GROUP BY c.WORKING_CODE) ic on (i.WORKING_CODE = ic.WORKING_CODE ) &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE = g.WORKING_CODE)&#13;&#10;Where i.DEPT_ID =:stock_id&#13;&#10;AND i.QTY_ON_HAND&#60;&#62;ISNULL(ic.QTY_LOT,0)&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;select i.WORKING_CODE,g.DRUG_NAME,i.QTY_ON_HAND,IFNULL(ic.QTY_LOT,0) as QTY_LOT  from INV_MD i &#13;&#10;left join &#13;&#10;( select  c.WORKING_CODE,SUM(c.QTY_ON_HAND) as QTY_LOT &#13;&#10;from INV_MD_C c&#13;&#10;Where c.DEPT_ID=:stock_id                &#13;&#10;GROUP BY c.WORKING_CODE) ic on (i.WORKING_CODE = ic.WORKING_CODE ) &#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE = g.WORKING_CODE)&#13;&#10;Where i.DEPT_ID =:stock_id&#13;&#10;AND i.QTY_ON_HAND&#60;&#62;IFNULL(ic.QTY_LOT,0)&#13;&#10;&#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
