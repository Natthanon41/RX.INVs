<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="45240.4291962269" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10; input_year : integer ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;  monthx.text:= formatdatetime('mm',now-29) ;&#13;&#10;  yearx.text:=  inttostr(strtoint(formatdatetime('YYYY',now-30))+543) ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;  date1.date:=now-30 ;&#13;&#10;  date2.date:=now ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure monthxOnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;    input_year:= strtoint(yearx.text)-543 ;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="frxReport1OnReportPrint">
  <Datasets>
    <item DataSet="qry_rp" DataSetName="rp1"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxUniDACQuery Name="qry_rp" UserName="rp1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;&#13;&#10;{ELSE}&#13;&#10;&#13;&#10;SELECT &#13;&#10;/*หน่วยงานภายใน รพ.*/&#13;&#10;COUNT(distinct CASE WHEN LEFT(o.DEPT_ID,2) IN ('AN') OR &#13;&#10;LEFT(o.DEPT_ID,3) IN ('CAR','COH','DEN','DIA','EME','ENG','ENT','FOO','GYN','HEA','ICU','IPD','LAB',&#13;&#10;'MAN','MED','NUR','OPD','OPE','PED','PHI','PHY','PSY','SEM','STI','SUP','SUR','TRA','VEJ','WAS','WEL','XRA') &#13;&#10;THEN c.SUB_PO_NO END) AS nDept,&#13;&#10;COUNT(CASE WHEN LEFT(o.DEPT_ID,2) IN ('AN') OR &#13;&#10;LEFT(o.DEPT_ID,3) IN ('CAR','COH','DEN','DIA','EME','ENG','ENT','FOO','GYN','HEA','ICU','IPD','LAB',&#13;&#10;'MAN','MED','NUR','OPD','OPE','PED','PHI','PHY','PSY','SEM','STI','SUP','SUR','TRA','VEJ','WAS','WEL','XRA') &#13;&#10;then c.TRADE_CODE END) AS itemsDept,&#13;&#10;SUM(CASE WHEN LEFT(o.DEPT_ID,2) IN ('AN') OR &#13;&#10;LEFT(o.DEPT_ID,3) IN ('CAR','COH','DEN','DIA','EME','ENG','ENT','FOO','GYN','HEA','ICU','IPD','LAB',&#13;&#10;'MAN','MED','NUR','OPD','OPE','PED','PHI','PHY','PSY','SEM','STI','SUP','SUR','TRA','VEJ','WAS','WEL','XRA') &#13;&#10;then c.VALUE END) AS valueDept,&#13;&#10;/*รพ สต*/&#13;&#10;COUNT(distinct CASE WHEN LEFT(o.DEPT_ID,2) = 'HC' OR o.DEPT_ID = 'PHA04' then c.SUB_PO_NO END) AS nHC,&#13;&#10;COUNT(CASE WHEN LEFT(o.DEPT_ID,2) = 'HC' OR o.DEPT_ID = 'PHA04' then c.TRADE_CODE END) AS itemsHC,&#13;&#10;SUM(CASE WHEN LEFT(o.DEPT_ID,2) = 'HC' OR o.DEPT_ID = 'PHA04' then c.VALUE END) AS valueHC,&#13;&#10;/*หน่วยงานราชการ*/&#13;&#10;COUNT(distinct CASE WHEN o.DEPT_ID IN ('BAN01','DUM01','GPO01','JED01','NHSO1','RAC01','SIR01','WAT01') then c.SUB_PO_NO END) AS nHOS,&#13;&#10;COUNT(CASE WHEN o.DEPT_ID IN ('BAN01','DUM01','GPO01','JED01','NHSO1','RAC01','SIR01','WAT01') then c.TRADE_CODE END) AS itemsHOS,&#13;&#10;SUM(CASE WHEN o.DEPT_ID IN ('BAN01','DUM01','GPO01','JED01','NHSO1','RAC01','SIR01','WAT01') then c.VALUE END) AS valueHOS,&#13;&#10;/*บริบาลเภสัช*/&#13;&#10;COUNT(distinct CASE WHEN o.DEPT_ID IN ('IPD01','IPD02','OPD01','OPD02','PHA01','PHA07','SUBST1') then c.SUB_PO_NO END) AS nRx,&#13;&#10;COUNT(CASE WHEN o.DEPT_ID IN ('IPD01','IPD02','OPD01','OPD02','PHA01','PHA07','SUBST1') then c.TRADE_CODE END) AS itemsRx,&#13;&#10;SUM(CASE WHEN o.DEPT_ID IN ('IPD01','IPD02','OPD01','OPD02','PHA01','PHA07','SUBST1') then c.VALUE END) AS valueRx,&#13;&#10;/*ผลิต*/&#13;&#10;COUNT(distinct CASE WHEN o.DEPT_ID = 'PHA02' then c.SUB_PO_NO END) AS nTPN,&#13;&#10;COUNT(CASE WHEN o.DEPT_ID = 'PHA02' then c.TRADE_CODE END) AS itemsTPN,&#13;&#10;SUM(CASE WHEN o.DEPT_ID = 'PHA02' then c.VALUE END) AS valueTPN,&#13;&#10;/*ปราศจากเชื้อ*/&#13;&#10;COUNT(distinct CASE WHEN o.DEPT_ID = 'PHA03' then c.SUB_PO_NO END) AS nSTERILE,&#13;&#10;COUNT(CASE WHEN o.DEPT_ID = 'PHA03' then c.TRADE_CODE END) AS itemsSTERILE,&#13;&#10;SUM(CASE WHEN o.DEPT_ID = 'PHA03' then c.VALUE END) AS valueSTERILE&#13;&#10;FROM sm_po_c c&#13;&#10;LEFT JOIN sm_po o ON o.SUB_PO_NO = c.SUB_PO_NO&#13;&#10;WHERE c.CONFIRM_DATE BETWEEN :date1 and :date2&#13;&#10;AND o.STOCK_ID =:stock_id&#13;&#10;AND o.DEPT_ID NOT IN ('STOCK1','STOCK2','PT01','SAN01')&#13;&#10;AND c.CANCEL_DISP IS NULL        &#13;&#10;&#13;&#10;{ENDIF}                " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}                                                        &#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME&#13;&#10;&#13;&#10; {ELSE}&#13;&#10;&#13;&#10; select * from DEPT_ID  where HIDE=''&#13;&#10; or HIDE is null&#13;&#10;  or HIDE='N'             &#13;&#10; order by DEPT_NAME&#13;&#10;&#13;&#10; {ENDIF}                 " SpecificOptions.Text="" PropData="05704C65667402580470546F7002700A506172616D65746572730100"/>
  </TfrxDataPage>
