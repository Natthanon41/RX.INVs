<?xml version="1.0" encoding="utf-8" standalone="no"?>
<TfrxReport Version="6.9.2" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="12287" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="41546.6611873611" ReportOptions.Description.Text="" ReportOptions.LastChange="43260.1104299421" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  m0,y0,ym1,ym2 : string ;&#13;&#10;&#13;&#10;procedure DialogPage1OnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  qry_stock.close ;&#13;&#10;  qry_stock.open ;&#13;&#10;&#13;&#10;&#13;&#10;  cbb_stock.keyvalue:= &#60;MY_STOCK_CODE&#62; ;&#13;&#10;  m1.text:=FormatDateTime('MM',&#60;Date&#62;-30) ;&#13;&#10;  y1.text:= inttostr(strtoint(FormatDateTime('YYYY',&#60;Date&#62;)) + 543)  ;&#13;&#10;  m2.text:=FormatDateTime('MM',&#60;Date&#62;) ;&#13;&#10;  y2.text:= inttostr(strtoint(FormatDateTime('YYYY',&#60;Date&#62;)) + 543)  ;&#13;&#10;&#13;&#10;   cbb_stock.keyvalue:=&#60;MY_STOCK_CODE&#62; ;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DialogPage1OnShow(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  if   strtoint(m1.text) = 1 then&#13;&#10;  begin&#13;&#10;    m0:='12' ;&#13;&#10;    y0:=inttostr(strtoint(y1.text)-1-543) ;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;&#13;&#10;    if   length(inttostr(strtoint(m1.text)-1)) = 1 then&#13;&#10;    m0:= '0'+inttostr(strtoint(m1.text)-1) else  m0:=inttostr(strtoint(m1.text)-1);&#13;&#10;&#13;&#10;    y0:=inttostr(strtoint(y1.text)-543) ;&#13;&#10;&#13;&#10;  end;&#13;&#10;&#13;&#10;  if length(m1.text)=1 then&#13;&#10;  begin&#13;&#10;    ym1:=inttostr(strtoint(y1.text)-543)+'0'+m1.text ;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;    ym1:=inttostr(strtoint(y1.text)-543)+m1.text ;&#13;&#10;  end;&#13;&#10;&#13;&#10;   if   strtoint(m2.text) = 1 then&#13;&#10;  begin&#13;&#10;    m0:='12' ;&#13;&#10;    y0:=inttostr(strtoint(y2.text)-1-543) ;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;&#13;&#10;  //***************************************************************************************&#13;&#10;&#13;&#10;    if   length(inttostr(strtoint(m2.text)-1)) = 1 then&#13;&#10;    m0:= '0'+inttostr(strtoint(m2.text)-1) else  m0:=inttostr(strtoint(m2.text)-1);&#13;&#10;&#13;&#10;    y0:=inttostr(strtoint(y2.text)-543) ;&#13;&#10;&#13;&#10;  end;&#13;&#10;&#13;&#10;  if length(m2.text)=1 then&#13;&#10;  begin&#13;&#10;    ym2:=inttostr(strtoint(y2.text)-543)+'0'+m2.text ;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;    ym2:=inttostr(strtoint(y2.text)-543)+m2.text ;&#13;&#10;  end;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   qry_nlem.close ;&#13;&#10;   qry_nlem.open ;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
  <Datasets>
    <item DataSet="ADOQuery1" DataSetName="ADOQuery1"/>
    <item DataSet="qry_sum_inv" DataSetName="sum_inv"/>
    <item DataSet="qry_stock" DataSetName="stock"/>
    <item DataSet="qry_nlem" DataSetName="nlem"/>
  </Datasets>
  <Variables>
    <item Name="MY_STOCK_CODE"/>
    <item Name="MY_STOCK_NAME"/>
    <item Name="hosp_name"/>
  </Variables>
  <TfrxDataPage Name="Data" HGuides.Text="" VGuides.Text="" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxADOQuery Name="ADOQuery1" UserName="ADOQuery1" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="/*      &#13;&#10;select m.YEAR,m.MONTH,g.DRUG_NAME,i.FIRST_PACK_RATIO,(m2.QTY_ON_HAND) as LATER_ON_HAND,SUM(m.RCV_QUAN) as RCV_QUAN,isnull(m2.QTY_ON_HAND,0)+SUM(isnull(m.RCV_QUAN,0)) as SUM_RCV,&#13;&#10;SUM(m.SALE_QUAN) as SALE_QUAN,SUM(m.SALE_VALUE) as SALE_VALUE,SUM(m.QTY_ON_HAND) as QTY_ON_HAND,SUM(m.VALUE_ON_HAND) as VALUE_ON_HAND&#13;&#10;from MBS_RE_M m (NOLOCK)&#13;&#10;left join DRUG_GN g (NOLOCK) on (m.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join  (select SUM(mx.QTY_ON_HAND) as QTY_ON_HAND, mx.DEPT_ID,mx.WORKING_CODE from MBS_RE_M mx (NOLOCK)  &#13;&#10;where mx.YEAR=:y0 and mx.MONTH=:m0 and mx.DEPT_ID=:stock0  group by mx.DEPT_ID,mx.WORKING_CODE) as m2&#13;&#10;on ( m2.DEPT_ID=m.DEPT_ID and m.WORKING_CODE=m2.WORKING_CODE )&#13;&#10;left join INV_MD i (NOLOCK) on (i.WORKING_CODE=m.WORKING_CODE and i.DEPT_ID=m.DEPT_ID)&#13;&#10;where m.[YEAR]+m.[MONTH]=:ym1              &#13;&#10;and m.DEPT_ID=:stock1&#13;&#10;and ISNULL(m.SALE_QUAN,0)=0                                       &#13;&#10;group by g.DRUG_NAME,i.FIRST_PACK_RATIO ,m2.QTY_ON_HAND,m.YEAR,m.MONTH      &#13;&#10;order by m.YEAR,m.MONTH, g.DRUG_NAME&#13;&#10;*/      " CommandTimeout="30" LockType="ltReadOnly" PropData=""/>
    <TfrxUniDACQuery Name="qry_sum_inv" UserName="sum_inv" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="{IF SQLSERVER}&#13;&#10;&#13;&#10;select i.WORKING_CODE,&#13;&#10;g.DRUG_NAME,i.FIRST_PACK_RATIO,i.QTY_ON_HAND,s.SUB_COMMIT_DES,i.TOTAL_VALUE,i.TOTAL_COST                                                                &#13;&#10;from INV_MD i (NOLOCK)&#13;&#10;left join DRUG_GN g (NOLOCK) on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join SUB_COM s (NOLOCK) on (g.SUBCOM=s.SUB_COMMIT_CODE)                        &#13;&#10;where      &#13;&#10;i.DEPT_ID=:stock1  and i.QTY_ON_HAND &#62; 0     &#13;&#10;and not EXISTS(select * from CARD c &#13;&#10;where c.STOCK_ID=i.DEPT_ID&#13;&#10;and  left(c.R_S_DATE,6) between :ym1  and :ym2                     &#13;&#10;and i.WORKING_CODE=c.WORKING_CODE )&#13;&#10;order by i.TOTAL_COST DESC    &#13;&#10;&#13;&#10; {ELSE}&#13;&#10;&#13;&#10;select i.WORKING_CODE,&#13;&#10;g.DRUG_NAME,i.FIRST_PACK_RATIO,i.QTY_ON_HAND,s.SUB_COMMIT_DES,i.TOTAL_VALUE,i.TOTAL_COST                                                                &#13;&#10;from INV_MD i &#13;&#10;left join DRUG_GN g  on (i.WORKING_CODE=g.WORKING_CODE)&#13;&#10;left join SUB_COM s  on (g.SUBCOM=s.SUB_COMMIT_CODE)                        &#13;&#10;where      &#13;&#10;i.DEPT_ID=:stock1  and i.QTY_ON_HAND &#62; 0     &#13;&#10;and not EXISTS(select * from CARD c &#13;&#10;where c.STOCK_ID=i.DEPT_ID&#13;&#10;and  left(c.R_S_DATE,6) between :ym1  and :ym2                     &#13;&#10;and i.WORKING_CODE=c.WORKING_CODE )&#13;&#10;order by i.TOTAL_COST DESC  &#13;&#10;&#13;&#10;&#13;&#10; {ENDIF}    &#13;&#10;&#13;&#10;             " SpecificOptions.Text="" PropData=""/>
    <TfrxUniDACQuery Name="qry_stock" UserName="stock" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="&#13;&#10;{IF SQLSERVER}&#13;&#10;&#13;&#10;select * from DEPT_ID (NOLOCK) where HIDE='' or HIDE is null or   HIDE='N'&#13;&#10;order by DEPT_NAME&#13;&#10;  &#13;&#10; {ELSE}&#13;&#10;&#13;&#10;&#13;&#10;select * from DEPT_ID  where HIDE='' or HIDE is null or   HIDE='N'&#13;&#10;order by DEPT_NAME  &#13;&#10;&#13;&#10; {ENDIF}    &#13;&#10;&#13;&#10;                                         " SpecificOptions.Text="" PropData="05704C6566740328010470546F700348010A506172616D65746572730100"/>
    <TfrxUniDACQuery Name="qry_nlem" UserName="nlem" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text=" {IF SQLSERVER}&#13;&#10;&#13;&#10;select top 1  dbo.IS_ED(d.IS_ED) as NLEM from DRUG_VN d&#13;&#10;where WORKING_CODE=:working_code&#13;&#10;and     d.IS_ED is not null and d.IS_ED&#60;&#62;''&#13;&#10;&#13;&#10;  &#13;&#10; {ELSE}&#13;&#10;&#13;&#10;select   dbo.IS_ED(d.IS_ED) as NLEM from DRUG_VN d&#13;&#10;where WORKING_CODE=:working_code&#13;&#10;and     d.IS_ED is not null and d.IS_ED&#60;&#62;''    limit 1                                           &#13;&#10;&#13;&#10;&#13;&#10; {ENDIF}    &#13;&#10;&#13;&#10;                                                              " SpecificOptions.Text="" PropData=""/>
  </TfrxDataPage>
